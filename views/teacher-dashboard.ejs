                    </div>
                    <% } else { %>
                        <div class="ghost-note">No groups yet. Create one above to start assigning students and tests.
                        </div>
                        <% } %>
            </section>

            <section class="card">
                <div class="page-header">
                    <div>
                        <h2>All Students</h2>
                        <p>Keep track of current group placement and remove student accounts when needed.</p>
                    </div>
                    <a href="/teacher/add-student" class="btn btn-success">+ Register Student</a>
                </div>

                <% if (allStudents.length> 0) { %>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Current Group</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% allStudents.forEach(student=> { %>
                                    <% const activeGroup=groups.find(group=> String(group._id) ===
                                        String(student.groupId)); %>
                                        <tr>
                                            <td style="font-weight: 800;">
                                                <%= student.username %>
                                            </td>
                                            <td>
                                                <% if (activeGroup) { %>
                                                    <span class="tag">
                                                        <%= activeGroup.name %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="tag muted">Unassigned</span>
                                                        <% } %>
                                            </td>
                                            <td>
                                                <div class="action-row">
                                                    <button class="btn btn-ghost"
                                                        onclick="viewPassword('<%= student._id %>', '<%= student.username %>')"
                                                        style="padding:8px 14px;font-size:0.85rem;">🔑 View
                                                        Password</button>
                                                    <button class="btn btn-danger"
                                                        onclick="deleteItem('student', '<%= student._id %>', '<%= student.username %>')">Delete</button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="ghost-note">No students registered yet. Use the register button to create the first
                            student account.</div>
                        <% } %>
            </section>
        </main>


       
</body>

</html>