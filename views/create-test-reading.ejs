                                        <span class="sel-text">Select...</span>
                                        <span class="sel-arrow">▼</span>
                                    </div>
                                    <div class="custom-select-options">
                                        <div class="custom-option clear-opt" onclick="selectCustomOption(this, '${currentQ}', '')">✕ Clear Answer</div>`;
                    featureLetters.forEach(L => { 
                        html += `       <div class="custom-option" onclick="selectCustomOption(this, '${currentQ}', '${L}')"><b>${L}</b></div>`; 
                    });
                    html += `       </div>
                                    <input type="hidden" id="q${currentQ}" value="" ${AC_OFF}>
                                 </div>
                             </div>`;
                    if(aInputs[i].value.trim()) updateAnswerKey(currentQ, aInputs[i].value.trim().toUpperCase());
                    currentQ++;
                }
            }
            html += `\n</div></div>`;
            document.getElementById(`gen_q_num_${partNum}`).value = currentQ;
            
        } else if (type === 'drag') {
            const val = document.getElementById(`drag_val_${partNum}`).value.trim();
            const text = document.getElementById(`drag_text_${partNum}`).value.trim();
            const linkId = document.getElementById(`drag_link_id_${partNum}`).value.trim();
            const uniqueDragId = "ditem_" + Date.now() + "_" + Math.floor(Math.random()*1000);
            html = `<div class="drag-wrapper">
    <div class="draggable-item" id="${uniqueDragId}" draggable="true" ondragstart="drag(event)" data-val="${val}">
        <span class="drag-handle">::</span>
        <span class="drag-val-visible">${val}</span>
        <span class="drag-text">${text}</span>
    </div>
    <button class="manual-strike-btn" onclick="toggleStrike(this)" title="Cross out">✕</button>
</div>`;
            if(linkId) updateAnswerKey(linkId, val);
            document.getElementById(`drag_val_${partNum}`).value = ""; document.getElementById(`drag_text_${partNum}`).value = ""; document.getElementById(`drag_link_id_${partNum}`).value = "";
            
        } else if (type === 'gap') {
            let content = document.getElementById(`gap_editor_${partNum}`).innerHTML;
            if(!content.trim()) { alert("Gap text is empty."); return; }
            // Clean inline background/colors secretly injected by browsers
            content = content.replace(/(background-color|color)\s*:\s*[^;"]+;?/gi, '');
            html = `<div class="gap-fill-text">${content}</div>`;
            document.getElementById(`gap_editor_${partNum}`).innerHTML = "";
            
        } else if (type === 'gap_drag') {
            let content = document.getElementById(`gap_drag_editor_${partNum}`).innerHTML;
            // Clean inline background/colors secretly injected by browsers
            content = content.replace(/(background-color|color)\s*:\s*[^;"]+;?/gi, '');
            const optsRaw = document.getElementById(`gap_drag_opts_${partNum}`).value;
            if(!content.trim()) { alert("Text is empty."); return; }
            let poolHtml = "";
            if(optsRaw.trim()) {
                poolHtml = `<div class="pool-container">`;
                optsRaw.split(',').forEach((opt, idx) => {
                    const o = opt.trim();
                    const uId = "pool_" + Date.now() + "_" + idx;
                    if(o) poolHtml += `<div class="chip-item" id="${uId}" draggable="true" ondragstart="drag(event)" data-val="${o}">${o}</div>`;
                });
                poolHtml += `</div>`;
            }
            html = `<div class="gap-fill-text">${poolHtml}${content}</div>`;
            document.getElementById(`gap_drag_editor_${partNum}`).innerHTML = "";
            document.getElementById(`gap_drag_opts_${partNum}`).value = "";
            
        } else if (type === 'pick2' || type === 'pick3' || type === 'pick5') {
    const qNumStart = parseInt(document.getElementById(`gen_q_num_${partNum}`).value);
    const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
    const ans1 = document.getElementById(`pick_ans1_${partNum}`).value;
    const ans2 = document.getElementById(`pick_ans2_${partNum}`).value;
    let ans3 = null, ans4 = null, ans5 = null; 
    let limit = 2; let qNumEnd = qNumStart + 1;
    
    if (type === 'pick3' || type === 'pick5') { 
        ans3 = document.getElementById(`pick_ans3_${partNum}`).value; 
        if (type === 'pick3') { limit = 3; qNumEnd = qNumStart + 2; }
    }
    if (type === 'pick5') { 
        ans4 = document.getElementById(`pick_ans4_${partNum}`).value; 
        ans5 = document.getElementById(`pick_ans5_${partNum}`).value; 
        limit = 5; qNumEnd = qNumStart + 4; 
    }
    
    html = `<div class="pick-n-question" data-group-start="${qNumStart}" data-limit="${limit}">
                <div class="question-prompt"><p><strong>${qNumStart}-${qNumEnd}</strong> ${formatText(prompt)}</p></div>`;
    const inputs = document.querySelectorAll(`.mcq-input-${partNum}`);
    let qIds = []; for(let k=0; k<limit; k++) qIds.push(qNumStart + k); const dataQ = qIds.join(" ");
    
    inputs.forEach((inp, idx) => {
        const letter = String.fromCharCode(65 + idx);
        html += `\n<div class="multi-choice-option">
                    <label class="modern-label">
                        <input type="checkbox" class="multi-checkbox hidden-cb" data-questions="${dataQ}" value="${letter}" ${AC_OFF}>
                        <span class="custom-cb"></span>
                        <span class="opt-text"><b>${letter}.</b> ${inp.value.trim()}</span>
                    </label>
                 </div>`;
    });
    html += `\n</div>`;
    
    updateAnswerKey(qNumStart, ans1); 
    updateAnswerKey(qNumStart + 1, ans2); 
    if(type === 'pick3' || type === 'pick5') updateAnswerKey(qNumStart + 2, ans3);
    if(type === 'pick5') {
        updateAnswerKey(qNumStart + 3, ans4);
        updateAnswerKey(qNumStart + 4, ans5);
    }
    
    document.getElementById(`gen_q_num_${partNum}`).value = qNumStart + limit;
    document.getElementById(`gen_prompt_${partNum}`).value = "";
    document.getElementById(`pick_ans1_${partNum}`).value = ""; 
    document.getElementById(`pick_ans2_${partNum}`).value = ""; 
    document.getElementById(`pick_ans3_${partNum}`).value = "";
    if (document.getElementById(`pick_ans4_${partNum}`)) document.getElementById(`pick_ans4_${partNum}`).value = "";
    if (document.getElementById(`pick_ans5_${partNum}`)) document.getElementById(`pick_ans5_${partNum}`).value = "";
    document.querySelectorAll(`.mcq-input-${partNum}`).forEach(i => i.value = "");
    
} else {
            const qNum = document.getElementById(`gen_q_num_${partNum}`).value;
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            const ans = document.getElementById(`gen_ans_${partNum}`).value;
            if (type === 'mcq') {
                html = `<div class="multi-choice-question" data-q-start="${qNum}"><div class="question-prompt"><p><strong>${qNum}</strong> ${formatText(prompt)}</p></div>`;
                const inputs = document.querySelectorAll(`.mcq-input-${partNum}`);
                inputs.forEach((inp, idx) => {
                    const letter = String.fromCharCode(65 + idx);
                    html += `\n<div class="multi-choice-option">
                                <label class="modern-label">
                                    <input type="radio" name="q${qNum}" class="hidden-cb" value="${letter}" ${AC_OFF} ondblclick="this.checked=false; saveState();">
                                    <span class="custom-radio"></span>
                                    <span class="opt-text"><b>${letter}.</b> ${inp.value.trim()}</span>
                                </label>
                             </div>`;
                });
                html += `\n</div>`;
            } else if (type === 'tf' || type === 'yn') {
                const t = type === 'tf' ? 'TRUE' : 'YES'; const f = type === 'tf' ? 'FALSE' : 'NO';
                html = `<div class="tf-question" data-q-start="${qNum}">
                            <div class="tf-question-line"><span class="tf-question-number">${qNum}</span><div class="tf-question-text">${formatText(prompt)}</div></div>
                            <div class="tf-options">
                                <div class="tf-option"><label class="modern-label"><input type="radio" name="q${qNum}" class="hidden-cb" value="${t}" ${AC_OFF} ondblclick="this.checked=false; saveState();"> <span class="custom-radio"></span> <span class="opt-text">${t}</span></label></div>
                                <div class="tf-option"><label class="modern-label"><input type="radio" name="q${qNum}" class="hidden-cb" value="${f}" ${AC_OFF} ondblclick="this.checked=false; saveState();"> <span class="custom-radio"></span> <span class="opt-text">${f}</span></label></div>
                                <div class="tf-option"><label class="modern-label"><input type="radio" name="q${qNum}" class="hidden-cb" value="NOT GIVEN" ${AC_OFF} ondblclick="this.checked=false; saveState();"> <span class="custom-radio"></span> <span class="opt-text">NOT GIVEN</span></label></div>
                            </div>
                        </div>`;
            } else if (type === 'input') {
                html = `<div class="short-answer-question" data-q-start="${qNum}"><p><strong>${qNum}</strong> ${formatText(prompt)} <input id="q${qNum}" class="answer-input" placeholder="${qNum}" style="width:160px;" ${AC_OFF}></p></div>`;
            }
            updateAnswerKey(qNum, ans);
            document.getElementById(`gen_q_num_${partNum}`).value = parseInt(qNum) + 1;
            document.getElementById(`gen_prompt_${partNum}`).value = "";
            document.getElementById(`gen_ans_${partNum}`).value = "";
            document.querySelectorAll(`.mcq-input-${partNum}`).forEach(i => i.value = "");
        }
        targetArea.value += html + "\n";
    }

    function saveProject() {
        const data = {
            p1_title: document.getElementById('p1_title').value,
            p1_text: document.getElementById('p1_text').value,
            p2_title: document.getElementById('p2_title').value,
            p2_text: document.getElementById('p2_text').value,
            p3_title: document.getElementById('p3_title').value,
            p3_text: document.getElementById('p3_text').value,
            q1_text: document.getElementById('q1_text').value,
            q2_text: document.getElementById('q2_text').value,
            q3_text: document.getElementById('q3_text').value,
            answer_key: document.getElementById('answer_key_json').value
        };
        const blob = new Blob([JSON.stringify(data)], {type: "application/json"});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = "ielts_project.json";
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
    }

    function loadProject(input) {
        const file = input.files[0];
        if(!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const data = JSON.parse(e.target.result);
                document.getElementById('p1_title').value = data.p1_title || "";
                document.getElementById('p1_text').value = data.p1_text || "";
                document.getElementById('p2_title').value = data.p2_title || "";
                document.getElementById('p2_text').value = data.p2_text || "";
                document.getElementById('p3_title').value = data.p3_title || "";
                document.getElementById('p3_text').value = data.p3_text || "";
                document.getElementById('q1_text').value = data.q1_text || "";
                document.getElementById('q2_text').value = data.q2_text || "";
                document.getElementById('q3_text').value = data.q3_text || "";
                document.getElementById('answer_key_json').value = data.answer_key || "{}";
                alert("Project loaded successfully!");
            } catch(err) { alert("Grading Error: " + err.message); }
        };
        reader.readAsText(file);
    }

    renderTabs();

    async function generateFile() {
    const getVal = (id) => document.getElementById(id).value;

    // 1. Gather all the data from your builder tabs
    const testData = {
        title: getVal('p1_title'), 
        content: {
            p1: { title: getVal('p1_title'), text: getVal('p1_text'), questions: getVal('q1_text') },
            p2: { title: getVal('p2_title'), text: getVal('p2_text'), questions: getVal('q2_text') },
            p3: { title: getVal('p3_title'), text: getVal('p3_text'), questions: getVal('q3_text') },
            answerKey: JSON.parse(getVal('answer_key_json') || "{}")
        }
    };

    const btn = document.getElementById('downloadBtn');
    btn.innerText = "⏳ Saving to Cloud...";

    try {
        // 2. Send the data to your Node.js server route
        const response = await fetch('/create-test/reading', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(testData)
        });

        const result = await response.json();

        if (result.success) {
            btn.innerText = "✅ Saved Successfully!";
            btn.style.background = "#27ae60";
            // Redirect back to admin dashboard after saving
            setTimeout(() => { window.location.href = "/admin"; }, 1500);
        } else {
            alert("Error: " + result.error);
            btn.innerText = "Try Again";
        }
    } catch (err) {
        console.error("Upload failed:", err);
        alert("Server connection failed. Make sure your server is running!");
        btn.innerText = "Save to Website";
    }
}
</script>
</body>
</html>