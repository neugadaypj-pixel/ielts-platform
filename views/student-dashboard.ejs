<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: "Segoe UI", "Trebuchet MS", sans-serif;
            min-height: 100vh;
            color: #1f2937;
            background:
                radial-gradient(circle at top left, rgba(255,255,255,0.45), transparent 30%),
                linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            padding: 24px;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
        }

        .hero {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: center;
            padding: 30px;
            border-radius: 30px;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            margin-bottom: 24px;
        }

        .hero h1 {
            font-size: 2.3rem;
            font-weight: 900;
            letter-spacing: -0.04em;
            margin-bottom: 10px;
        }

        .hero p {
            color: #64748b;
            line-height: 1.6;
        }

        .group-pill {
            display: inline-flex;
            align-items: center;
            padding: 9px 14px;
            border-radius: 999px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-weight: 800;
            margin-top: 12px;
        }

        .logout {
            text-decoration: none;
            border-radius: 999px;
            padding: 12px 18px;
            background: white;
            color: #334155;
            border: 1px solid #dbe3f1;
            font-weight: 800;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
        }

        .section {
            padding: 26px;
            border-radius: 28px;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(16px);
            box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
            margin-bottom: 22px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
            margin-bottom: 18px;
        }

        .section-header h2 {
            font-size: 1.45rem;
            font-weight: 900;
            margin-bottom: 8px;
        }

        .section-header p {
            color: #64748b;
            line-height: 1.6;
        }

        .type-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .type-column {
            padding: 18px;
            border-radius: 24px;
            border: 1px solid #e2e8f0;
            background: linear-gradient(180deg, rgba(248,250,252,0.92) 0%, rgba(241,245,249,0.78) 100%);
        }

        .reading { border-top: 6px solid #3b82f6; }
        .listening { border-top: 6px solid #10b981; }
        .writing { border-top: 6px solid #f97316; }

        .type-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }

        .type-header h3 {
            font-size: 1.12rem;
            font-weight: 900;
        }

        .badge {
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 800;
            background: white;
            border: 1px solid #dbe3f1;
            color: #334155;
        }

        .test-list {
            display: grid;
            gap: 14px;
        }

        .test-card {
            padding: 18px;
            border-radius: 22px;
            background: white;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        }

        .test-card h4 {
            font-size: 1.06rem;
            font-weight: 900;
            margin-bottom: 8px;
        }

        .test-card p {
            color: #64748b;
            line-height: 1.55;
            font-size: 0.92rem;
        }

        .meta-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 14px 0;
        }

        .meta-pill {
            padding: 7px 11px;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 800;
            background: #eef2ff;
            color: #4338ca;
        }

        .meta-pill.success {
            background: #dcfce7;
            color: #166534;
        }

        .meta-pill.warning {
            background: #fee2e2;
            color: #b91c1c;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 11px 16px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 800;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .btn:hover { transform: translateY(-2px); }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 12px 26px rgba(102, 126, 234, 0.26);
        }

        .empty {
            padding: 18px;
            border-radius: 18px;
            background: rgba(255,255,255,0.75);
            border: 1px dashed #cbd5e1;
            color: #64748b;
        }

        @media (max-width: 1180px) {
            .type-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 760px) {
            body { padding: 16px; }
            .hero { flex-direction: column; align-items: flex-start; }
        }

        /* Dark Mode */
        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #e2e8f0;
        }
        body.dark-mode .hero, body.dark-mode .section {
            background: rgba(30, 41, 59, 0.92);
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.3);
        }
        body.dark-mode h1, body.dark-mode h2, body.dark-mode h3, body.dark-mode h4 {
            color: #f1f5f9;
        }
        body.dark-mode p, body.dark-mode .empty {
            color: #94a3b8;
        }
        body.dark-mode .type-column {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.92) 0%, rgba(15, 23, 42, 0.78) 100%);
            border-color: #334155;
        }
        body.dark-mode .test-card {
            background: rgba(30, 41, 59, 0.98);
            border-color: #334155;
        }
        body.dark-mode .logout, body.dark-mode .badge {
            background: rgba(51, 65, 85, 0.9);
            color: #e2e8f0;
            border-color: #475569;
        }
        body.dark-mode .meta-pill {
            background: rgba(102, 126, 234, 0.2);
            color: #a5b4fc;
        }
        body.dark-mode .meta-pill.success {
            background: rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
        }
        body.dark-mode .meta-pill.warning {
            background: rgba(239, 68, 68, 0.2);
            color: #fca5a5;
        }

        .theme-toggle {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 1000;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 12px 28px rgba(102, 126, 234, 0.3);
            transition: transform 0.2s ease;
        }
        .theme-toggle:hover {
            transform: translateY(-2px);
        }
        body.dark-mode .theme-toggle {
            background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <div class="container">
        <header class="hero">
            <div>
                <h1>Welcome, <%= student.username %></h1>
                <p>Your assigned tests are grouped below by skill area so it’s easy to jump into the right exam format.</p>
                <% if (groupName && groupName !== 'No Group Assigned') { %>
                    <div class="group-pill"><%= groupName %></div>
                <% } %>
            </div>
            <a href="/logout" class="logout">Logout</a>
            <a href="/settings" class="logout" style="margin-right:10px;">⚙️ Settings</a>
            <a href="/student/feedback" class="logout" style="margin-right:10px;background:linear-gradient(135deg,#f97316,#ea580c);color:white;border:none;">🐛 Report Issue</a>
        </header>

        <section class="section">
            <div class="section-header">
                <div>
                    <h2>Your Tests</h2>
                    <p>Each test opens in the same student view your teacher previewed and can resume from saved progress.</p>
                </div>
            </div>

            <% const typeConfig = [
                { key: 'reading', label: 'Reading', className: 'reading' },
                { key: 'listening', label: 'Listening', className: 'listening' },
                { key: 'writing', label: 'Writing', className: 'writing' }
            ]; %>

            <% if (tests.length > 0) { %>
                <div class="type-grid">
                    <% typeConfig.forEach(type => { const typeTests = testsByType[type.key] || []; %>
                        <div class="type-column <%= type.className %>">
                            <div class="type-header">
                                <h3><%= type.label %></h3>
                                <div class="badge"><%= typeTests.length %> tests</div>
                            </div>

                            <% if (typeTests.length > 0) { %>
                                <div class="test-list">
                                    <% typeTests.forEach(test => { %>
                                        <article class="test-card">
                                            <h4><%= test.title %></h4>
                                            <p>Open the live student view and continue from where you left off.</p>

                                            <div class="meta-row">
                                                <% if (test.submission) { %>
                                                    <div class="meta-pill success">Completed</div>
                                                    <% if (test.type === 'writing') { %>
                                                        <div class="meta-pill">Writing saved</div>
                                                    <% } else { %>
                                                        <div class="meta-pill"><%= test.submission.score %>/<%= test.submission.totalQuestions %></div>
                                                    <% } %>
                                                <% } else { %>
                                                    <div class="meta-pill warning">Not submitted yet</div>
                                                <% } %>
                                                <div class="meta-pill">ID <%= test._id.toString().slice(-6) %></div>
                                            </div>

                                            <% if (test.submission && test.submission.lastSubmittedAt) { %>
                                                <p style="margin-bottom: 14px;">Last saved result: <strong><%= new Date(test.submission.lastSubmittedAt).toLocaleString() %></strong></p>
                                            <% } %>

                                            <div class="actions">
                                                <a href="/view-test/<%= test._id %>" class="btn btn-primary">Open Test</a>
                                            </div>
                                        </article>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="empty">No <%= type.label.toLowerCase() %> tests assigned right now.</div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty">No tests have been assigned to you yet. Your teacher will place them here when they are ready.</div>
            <% } %>
        </section>
    </div>

    <button class="theme-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode">🌙</button>
</body>
</html>
