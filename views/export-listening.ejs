<script>
(function() {
    const encodedKey = <%- JSON.stringify(encodedAnsKey) %>;
    
    let isSubmitted = false;
    let isResetting = false; 
    let testStarted = false;
    let reviewTime = false;
    let timerInterval = null;
    let secondsLeft = 0; 
    let currentPart = 1;
    const SESSION_KEY = 'ielts_listening_<%= test._id || Date.now() %>'; 
    const AUDIO_KEY = SESSION_KEY + '_audio_state'; 

// AUDIO PLAYLIST LOGIC - R2 DIRECT URLS
    const rawAudioDataList = <%- JSON.stringify(test.audioParts || testData.audioParts || [null, null, null, null]) %>;
    const rawFullAudioData = <%- JSON.stringify(test.fullAudio || testData.fullAudio || null) %>;
    const usePause = <%- (test.includePause || testData.includePause) ? "true" : "false" %>;
    
    const audioPlayer = document.getElementById('testAudio');
    let currentAudioIndex = 0;
    let isFullAudio = rawFullAudioData !== null;

    // Direct URL passthrough for Cloudflare R2 storage (no base64 conversion needed)
    function createBlobUrl(url) {
        if (!url) return null;
        // If it's already a URL (starts with http/https or /), return it directly
        // Otherwise treat as fallback
        if (typeof url === 'string' && (url.startsWith('http') || url.startsWith('/'))) {
            return url;
        }
        // Legacy support: if it's a base64 data URL, still support it
        if (typeof url === 'string' && url.startsWith('data:')) {
            try {
                const parts = url.split(',');
                const mime = parts[0].match(/:(.*?);/)[1];
                const bstr = atob(parts[1]);
                let n = bstr.length;
                const u8arr = new Uint8Array(n);
                while (n--) { u8arr[n] = bstr.charCodeAt(n); }
                return URL.createObjectURL(new Blob([u8arr], { type: mime }));
            } catch(e) { 
                return null;
            }
        }
        return null;
    }

    const audioDataList = rawAudioDataList ? rawAudioDataList.map(createBlobUrl) : [null, null, null, null];
    const fullAudioData = rawFullAudioData ? createBlobUrl(rawFullAudioData) : null;

    window.startTest = startTest;
    window.switchPart = switchPart;
    window.checkAnswers = checkAnswers;
    window.adminReset = adminReset;
    window.openMapPicker = openMapPicker;
    window.clearZone = clearZone;
    window.saveState = saveState;
    window.performHighlight = performHighlight;
    window.clearHighlight = clearHighlight;
    window.toggleBlockFlag = toggleBlockFlag;
    window.toggleZoneFlag = toggleZoneFlag;
    window.toggleInlineFlag = toggleInlineFlag;
    window.showHelp = showHelp;
    window.toggleCustomSelect = toggleCustomSelect;
    window.selectCustomOption = selectCustomOption;
    window.toggleTheme = toggleTheme;
    window.saveName = saveName;
    window.submitFromLockdown = submitFromLockdown;

    window.showModernModal = function(title, text, type, onConfirm) {
        const overlay = document.getElementById('modernModal');
        document.getElementById('modernModalTitle').innerHTML = title;
        document.getElementById('modernModalText').innerHTML = text;
        const input = document.getElementById('modernModalInput');
        const btnCancel = document.getElementById('modernModalCancel');
        const btnConfirm = document.getElementById('modernModalConfirm');
        
        input.style.display = 'none'; input.value = '';
        btnCancel.style.display = 'block'; btnCancel.innerText = 'Cancel';
        btnConfirm.innerText = 'Confirm';

        if (type === 'alert') {
            btnCancel.style.display = 'none';
            btnConfirm.innerText = 'Got it';
        } else if (type === 'prompt') {
            input.style.display = 'block';
            setTimeout(() => input.focus(), 100);
        }

        overlay.classList.add('show');

        btnConfirm.onclick = function() {
            overlay.classList.remove('show');
            if (onConfirm) {
                if (type === 'prompt') onConfirm(input.value);
                else onConfirm();
            }
        };
        btnCancel.onclick = function() { overlay.classList.remove('show'); };
    };

    function showHelp() {
