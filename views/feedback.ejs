<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report an Issue</title>
    <%- include('../partials/design-system') %>
    <style>
        /* ============================================================
           FEEDBACK/REPORT PAGE — centered card form
           ============================================================ */
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: var(--space-lg);
        }

        .feedback-card {
            max-width: 600px;
            width: 100%;
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: var(--radius-xl);
            padding: var(--space-2xl);
            box-shadow: var(--shadow-xl);
            border: 1px solid rgba(255,255,255,0.12);
        }
        .feedback-card h1 { font-size: 1.6rem; font-weight: 900; margin-bottom: var(--space-sm); color: var(--text-primary); }
        .subtitle { color: var(--text-muted); margin-bottom: var(--space-lg); line-height: 1.6; }

        .instructions {
            padding: var(--space-md);
            border-radius: var(--radius-md);
            background: var(--warning-bg);
            border: 1px solid rgba(245, 158, 11, 0.3);
            margin-bottom: var(--space-lg);
            font-size: 0.9rem;
            line-height: 1.7;
            color: #92400e;
        }
        .instructions strong { color: #854d0e; }

        .btn-group { display: flex; gap: var(--space-sm); margin-top: var(--space-lg); }

        body.dark-mode .instructions { background: rgba(245, 158, 11, 0.12); color: #fcd34d; border-color: rgba(245, 158, 11, 0.25); }
        body.dark-mode .instructions strong { color: #fbbf24; }

        @media (max-width: 480px) {
            .feedback-card { padding: var(--space-xl); }
            .btn-group { flex-direction: column; }
        }
    </style>
</head>
<body>
    <div class="feedback-card">
        <h1>🐛 Report an Issue</h1>
        <p class="subtitle">Help us improve the platform by reporting problems you encounter during tests.</p>

        <div class="instructions">
            <strong>📝 How to report effectively:</strong><br>
            • Mention which <strong>test type</strong> (Reading/Listening/Writing)<br>
            • Specify the <strong>question type</strong> (Multiple Choice, Gap Fill, etc.)<br>
            • Describe <strong>when</strong> the problem occurs (e.g., "when I click submit", "after 10 minutes")<br>
            • Be as detailed as possible
        </div>

        <form id="feedbackForm">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
                <label for="testType">Test Type *</label>
                <select id="testType" name="testType" class="form-select" required>
                    <option value="">Select test type</option>
                    <option value="reading">Reading</option>
                    <option value="listening">Listening</option>
                    <option value="writing">Writing</option>
                    <option value="general">General Platform Issue</option>
                </select>
            </div>

            <div class="form-group">
                <label for="questionType">Question Type (if applicable)</label>
                <select id="questionType" name="questionType" class="form-select">
                    <option value="">Select question type</option>
                    <option value="multiple-choice">Multiple Choice</option>
                    <option value="true-false">True/False/Not Given</option>
                    <option value="gap-fill">Gap Fill</option>
                    <option value="matching">Matching</option>
                    <option value="short-answer">Short Answer</option>
                    <option value="diagram">Diagram Labeling</option>
                    <option value="map">Map Labeling</option>
                    <option value="flow-chart">Flow Chart</option>
                    <option value="essay">Essay/Writing Task</option>
                    <option value="other">Other</option>
                </select>
            </div>

            <div class="form-group">
                <label for="issueDescription">Describe the Problem *</label>
                <textarea id="issueDescription" name="issueDescription" class="form-input" required placeholder="Example: In the Reading test, when I select an answer for question 5 (multiple choice), it doesn't save and disappears when I move to the next question. This happens every time I try." style="min-height:150px;resize:vertical;"></textarea>
            </div>

            <div class="btn-group">
                <button type="button" class="btn btn-ghost" onclick="window.location.href='/student-dashboard'" style="flex:1;">Cancel</button>
                <button type="submit" class="btn btn-primary" style="flex:1;">Submit Report</button>
            </div>
        </form>
    </div>

    <script>
        document.getElementById('feedbackForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);
            const csrfToken = data._csrf;

            try {
                const res = await fetch('/student/feedback', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'CSRF-Token': csrfToken
                    },
                    body: JSON.stringify(data)
                });
                const result = await res.json();

                if (result.success) {
                    if (typeof showToast === 'function') {
                        showToast('Report submitted successfully! Thank you.', 'success');
                    }
                    setTimeout(() => window.location.href = '/student-dashboard', 2000);
                } else {
                    if (typeof showToast === 'function') {
                        showToast('Error: ' + result.message, 'error');
                    }
                }
            } catch (err) {
                if (typeof showToast === 'function') {
                    showToast('Error submitting report', 'error');
                }
            }
        });
    </script>
    <%- include('../partials/notifications') %>
</body>
</html>
