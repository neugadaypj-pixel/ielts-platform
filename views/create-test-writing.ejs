<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IELTS Writing Test Builder</title>
    <style>
        /* --- ADMIN INTERFACE STYLES --- */
        body { font-family: 'Segoe UI', Arial, sans-serif; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); padding: 20px; margin: 0; color: #333; min-height: 100vh; }
        .container { max-width: 1280px; margin: 0 auto; background: white; padding: 30px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); border-radius: 20px; animation: fadeIn 0.8s ease-out; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        
        h1 { text-align: center; color: #2c3e50; margin-bottom: 5px; }
        p.subtitle { text-align: center; color: #8e44ad; font-weight: bold; margin-top: 0; margin-bottom: 30px; }
        
        .tabs { display: flex; border-bottom: 2px solid #e1e4e8; margin-bottom: 20px; }
        .tab { padding: 12px 30px; cursor: pointer; background: #f8f9fa; border: 1px solid #e1e4e8; border-bottom: none; margin-right: 5px; border-radius: 12px 12px 0 0; font-weight: 600; color: #666; transition: all 0.3s ease; }
        .tab:hover { background: #e9ecef; }
        .tab.active { background: white; color: #8e44ad; border-bottom: 2px solid white; margin-bottom: -2px; border-top: 3px solid #8e44ad; color:#333; }
        
        .tab-content { display: none; padding: 30px; border: 1px solid #e1e4e8; border-top: none; background: white; border-radius: 0 0 12px 12px; }
        .tab-content.active { display: block; }

        .editor-grid { display: flex; gap: 40px; }
        .half { flex: 1; display: flex; flex-direction: column; }
        
        h3 { color: #34495e; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-top: 0; }
        label { font-weight: 600; margin-top: 15px; display: block; font-size: 14px; color: #34495e; }
        input[type="text"], input[type="number"], select { width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #ccc; border-radius: 8px; font-size: 14px; outline: none; transition: border 0.3s, box-shadow 0.3s; }
        input[type="text"]:focus, textarea:focus { border-color: #8e44ad; box-shadow: 0 0 0 3px rgba(142,68,173,0.1); }
        
        textarea { width: 100%; height: 300px; padding: 12px; font-family: 'Consolas', monospace; border: 1px solid #ccc; border-radius: 8px; resize: vertical; font-size: 13px; line-height: 1.5; background: #fdfdfd; outline: none; }
        
        .btn-format { background: #ecf0f1; color: #2c3e50; padding: 6px 12px; font-size: 13px; margin-right: 5px; border: 1px solid #bdc3c7; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
        .btn-format:hover { background: #d0ece7; }

        .action-area { margin-top: 40px; padding-top: 20px; border-top: 2px solid #eee; }
        .btn-download { background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%); color: white; font-size: 18px; padding: 15px 30px; width: 100%; display: block; border-radius: 30px; box-shadow: 0 10px 20px rgba(39, 174, 96, 0.3); cursor: pointer; border: 1px solid rgba(255,255,255,0.2); transition: all 0.3s ease; backdrop-filter: blur(5px); }
        .btn-download:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(39, 174, 96, 0.4); border-color: rgba(255,255,255,0.5); }
        .btn-download:active { transform: translateY(1px); box-shadow: 0 5px 10px rgba(39, 174, 96, 0.3); }
        
        .settings-box { background: #fff; padding: 20px; border-radius: 15px; margin-bottom: 20px; border: 1px solid #e1e4e8; }
        
        .image-preview { margin-top: 10px; max-width: 100%; height: auto; border: 1px dashed #ccc; padding: 5px; display: none; }

        /* Dark Mode */
        body.dark-mode { background: #1a1a1a; color: #e0e0e0; }
        .dark-mode .container { background: #252525; }
        .dark-mode .tab { background: #2d2d2d; border-color: #444; color: #ccc; }
        .dark-mode .tab.active { background: #252525; color: #fff; border-color: #8e44ad; }
        .dark-mode .tab-content { background: #1e1e1e; border-color: #444; }
        .dark-mode h3, .dark-mode label { color: #ddd; }
        .dark-mode textarea, .dark-mode input[type="text"], .dark-mode input[type="number"], .dark-mode select { background: #333; color: #fff; border-color: #444; }
        .dark-mode .settings-box { background: #333; border-color: #444; }
    </style>
</head>
<body>

<div class="container">
    <h1>IELTS Writing Test Builder</h1>
    <p class="subtitle">Create Professional Writing Tests with Model Answers</p>

    <div class="tabs">
        <div class="tab active" onclick="switchTab(1)">Task 1 (Report)</div>
        <div class="tab" onclick="switchTab(2)">Task 2 (Essay)</div>
    </div>

    <div id="tab1" class="tab-content active">
        <div class="editor-grid">
            <div class="half">
                <h3>Task 1 Prompt</h3>
                <label>Chart/Graph Image (Filename or URL):</label>
                <input type="text" id="t1_img" placeholder="chart.png OR https://example.com/graph.jpg" onchange="previewImage(1)">
                <img id="prev_1" class="image-preview">

                <label>Instructions / Topic:</label>
                <div style="margin-bottom:8px;">
                    <button class="btn-format" onclick="insertTag('t1_prompt', '<strong>', '</strong>')">Bold</button>
                    <button class="btn-format" onclick="insertTag('t1_prompt', '<em>', '</em>')">Italic</button>
                </div>
                <textarea id="t1_prompt">The chart below shows the main reasons for migration to the UK in 2007, 2008, and 2009.

Summarise the information by selecting and reporting the main features, and make comparisons where relevant.</textarea>
            </div>
            <div class="half">
                <h3>Model Answer (Hidden)</h3>
                <label>Band 9 Sample Answer:</label>
                <p style="font-size:12px; color:#666;">Revealed after student submission.</p>
                <textarea id="t1_model" placeholder="The bar chart illustrates...">The bar chart presents data on the primary reasons for migration to the UK across three consecutive years. Overall, work-related factors consistently dominated migration patterns, with employment opportunities remaining the leading motivator throughout the period examined.

In 2007, work represented approximately 45% of migration reasons, a figure that increased marginally to 47% in 2008 before slightly declining to 43% in 2009. This trend underscores the UK's status as a major employment destination. Conversely, migration for study purposes experienced a gradual decline, dropping from 25% in 2007 to just 18% by 2009, suggesting diminishing appeal of UK educational institutions during this period.

Other significant reasons, including family reunification and formal immigration, together constituted roughly 30% of total migration flows. While family-related migration remained relatively stable at 15-17%, formal immigration procedures fluctuated, reaching a peak of 18% in 2008 before falling to 15% in 2009. This volatility may reflect policy changes or administrative adjustments during this timeframe.</textarea>
            </div>
        </div>
    </div>

    <div id="tab2" class="tab-content">
        <div class="editor-grid">
            <div class="half">
                <h3>Task 2 Prompt</h3>
                <label>Instructions / Topic:</label>
                <div style="margin-bottom:8px;">
                    <button class="btn-format" onclick="insertTag('t2_prompt', '<strong>', '</strong>')">Bold</button>
                    <button class="btn-format" onclick="insertTag('t2_prompt', '<em>', '</em>')">Italic</button>
                </div>
                <textarea id="t2_prompt">Some people think that hard work and determination are the keys to success in life, while others believe that other factors such as money and personal appearance are more important.

Discuss both views and give your own opinion.</textarea>
            </div>
            <div class="half">
                <h3>Model Answer (Hidden)</h3>
                <label>Band 9 Sample Answer:</label>
                <textarea id="t2_model" placeholder="It is argued that...">Success in life is a multifaceted concept that different individuals prioritize differently. While some advocate that perseverance and dedication are the primary drivers of achievement, others contend that external factors such as financial resources and physical appearance play equally significant roles. This essay will examine both perspectives before presenting a balanced viewpoint.

The proponents of hard work and determination argue that these intrinsic qualities form the foundation of success. Throughout history, countless individuals have risen from humble beginnings through sheer determination and consistent effort. These advocates suggest that regardless of one's initial circumstances, commitment to personal development and goal-setting inevitably leads to accomplishment. This perspective emphasizes the importance of agency and personal responsibility in shaping one's future.

However, critics of this viewpoint maintain that extrinsic factors substantially influence one's trajectory. Financial resources undeniably provide access to superior education, networking opportunities, and professional advantages. Similarly, physical appearance can influence social interactions and career prospects in certain fields. These factors, while perhaps not ethical considerations, remain undeniably influential in contemporary society.

In my view, success emerges from an interplay of both factors. While inherent qualities such as determination remain crucial, acknowledging the role of external circumstances demonstrates realism. The most sustainable success comes from developing strong work ethic while strategically leveraging available resources and opportunities. A balanced approach, combining personal effort with pragmatic awareness of environmental factors, offers the most comprehensive pathway to meaningful achievement.</textarea>
            </div>
        </div>
    </div>

    <div class="action-area">
        <div class="settings-box">
            <h3>⚙️ Test Settings</h3>
            <label>Test Title:</label>
            <input type="text" id="test_title" value="IELTS Writing Practice Test" placeholder="e.g., IELTS Writing Practice Test 5">
            
            <label style="margin-top:15px;">Time Limit (Minutes):</label>
            <input type="number" id="time_limit" value="60" style="width: 100px;">
            
            <label style="margin-top:15px;">Test Description:</label>
            <textarea style="height:80px;" id="test_desc" placeholder="Add a description for this test..."></textarea>
        </div>
        <button class="btn-download" onclick="saveTest()">💾 Save & Publish Test</button>
    </div>
</div>

<script>
    function switchTab(num) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('.tab')[num-1].classList.add('active');
        document.getElementById('tab'+num).classList.add('active');
    }

    function insertTag(areaId, start, end) {
        const area = document.getElementById(areaId);
        let s = area.selectionStart; let e = area.selectionEnd;
        area.focus();
        if (typeof s === 'number') area.setSelectionRange(s, e);
        const text = area.value.substring(s, e);
        const fullText = start + text + end;
        if (!document.execCommand('insertText', false, fullText)) {
            area.setRangeText(fullText, s, e, 'end');
        }
    }

    function previewImage(id) {
        const url = document.getElementById('t'+id+'_img').value;
        const img = document.getElementById('prev_'+id);
        if(url){ img.src = url; img.style.display = 'block'; } else { img.style.display = 'none'; }
    }

    async function saveTest() {
        const title = document.getElementById('test_title').value.trim();
        const desc = document.getElementById('test_desc').value.trim();
        const timeLimit = document.getElementById('time_limit').value || 60;

        if (!title) {
            alert("Please enter a test title");
            return;
        }

        const testData = {
            title: title,
            description: desc,
            type: 'writing',
            timeLimit: parseInt(timeLimit),
            task1: {
                prompt: document.getElementById('t1_prompt').value,
                image: document.getElementById('t1_img').value,
                modelAnswer: document.getElementById('t1_model').value
            },
            task2: {
                prompt: document.getElementById('t2_prompt').value,
                modelAnswer: document.getElementById('t2_model').value
            }
        };

        try {
            const response = await fetch('/create-test/writing', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(testData)
            });

            const data = await response.json();
            if (data.success) {
                alert("✅ Writing test created successfully!");
                setTimeout(() => window.location.href = '/admin', 1500);
            } else {
                alert("❌ Error: " + data.message);
            }
        } catch (err) {
            alert("❌ Error saving test: " + err.message);
        }
    }
</script>
</body>
</html>
