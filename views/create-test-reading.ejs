    function insertTag(areaId, start, end) {
        const area = document.getElementById(areaId);
        if (!area) return;
        let s = area.selectionStart;
        let e = area.selectionEnd;
        area.focus();
        const text = area.value.substring(s, e);
        const fullText = start + text + end;
        area.setRangeText(fullText, s, e, 'end');
    }
    
    function updateAnswerKey(num, ans) {
        if(!num || (ans === null || ans === undefined)) return;
        try {
            const currentVal = document.getElementById('answer_key_json').value || "{}";
            const current = JSON.parse(currentVal);
            let valueToSet = ans;
            if (typeof ans === 'string') {
                try {
                    const parsed = JSON.parse(ans);
                    if (Array.isArray(parsed)) valueToSet = parsed;
                } catch(e) {
                    if (ans.includes('|')) { valueToSet = ans.split('|').map(s => s.trim()).filter(Boolean); }
                }
            }
            current[num] = valueToSet;
            document.getElementById('answer_key_json').value = JSON.stringify(current, null, 2);
        } catch(e) { document.getElementById('answer_key_json').value = JSON.stringify({[num]: ans}, null, 2); }
    }

    function insertQuestion(partNum) {
        const type = document.getElementById(`gen_type_${partNum}`).value;
        const targetArea = document.getElementById(`q${partNum}_text`);
        let html = "";
        const AC_OFF = 'autocomplete="off"';
        const formatText = (txt) => txt.replace(/\n/g, '<br>');

        if (type === 'header') {
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            html = `<div class="question-section-header">${formatText(prompt)}</div>`;
            document.getElementById(`gen_prompt_${partNum}`).value = "";

        } else if (type === 'flow') {
            const prompt = document.getElementById(`flow_prompt_${partNum}`).value;
            const editorContent = document.getElementById(`flow_editor_${partNum}`).innerHTML;
            const optInputs = document.querySelectorAll(`.flow-opt-text-${partNum}`);
            
            let poolHtml = "";
            let hasOptions = false;
            
            // Build the drag-and-drop pool if options are provided
            if(optInputs.length > 0 && Array.from(optInputs).some(inp => inp.value.trim() !== '')) {
                hasOptions = true;
                poolHtml = '<div class="pool-container" style="justify-content: center;">';
                optInputs.forEach((inp, i) => {
                    const label = String.fromCharCode(65 + i);
                    const val = inp.value.trim();
                    if(val) {
                        const uId = "flow_pool_" + Date.now() + "_" + i;
                        poolHtml += `<div class="chip-item" id="${uId}" draggable="true" ondragstart="drag(event)" data-val="${label}"><b>${label}</b> - ${val}</div>`;
                    }
                });
                poolHtml += '</div>';
            }

            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = editorContent;
            
            // Map the temporary builder gaps to final interactive gaps
            const gaps = tempDiv.querySelectorAll('.temp-flow-gap');
            gaps.forEach(gap => {
                const qId = gap.id; 
                const qNum = gap.getAttribute('placeholder');
                const newSpan = document.createElement('span');
                
                if (hasOptions) {
                    newSpan.className = "drop-zone";
                    newSpan.setAttribute('data-qid', qNum);
                    newSpan.innerHTML = `[ ${qNum} ] <input type="hidden" id="${qId}" value="">`;
                } else {
                    newSpan.innerHTML = `<input type="text" id="${qId}" class="gap-input" placeholder="${qNum}" ${AC_OFF}>`;
                }
                
                gap.parentNode.replaceChild(newSpan, gap);
                
                if (hasOptions) {
                    const flagSpan = document.createElement('span');
                    flagSpan.className = 'q-flag';
                    flagSpan.innerHTML = '⚑';
                    newSpan.parentNode.insertBefore(flagSpan, newSpan.nextSibling);
                }
            });

            html = `<div class="flow-question-block">`;
            if(prompt) html += `<p class="question-prompt" style="margin-bottom:20px;"><strong>${formatText(prompt)}</strong></p>`;
            html += poolHtml;
            html += `<div class="flow-chart-content" style="text-align: center;">${tempDiv.innerHTML}</div></div>`;
            
            document.getElementById(`flow_editor_${partNum}`).innerHTML = "";
            document.getElementById(`flow_prompt_${partNum}`).value = "";
            optInputs.forEach(inp => inp.value = "");    
            
        } else if (type === 'diagram') {
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            const stage = document.getElementById(`diagram_stage_${partNum}`);
            const img = stage.querySelector('img.bg-img');
            if(!img) { alert("No image found! Please upload/paste an image first."); return; }
            
            let questionsHtml = "";
            const textInputs = document.querySelectorAll(`.diag-q-text-${partNum}`);
            const ansInputs = document.querySelectorAll(`.diag-q-ans-${partNum}`);
            let qNumStart = parseInt(document.getElementById(`gen_q_num_${partNum}`).value);
            let currentQ = qNumStart;

            for(let i=0; i<ansInputs.length; i++) {
                const ans = ansInputs[i].value.trim();
                if(ans) {
                    const desc = textInputs[i].value.trim();
                    questionsHtml += `\n<div class="short-answer-question" data-q-start="${currentQ}" style="padding: 12px 20px; margin-bottom: 10px;">
                        <strong>${currentQ}</strong> <span style="margin: 0 10px;">${formatText(desc)}</span> <input id="q${currentQ}" class="answer-input" placeholder="${currentQ}" ${AC_OFF} style="width:160px;">
                    </div>`;
                    updateAnswerKey(currentQ, ans.toUpperCase());
                    currentQ++;
                }
            }
            
            html = `<div class="diagram-container">
                <div class="question-prompt" style="margin-bottom:15px;">${formatText(prompt)}</div>
                <div class="diagram-wrapper" style="text-align:center; background:#fff; padding:10px; border-radius:8px; border:1px solid #eee; margin-bottom:20px;">
                    <img src="${img.src}" class="diagram-img" style="max-width:100%; height:auto;">
                </div>
                <div class="diagram-inputs-list">
                    ${questionsHtml}
                </div>
            </div>`;
            
            document.getElementById(`gen_q_num_${partNum}`).value = currentQ;
            document.getElementById(`gen_prompt_${partNum}`).value = "";
            textInputs.forEach(i => i.value = "");
            ansInputs.forEach(i => i.value = "");

        } else if (type === 'match') {
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value.trim();
            const featInputs = document.querySelectorAll(`.match-opt-text-${partNum}`);
            const featureLetters = [];
            let featuresHtmlContent = "";
            
            featInputs.forEach((inp) => {
                const val = inp.value.trim();
                // Always generate the letter for the custom dropdown menu
                const letter = String.fromCharCode(65 + featureLetters.length);
                featureLetters.push(letter);
                
                // Only print the letter/description in the box if text exists
                if (val) {
                    featuresHtmlContent += `<div><b>${letter}</b> ${val}</div>`;
                }
            });
            
            // If there's no text content, don't generate the features box HTML at all
            let featuresHtml = featuresHtmlContent ? `<div class="match-features-box" style="margin-bottom:15px;">${featuresHtmlContent}</div>` : "";
            // If prompt is empty, don't generate the empty paragraph tags
            let promptHtml = prompt ? `<p style="margin-top:0;"><strong>${formatText(prompt)}</strong></p>` : "";
            
            const qInputs = document.querySelectorAll(`.match-q-text-${partNum}`);
            const aInputs = document.querySelectorAll(`.match-q-ans-${partNum}`);
            let qNumStart = parseInt(document.getElementById(`gen_q_num_${partNum}`).value);
            
            html = `<div class="matching-group-block">${promptHtml}${featuresHtml}<div class="match-questions-list">`;
            let currentQ = qNumStart;
            for(let i=0; i<qInputs.length; i++) {
                if(qInputs[i].value.trim()) {
                    html += `\n<div class="multi-choice-question match-item" data-q-start="${currentQ}" style="display:flex; justify-content:space-between; align-items:center; overflow:visible;">
                                 <div class="question-prompt" style="margin-bottom:0; flex:1; padding-right:15px;"><strong>${currentQ}</strong> ${qInputs[i].value.trim()}</div>
