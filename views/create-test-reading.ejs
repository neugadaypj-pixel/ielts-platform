    function insertFlowGap(partNum) {
        const editor = document.getElementById(`flow_editor_${partNum}`);
        if (!editor) return;

        // 1. Capture the exact selection and range BEFORE the prompt appears
        const sel = window.getSelection();
        if (!sel.rangeCount) {
            alert("Please click inside a flow box first!");
            return;
        }
        const range = sel.getRangeAt(0);

        // 2. Verify the user is actually clicking inside the editor
        if (!editor.contains(range.commonAncestorContainer)) {
            alert("Please click inside the flow chart editor area!");
            return;
        }

        const qNumInput = document.getElementById(`gen_q_num_${partNum}`);
        const finalQ = prompt("Enter Question Number:", qNumInput.value);
        if (!finalQ) return;
        
        const ans = prompt("Correct Answer for Q" + finalQ + ":", "");
        if (ans === null) return;

        // 3. Create the gap element as a true inline-block
        const gap = document.createElement('input');
        gap.type = 'text';
        gap.id = 'q' + finalQ;
        gap.className = 'gap-input temp-flow-gap';
        gap.placeholder = finalQ;
        gap.value = `[Q${finalQ}]`;
        gap.readOnly = true;
        // The display:inline-block and vertical-align:middle keep it inside the text line
        gap.style.cssText = 'width:55px; border:2px solid #3498db; text-align:center; margin: 0 5px; display:inline-block; vertical-align:middle; cursor:pointer;';

        // 4. Insert precisely at the saved cursor location
        range.deleteContents(); // Removes highlighted text if any
        range.insertNode(gap);
        
        // 5. Add a non-breaking space after the gap so you can keep typing
        const space = document.createTextNode('\u00A0');
        range.collapse(false); 
        range.insertNode(space);

        // 6. Move cursor after the new gap so you can continue typing immediately
        const newRange = document.createRange();
        newRange.setStartAfter(space);
        newRange.setEndAfter(space);
        sel.removeAllRanges();
        sel.addRange(newRange);

        updateAnswerKey(finalQ, ans);
        qNumInput.value = parseInt(finalQ) + 1;
        editor.focus();
    }

    function insertFlowTableTemplate(partNum) {
        const editor = document.getElementById(`flow_editor_${partNum}`);
        if (!editor) return;

        // Save range before prompts
        let savedRange = null;
        const sel = window.getSelection();
        if (sel.rangeCount > 0) {
            savedRange = sel.getRangeAt(0);
        }

        const rows = prompt("Rows:", "3"); if(!rows) return;
        const cols = prompt("Columns:", "1"); if(!cols) return;

        let t = `<div style="display: grid; grid-template-columns: repeat(${cols}, 1fr); gap: 20px; margin-bottom: 15px; justify-items: center; align-items: center; text-align: center;">`;
        for(let r=0; r<rows; r++) {
            for(let c=0; c<cols; c++) { 
                t += '<div class="flow-box">Text...</div>'; 
            }
        }
        t += '</div><div><br></div>';

        editor.focus();
        if (savedRange) {
            sel.removeAllRanges();
            sel.addRange(savedRange);
        }
        document.execCommand('insertHTML', false, t);
    }

    function insertAtCursor(field, text) {
        if (field.selectionStart || field.selectionStart === 0) {
