    <div class="footer">
        <div class="part-nav">
            <button class="part-btn active" onclick="switchPart(1)">Part 1</button>
            <button class="part-btn" onclick="switchPart(2)">Part 2</button>
            <button class="part-btn" onclick="switchPart(3)">Part 3</button>
