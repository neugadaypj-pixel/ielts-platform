        const gapArea = document.getElementById(`gap_fields_${partNum}`);
        const matchArea = document.getElementById(`match_fields_${partNum}`);
        const stdAns = document.getElementById(`std_ans_field_${partNum}`);
        const pickAns = document.getElementById(`pick_ans_field_${partNum}`);
        const pick3Input = document.getElementById(`pick3_input_${partNum}`);
        const common = document.getElementById(`common_fields_${partNum}`);
        const stdPromptBox = document.getElementById(`std_prompt_box_${partNum}`);
        const qNumRow = document.getElementById(`q_num_row_${partNum}`);
        const infoPick = document.getElementById(`info_pick_${partNum}`);

        [mcqArea, dragArea, flowArea, gapArea, matchArea, pickAns].forEach(el => el.classList.add('hidden-field'));
        [stdAns, common, qNumRow, stdPromptBox].forEach(el => el.classList.remove('hidden-field'));
        infoPick.style.display = 'none'; pick3Input.style.display = 'none';

        if (type === 'header') { stdAns.classList.add('hidden-field'); qNumRow.classList.add('hidden-field'); } 
        else if (type === 'mcq') { mcqArea.classList.remove('hidden-field'); } 
        else if (type === 'match') { matchArea.classList.remove('hidden-field'); stdAns.classList.add('hidden-field'); } 
        else if (type === 'pick2') { mcqArea.classList.remove('hidden-field'); stdAns.classList.add('hidden-field'); pickAns.classList.remove('hidden-field'); infoPick.style.display = 'block'; infoPick.innerHTML = '<strong>Note:</strong> Reserves 2 Qs'; } 
        else if (type === 'pick3') { mcqArea.classList.remove('hidden-field'); stdAns.classList.add('hidden-field'); pickAns.classList.remove('hidden-field'); pick3Input.style.display = 'block'; infoPick.style.display = 'block'; infoPick.innerHTML = '<strong>Note:</strong> Reserves 3 Qs'; } 
        else if (type === 'drag') { dragArea.classList.remove('hidden-field'); stdAns.classList.add('hidden-field'); common.classList.add('hidden-field'); } 
        else if (type === 'flow') { flowArea.classList.remove('hidden-field'); stdAns.classList.add('hidden-field'); common.classList.add('hidden-field'); }
        else if (type === 'gap' || type === 'table-gap') { gapArea.classList.remove('hidden-field'); stdPromptBox.classList.add('hidden-field'); stdAns.classList.add('hidden-field'); }
    }
    function insertTag(areaId, start, end) {
        const area = document.getElementById(areaId);
        if (!area) return;
        
        if (area.tagName === 'TEXTAREA' || area.tagName === 'INPUT') {
            let s = area.selectionStart; let e = area.selectionEnd; area.focus();
            if (typeof s === 'number') { area.setSelectionRange(s, e); }
            const text = area.value.substring(s, e);
            const fullText = start + text + end;
            const success = document.execCommand('insertText', false, fullText);
            if (!success) { area.setRangeText(fullText, s, e, 'end'); }
        } else {
            if (lastSavedRange) {
                const sel = window.getSelection();
                sel.removeAllRanges();
                sel.addRange(lastSavedRange);
            } else { area.focus(); }
            const sel = window.getSelection();
            if (sel.rangeCount > 0) {
                const html = start + sel.toString() + end;
                document.execCommand('insertHTML', false, html);
            }
        }
    }
    function updateAnswerKey(num, ans) {
        if(!num || (ans === null || ans === undefined)) return;
        try {
            const currentVal = document.getElementById('answer_key_json').value || "{}";
            const current = JSON.parse(currentVal);
            let valueToSet = ans;
            if (typeof ans === 'string') {
                try {
                    const parsed = JSON.parse(ans);
                    if (Array.isArray(parsed)) valueToSet = parsed;
                } catch(e) {
                    if (ans.includes('|')) {
                        valueToSet = ans.split('|').map(s => s.trim()).filter(Boolean);
                    }
                }
            }
            current[num] = valueToSet;
            document.getElementById('answer_key_json').value = JSON.stringify(current, null, 2);
        } catch(e) {
            document.getElementById('answer_key_json').value = JSON.stringify({[num]: ans}, null, 2);
        }
    }
    function insertQuestion(partNum) {
        const type = document.getElementById(`gen_type_${partNum}`).value;
        const targetArea = document.getElementById(`q${partNum}_text`);
        let html = "";
        const AC_OFF = 'autocomplete="off"';
        const formatText = (txt) => txt.replace(/\n/g, '<br>');

        if (type === 'header') {
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            html = `<div class="question-section-header">${formatText(prompt)}</div>`;
            document.getElementById(`gen_prompt_${partNum}`).value = "";
        } else if (type === 'match') {
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            let featuresHtml = `<div class="match-features-box">`;
            const featInputs = document.querySelectorAll(`.match-opt-text-${partNum}`);
            const featureLetters = [];
            featInputs.forEach((inp, i) => {
                const letter = String.fromCharCode(65 + i);
                featureLetters.push(letter);
                featuresHtml += `<div><b>${letter}</b> ${inp.value.trim()}</div>`;
            });
            featuresHtml += `</div>`;
            const qInputs = document.querySelectorAll(`.match-q-text-${partNum}`);
            const aInputs = document.querySelectorAll(`.match-q-ans-${partNum}`);
            let qNumStart = parseInt(document.getElementById(`gen_q_num_${partNum}`).value);
            
            html = `<div class="matching-group-block"><p><strong>${formatText(prompt)}</strong></p>${featuresHtml}<div class="match-questions-list">`;
            let currentQ = qNumStart;
            for(let i=0; i<qInputs.length; i++) {
                if(qInputs[i].value.trim()) {
                    html += `\n<div class="multi-choice-question match-item" data-q-start="${currentQ}" style="display:flex; justify-content:space-between; align-items:center; overflow:visible;">
                                 <div class="question-prompt" style="margin-bottom:0; flex:1; padding-right:15px;"><strong>${currentQ}</strong> ${qInputs[i].value.trim()}</div>
                                 <div class="custom-select-wrapper" id="wrap_q${currentQ}">
                                    <div class="custom-select-trigger" onclick="toggleCustomSelect(this)">
                                        <span class="sel-text">Select...</span>
                                        <span class="sel-arrow">▼</span>
                                    </div>
                                    <div class="custom-select-options">
                                        <div class="custom-option clear-opt" onclick="selectCustomOption(this, '${currentQ}', '')">✕ Clear Answer</div>`;
                    featureLetters.forEach(L => { 
                        html += `       <div class="custom-option" onclick="selectCustomOption(this, '${currentQ}', '${L}')"><b>${L}</b></div>`; 
                    });
                    html += `       </div>
                                    <input type="hidden" id="q${currentQ}" value="" ${AC_OFF}>
                                 </div>
                             </div>`;
                    if(aInputs[i].value.trim()) updateAnswerKey(currentQ, aInputs[i].value.trim().toUpperCase());
                    currentQ++;
                }
            }
            html += `\n</div></div>`;
            document.getElementById(`gen_q_num_${partNum}`).value = currentQ;
        } else if (type === 'drag') {
            const prompt = document.getElementById(`map_prompt_${partNum}`).value;
            const imgContent = document.getElementById(`map_img_${partNum}`).innerHTML;
            const qInputs = document.querySelectorAll(`.map-q-num-${partNum}`);
            const tInputs = document.querySelectorAll(`.map-q-text-${partNum}`);
            const aInputs = document.querySelectorAll(`.map-q-ans-${partNum}`);
            const optContainer = document.getElementById(`map_options_container_${partNum}`);
            
            let variants = [];
            for(let i=0; i<optContainer.children.length; i++) { variants.push(optContainer.children[i].innerText); }
            const variantsStr = variants.join(',');

            let questionsHtml = "";
            qInputs.forEach((inp, i) => {
                const qNum = inp.value;
                const qText = tInputs[i] ? tInputs[i].value.trim() : "";
                const ans = aInputs[i].value.trim().toUpperCase();
                if(qNum) {
                    let inputHtml = "";
                    if (variants.length > 0) {
                        inputHtml = `<span class="drop-zone map-drop-zone" data-qid="${qNum}" data-variants="${variantsStr}" onclick="openMapPicker(this)" ondblclick="clearZone(this)">? <input type="hidden" id="q${qNum}" value=""></span><span class="q-flag" onclick="toggleZoneFlag(this)">⚑</span>`;
                    } else {
                        inputHtml = `<input type="text" id="q${qNum}" class="answer-input" style="width:60px; text-align:center; margin-left:10px;" ${AC_OFF}>`;
                    }
                    questionsHtml += `<div class="map-q-item" style="margin-bottom:10px; font-size:18px; display:inline-block; margin-right:20px;"><strong>${qNum}</strong> ${qText} ${inputHtml}</div>`;
                    if(ans) updateAnswerKey(qNum, ans);
                }
            });

            html = `<div class="map-question-block">`;
            if(prompt) html += `<p><strong>${formatText(prompt)}</strong></p>`;
            html += `<div class="map-image" style="text-align:center; margin-bottom:20px; overflow-x:auto;">${imgContent}</div><div class="map-questions-list">${questionsHtml}</div></div>`;
            document.getElementById(`map_img_${partNum}`).innerHTML = "";
            document.getElementById(`map_prompt_${partNum}`).value = "";
        } else if (type === 'flow') {
            const prompt = document.getElementById(`flow_prompt_${partNum}`).value;
            const editorContent = document.getElementById(`flow_editor_${partNum}`).innerHTML;
            const optInputs = document.querySelectorAll(`.flow-opt-text-${partNum}`);
            
            let variants = [];
            let optionsHtml = "";
            if(optInputs.length > 0) {
                optionsHtml = '<div class="match-features-box"><h4 style="margin: 0 0 15px 0; text-align: center; color: #8e44ad; text-transform: uppercase; font-size: 14px; letter-spacing: 1px;">Options</h4>';
                optionsHtml += '<div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">';
                optInputs.forEach((inp, i) => {
                    const label = String.fromCharCode(65 + i);
                    variants.push(label);
                    optionsHtml += `<div style="font-size: 15px; display: flex; align-items: center;"><span style="background: #34495e; color: #fff; padding: 2px 8px; border-radius: 6px; margin-right: 8px; font-size: 12px; font-weight: bold;">${label}</span> ${inp.value.trim()}</div>`;
                });
                optionsHtml += '</div></div>';
            }
            const variantsStr = variants.join(',');

            const tempDiv = document.createElement('div');
            tempDiv.innerHTML = editorContent;
            
            const gaps = tempDiv.querySelectorAll('.temp-flow-gap');
            gaps.forEach(gap => {
                const qId = gap.id; 
                const qNum = gap.getAttribute('placeholder');
                const newSpan = document.createElement('span');
                newSpan.className = "drop-zone map-drop-zone";
                newSpan.setAttribute('data-qid', qNum);
                newSpan.setAttribute('data-variants', variantsStr);
                newSpan.setAttribute('onclick', 'openMapPicker(this)');
                newSpan.setAttribute('ondblclick', 'clearZone(this)');
                newSpan.innerHTML = `? <input type="hidden" id="${qId}" value="">`;
                gap.parentNode.replaceChild(newSpan, gap);
                
                const flagSpan = document.createElement('span');
                flagSpan.className = 'q-flag';
                flagSpan.setAttribute('onclick', 'toggleZoneFlag(this)');
                flagSpan.innerHTML = '⚑';
                newSpan.parentNode.insertBefore(flagSpan, newSpan.nextSibling);
            });

            html = `<div class="flow-question-block">`;
            if(prompt) html += `<p class="question-prompt" style="margin-bottom:20px;"><strong>${formatText(prompt)}</strong></p>`;
            html += optionsHtml;
            html += `<div class="flow-chart-content" style="text-align: center;">${tempDiv.innerHTML}</div></div>`;
            
            document.getElementById(`flow_editor_${partNum}`).innerHTML = "";
            document.getElementById(`flow_prompt_${partNum}`).value = "";
        } else if (type === 'gap') {
            const editor = document.getElementById(`gap_editor_${partNum}`);
            if(!editor.innerText.trim() && !editor.innerHTML.includes('<table') && !editor.innerHTML.includes('<div class="modern-table-wrapper"')) { alert("Gap text is empty."); return; }
            html = `<div class="gap-fill-text">${editor.innerHTML}</div>`;
            editor.innerHTML = "";
        } else if (type === 'table-gap') {
            const editor = document.getElementById(`gap_editor_${partNum}`);
            if(!editor.innerText.trim() && !editor.innerHTML.includes('<table') && !editor.innerHTML.includes('<div class="modern-table-wrapper"')) { alert("Table content is empty."); return; }
            html = `<div class="gap-fill-text">${editor.innerHTML}</div>`;
            editor.innerHTML = "";
        } else if (type === 'pick2' || type === 'pick3') {
            const qNumStart = parseInt(document.getElementById(`gen_q_num_${partNum}`).value);
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            const ans1 = document.getElementById(`pick_ans1_${partNum}`).value;
            const ans2 = document.getElementById(`pick_ans2_${partNum}`).value;
            let ans3 = null; let limit = 2; let qNumEnd = qNumStart + 1;
            if (type === 'pick3') { ans3 = document.getElementById(`pick_ans3_${partNum}`).value; limit = 3; qNumEnd = qNumStart + 2; }
            html = `<div class="pick-n-question" data-group-start="${qNumStart}" data-limit="${limit}"><div class="question-prompt"><p><strong>${qNumStart}-${qNumEnd}</strong> ${formatText(prompt)}</p></div>`;
            const inputs = document.querySelectorAll(`.mcq-input-${partNum}`);
            let qIds = []; for(let k=0; k<limit; k++) qIds.push(qNumStart + k); const dataQ = qIds.join(" ");
            inputs.forEach((inp, idx) => {
                const letter = String.fromCharCode(65 + idx);
                html += `\n<div class="multi-choice-option">
                            <label class="modern-label">
                                <input type="checkbox" class="multi-checkbox hidden-cb" data-questions="${dataQ}" value="${letter}" ${AC_OFF}>
                                <span class="custom-cb"></span>
                                <span class="opt-text"><b>${letter}.</b> ${inp.value.trim()}</span>
                            </label>
                         </div>`;
            });
            html += `\n</div>`;
            updateAnswerKey(qNumStart, ans1); updateAnswerKey(qNumStart + 1, ans2); if(type === 'pick3') updateAnswerKey(qNumStart + 2, ans3);
            document.getElementById(`gen_q_num_${partNum}`).value = qNumStart + limit;
            document.getElementById(`gen_prompt_${partNum}`).value = "";
            document.getElementById(`pick_ans1_${partNum}`).value = ""; document.getElementById(`pick_ans2_${partNum}`).value = ""; document.getElementById(`pick_ans3_${partNum}`).value = "";
            document.querySelectorAll(`.mcq-input-${partNum}`).forEach(i => i.value = "");
        } else {
            const qNum = document.getElementById(`gen_q_num_${partNum}`).value;
            const prompt = document.getElementById(`gen_prompt_${partNum}`).value;
            const ans = document.getElementById(`gen_ans_${partNum}`).value;
            if (type === 'mcq') {
                html = `<div class="multi-choice-question" data-q-start="${qNum}"><div class="question-prompt"><p><strong>${qNum}</strong> ${formatText(prompt)}</p></div>`;
                const inputs = document.querySelectorAll(`.mcq-input-${partNum}`);
                inputs.forEach((inp, idx) => {
                    const letter = String.fromCharCode(65 + idx);
                    html += `\n<div class="multi-choice-option">
                                <label class="modern-label">
                                    <input type="radio" name="q${qNum}" class="hidden-cb" value="${letter}" ${AC_OFF} ondblclick="this.checked=false; saveState();">
                                    <span class="custom-radio"></span>
                                    <span class="opt-text"><b>${letter}.</b> ${inp.value.trim()}</span>
                                </label>
                             </div>`;
                });
                html += `\n</div>`;
            } else if (type === 'input') {
                html = `<div class="short-answer-question" data-q-start="${qNum}"><p><strong>${qNum}</strong> ${formatText(prompt)} <input id="q${qNum}" class="answer-input" placeholder="${qNum}" style="width:160px;" ${AC_OFF}></p></div>`;
            }
            updateAnswerKey(qNum, ans);
            document.getElementById(`gen_q_num_${partNum}`).value = parseInt(qNum) + 1;
            document.getElementById(`gen_prompt_${partNum}`).value = "";
            document.getElementById(`gen_ans_${partNum}`).value = "";
            document.querySelectorAll(`.mcq-input-${partNum}`).forEach(i => i.value = "");
        }
        targetArea.value += html + "\n";
    }

    /* --- BUILDER SAVE / LOAD --- */
    function saveBuilderProject() {
        const data = {
            answerKey: document.getElementById('answer_key_json').value,
            parts: {}
        };
        [1,2,3,4].forEach(i => {
            data.parts[i] = {
                finalHtml: document.getElementById(`q${i}_text`).value,
                startQ: document.getElementById(`gen_q_num_${i}`).value
            };
        });
        
        const blob = new Blob([JSON.stringify(data)], {type: "application/json"});
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "IELTS_Listening_Project.json";
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
    }

    function loadBuilderProject(input) {
        const file = input.files[0];
        if(!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const data = JSON.parse(e.target.result);
                document.getElementById('answer_key_json').value = data.answerKey;
                for(let i=1; i<=4; i++) {
                    if(data.parts[i]) {
                        document.getElementById(`q${i}_text`).value = data.parts[i].finalHtml;
                        if(data.parts[i].startQ) document.getElementById(`gen_q_num_${i}`).value = data.parts[i].startQ;
                    }
                }
                alert("Project Loaded Successfully!");
            } catch(err) { alert("Error loading file: " + err.message); }
        };
        reader.readAsText(file);
    }

    renderTabs();

    async function generateFile() {
    const getVal = (id) => document.getElementById(id).value;
    const testTitle = prompt("Enter a title for this Listening Test:", "New Listening Test");
    if (!testTitle) return;

    const btn = document.getElementById('downloadBtn');
    const originalText = btn.innerText;

    // Ссылки на инпуты
    const fullAudioInput = document.querySelector('input[onchange="processFullAudio(this)"]');
    const partInputs = document.querySelectorAll('input[onchange^="processAudio(this,"]');

    // Проверка: загружено ли хоть что-то?
    const hasFull = fullAudioInput.files[0];
    const hasParts = Array.from(partInputs).some(input => input.files[0]);

    if (!hasFull && !hasParts) {
        alert("Ошибка: Загрузи либо один полный файл (Option A), либо файлы по частям!");
        return;
    }

    btn.innerText = "⏳ Uploading all audios...";
    btn.disabled = true;

    const formData = new FormData();
    formData.append('title', testTitle);
    formData.append('usePause', document.getElementById('add_pause_cb').checked);
    
    if (hasFull) {
        formData.append('audioFile', fullAudioInput.files[0]);
    }

    partInputs.forEach((input, index) => {
        if (input.files[0]) {
            formData.append(`part${index + 1}`, input.files[0]);
        }
    });

    const partsData = [
        getVal('q1_text'),
        getVal('q2_text'),
        getVal('q3_text'),
        getVal('q4_text')
    ];
    formData.append('parts', JSON.stringify(partsData));
    formData.append('answerKey', getVal('answer_key_json'));

    try {
        const response = await fetch('/create-test/listening', {
            method: 'POST',
            body: formData 
        });

        const result = await response.json();
        if (result.success) {
            btn.innerText = "✅ Saved Successfully!";
            btn.style.background = "#27ae60";
            setTimeout(() => { window.location.href = "/admin"; }, 1500);
        } else {
            throw new Error(result.error);
        }
    } catch (err) {
        alert("Upload failed: " + err.message);
        btn.innerText = originalText;
        btn.disabled = false;
    }
}
</script>
