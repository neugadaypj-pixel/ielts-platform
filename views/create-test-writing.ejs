<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <title>IELTS Writing Test Builder</title>
    <%- include('../partials/design-system') %>
    <style>
        /* ============================================================
           PAGE-SPECIFIC STYLES — Writing Test Builder
           ============================================================ */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: var(--space-xl);
            animation: fadeIn 0.6s ease-out;
        }

        .header { margin-bottom: var(--space-2xl); }

        h1 {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-400), var(--accent-500));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
            font-weight: 500;
            margin: 0;
        }

        .tabs {
            display: flex;
            gap: var(--space-sm);
            margin-bottom: var(--space-xl);
            border-bottom: 1px solid var(--border);
        }

        .tab {
            padding: 12px 24px;
            border: none;
            background: transparent;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-muted);
            transition: all var(--transition-base);
            border-radius: var(--radius-md) var(--radius-md) 0 0;
        }
        .tab:hover {
            color: var(--primary-400);
            background: rgba(99, 102, 241, 0.05);
        }
        .tab.active {
            color: var(--primary-500);
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(236, 72, 153, 0.05));
        }

        .tab-content {
            display: none;
            padding: var(--space-xl);
            background: var(--surface-glass);
            border-radius: var(--radius-lg);
            animation: fadeIn 0.3s ease-out;
        }
        .tab-content.active { display: block; }

        .editor-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-xl);
        }

        h3 {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: var(--space-md);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        h3::before {
            content: '';
            width: 4px;
            height: 24px;
            background: linear-gradient(135deg, var(--primary-400), var(--accent-500));
            border-radius: 2px;
        }

        .format-bar {
            display: flex;
            gap: var(--space-sm);
            margin: 12px 0 16px 0;
        }

        .btn-format {
            background: var(--surface);
            color: var(--primary-500);
            padding: 8px 16px;
            font-size: 0.85rem;
            border: 2px solid var(--primary-400);
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-weight: 600;
            font-family: var(--font-sans);
            transition: all var(--transition-fast);
        }
        .btn-format:hover {
            background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
            color: #fff;
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        textarea {
            height: 320px;
            resize: vertical;
            font-family: var(--font-mono);
            line-height: 1.6;
            padding: 16px;
        }

        .action-area {
            margin-top: var(--space-2xl);
            padding-top: var(--space-xl);
            border-top: 2px solid var(--border);
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: var(--space-md);
        }

        .image-preview {
            margin-top: 12px;
            max-width: 100%;
            border: 2px dashed var(--primary-400);
            border-radius: var(--radius-md);
            padding: 8px;
            display: none;
        }

        .info-box {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.08), rgba(236, 72, 153, 0.04));
            border-left: 4px solid var(--primary-400);
            padding: var(--space-md);
            border-radius: var(--radius-sm);
            font-size: 0.92rem;
            color: var(--text-secondary);
            margin: 12px 0;
        }

        @media (max-width: 1024px) {
            .editor-grid { grid-template-columns: 1fr; gap: var(--space-lg); }
            h1 { font-size: 1.8rem; }
            .action-area { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>

<div class="container">
    <div class="header">
        <h1>✍️ IELTS Writing Builder</h1>
        <p class="subtitle">Create, review, and manage writing tests with AI-powered feedback</p>
    </div>

    <div class="tabs">
        <div class="tab active" onclick="switchTab(1)">📊 Task 1: Report</div>
        <div class="tab" onclick="switchTab(2)">📝 Task 2: Essay</div>
    </div>

    <div id="tab1" class="tab-content active">
        <div class="editor-grid">
            <div>
                <h3>Task Prompt</h3>
                <label for="t1_img" style="display:block;font-weight:600;color:var(--text-secondary);font-size:0.9rem;margin:16px 0 8px 0;">📈 Chart/Image (URL or filename)</label>
                <input type="text" id="t1_img" class="form-input" placeholder="https://example.com/chart.jpg" onchange="previewImage(1)">
                <img id="prev_1" class="image-preview" alt="Chart preview">

                <label for="t1_prompt" style="display:block;font-weight:600;color:var(--text-secondary);font-size:0.9rem;margin:16px 0 8px 0;">📝 Instructions</label>
                <div class="format-bar">
                    <button type="button" class="btn-format" onclick="insertTag('t1_prompt', '<strong>', '</strong>')">Bold</button>
                    <button type="button" class="btn-format" onclick="insertTag('t1_prompt', '<em>', '</em>')">Italic</button>
                </div>
                <textarea id="t1_prompt" class="form-input">The chart below shows consumer spending patterns...

Summarise the information by selecting and reporting the main features, and make comparisons where relevant.</textarea>
                <div class="info-box">💡 Minimum word count: 150 words</div>
            </div>
            <div>
                <h3>Model Answer</h3>
                <label for="t1_model" style="display:block;font-weight:600;color:var(--text-secondary);font-size:0.9rem;margin:16px 0 8px 0;">🎯 Band 9 Sample</label>
                <p class="info-box">Revealed after student submission for comparison.</p>
                <textarea id="t1_model" class="form-input" placeholder="The bar chart illustrates consumer spending across different categories..."></textarea>
            </div>
        </div>
    </div>

    <div id="tab2" class="tab-content">
        <div class="editor-grid">
            <div>
                <h3>Task Prompt</h3>
                <label for="t2_prompt" style="display:block;font-weight:600;color:var(--text-secondary);font-size:0.9rem;margin:16px 0 8px 0;">📋 Instructions</label>
                <div class="format-bar">
                    <button type="button" class="btn-format" onclick="insertTag('t2_prompt', '<strong>', '</strong>')">Bold</button>
                    <button type="button" class="btn-format" onclick="insertTag('t2_prompt', '<em>', '</em>')">Italic</button>
                </div>
                <textarea id="t2_prompt" class="form-input">Some people believe that standardized testing is essential for education...

Discuss both views and give your own opinion.</textarea>
                <div class="info-box">💡 Minimum word count: 250 words</div>
            </div>
            <div>
                <h3>Model Answer</h3>
                <label for="t2_model" style="display:block;font-weight:600;color:var(--text-secondary);font-size:0.9rem;margin:16px 0 8px 0;">🎯 Band 9 Sample</label>
                <p class="info-box">Revealed after student submission for comparison.</p>
                <textarea id="t2_model" class="form-input" placeholder="It is argued that standardized testing plays a crucial role in education..."></textarea>
            </div>
        </div>
    </div>

    <div class="action-area">
        <div class="form-group">
            <label for="timeLimit">⏱️ Time Limit (minutes)</label>
            <input type="number" id="timeLimit" class="form-input" value="60" min="1" max="180">
        </div>
        <div class="form-group">
            <label for="testTitle">📚 Test Title</label>
            <input type="text" id="testTitle" class="form-input" placeholder="Writing Test - Week 1">
        </div>
        <button class="btn btn-primary btn-lg" onclick="saveTest()" style="grid-column:1/-1;font-size:1.1rem;">✨ Create & Save Test</button>
    </div>
</div>

<script>
    function switchTab(num) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.getElementById('tab' + num).classList.add('active');
        document.querySelectorAll('.tab')[num - 1].classList.add('active');
    }

    function insertTag(id, openTag, closeTag) {
        const textarea = document.getElementById(id);
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const selected = textarea.value.substring(start, end);
        const before = textarea.value.substring(0, start);
        const after = textarea.value.substring(end);
        textarea.value = before + openTag + selected + closeTag + after;
        textarea.selectionStart = start + openTag.length;
        textarea.selectionEnd = end + openTag.length;
        textarea.focus();
    }

    function previewImage(task) {
        const img = document.getElementById('t' + task + '_img').value;
        const preview = document.getElementById('prev_' + task);
        if (img.startsWith('http') || img.includes('.')) {
            preview.src = img;
            preview.style.display = 'block';
            preview.onerror = function() { this.style.display = 'none'; };
        } else {
            preview.style.display = 'none';
        }
    }

    async function saveTest() {
        const title = document.getElementById('testTitle').value.trim();
        if (!title) { alert('Please enter a test title'); return; }

        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

        const testData = {
            type: 'writing',
            title: title,
            readingPassage: JSON.stringify({
                timeLimit: parseInt(document.getElementById('timeLimit').value) || 60,
                task1: {
                    prompt: document.getElementById('t1_prompt').value,
                    image: document.getElementById('t1_img').value,
                    modelAnswer: document.getElementById('t1_model').value
                },
                task2: {
                    prompt: document.getElementById('t2_prompt').value,
                    modelAnswer: document.getElementById('t2_model').value
                }
            })
        };

        try {
            const res = await fetch('/create-test-writing', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
                body: JSON.stringify(testData)
            });
            if (res.ok) {
                alert('✨ Test created successfully!');
                window.location.href = '/admin';
            } else {
                alert('Error: ' + await res.text());
            }
        } catch (err) {
            alert('Error creating test: ' + err.message);
        }
    }
</script>
    <%- include('../partials/notifications') %>
</body>
</html>
