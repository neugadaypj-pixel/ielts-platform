<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken %>">
    <title>IELTS Writing Test Builder</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif; 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            color: #1f2937;
            padding: 20px;
        }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideInRight { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
        
        .container { 
            max-width: 1400px; 
            margin: 0 auto; 
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            animation: fadeIn 0.6s ease-out;
        }
        
        .header { margin-bottom: 40px; }
        
        h1 { 
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }
        
        .subtitle { 
            color: #6b7280;
            font-size: 1rem;
            font-weight: 500;
            margin: 0;
        }
        
        .tabs { 
            display: flex;
            gap: 8px;
            margin-bottom: 32px;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 0;
        }
        
        .tab { 
            padding: 12px 24px;
            border: none;
            background: transparent;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            color: #9ca3af;
            transition: all 0.3s ease;
            border-radius: 12px 12px 0 0;
            position: relative;
        }
        
        .tab:hover { 
            color: #667eea;
            background: rgba(102, 126, 234, 0.05);
        }
        
        .tab.active { 
            color: #667eea;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.05) 100%);
        }
        
        .tab-content { 
            display: none;
            padding: 32px;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, rgba(102, 126, 234, 0.05) 100%);
            border-radius: 16px;
            animation: fadeIn 0.3s ease-out;
        }
        
        .tab-content.active { display: block; }
        
        .editor-grid { 
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
        }
        
        h3 { 
            font-size: 1.3rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        h3:before {
            content: '';
            width: 4px;
            height: 24px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 2px;
        }
        
        label { 
            display: block;
            font-weight: 600;
            color: #374151;
            margin: 20px 0 8px 0;
            font-size: 0.95rem;
        }
        
        input[type="text"], 
        input[type="number"], 
        select,
        textarea { 
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 1rem;
            font-family: inherit;
            transition: all 0.3s ease;
            background: white;
        }
        
        input[type="text"]:focus, 
        input[type="number"]:focus,
        select:focus,
        textarea:focus { 
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
            outline: none;
        }
        
        textarea { 
            height: 320px;
            resize: vertical;
            font-family: "Fira Code", "Monaco", monospace;
            line-height: 1.6;
            padding: 16px;
        }
        
        .format-bar {
            display: flex;
            gap: 8px;
            margin: 12px 0 16px 0;
        }
        
        .btn-format { 
            background: white;
            color: #667eea;
            padding: 8px 16px;
            font-size: 0.9rem;
            border: 2px solid #667eea;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }
        
        .btn-format:hover { 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(102, 126, 234, 0.3);
        }
        
        .action-area { 
            margin-top: 48px;
            padding-top: 32px;
            border-top: 2px solid #e5e7eb;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
        
        .btn-download { 
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-size: 1.1rem;
            padding: 16px 32px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 12px 24px rgba(102, 126, 234, 0.3);
            grid-column: 1 / -1;
        }
        
        .btn-download:hover { 
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(102, 126, 234, 0.4);
        }
        
        .btn-download:active { 
            transform: translateY(-1px);
        }
        
        .image-preview { 
            margin-top: 12px;
            max-width: 100%;
            height: auto;
            border: 2px dashed #667eea;
            border-radius: 12px;
            padding: 8px;
            display: none;
        }
        
        .info-box {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.05) 100%);
            border-left: 4px solid #667eea;
            padding: 16px;
            border-radius: 8px;
            font-size: 0.95rem;
            color: #374151;
            margin: 12px 0;
        }
        
        @media (max-width: 1024px) {
            .editor-grid { grid-template-columns: 1fr; gap: 24px; }
            h1 { font-size: 2rem; }
        }

        /* Dark Mode Styles */
        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #e2e8f0;
        }

        body.dark-mode .container {
            background: rgba(30, 41, 59, 0.95);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
        }

        body.dark-mode h1 {
            background: linear-gradient(135deg, #a5f4fc 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        body.dark-mode .subtitle {
            color: #cbd5e1;
        }

        body.dark-mode .tabs {
            border-bottom-color: #334155;
        }

        body.dark-mode .tab {
            color: #94a3b8;
        }

        body.dark-mode .tab:hover {
            color: #667eea;
            background: rgba(102, 126, 234, 0.1);
        }

        body.dark-mode .tab.active {
            color: #667eea;
            background: rgba(102, 126, 234, 0.15);
        }

        body.dark-mode .tab-content {
            background: rgba(15, 23, 42, 0.6);
        }

        body.dark-mode h3 {
            color: #f1f5f9;
        }

        body.dark-mode label {
            color: #cbd5e1;
        }

        body.dark-mode input[type="text"],
        body.dark-mode input[type="number"],
        body.dark-mode select,
        body.dark-mode textarea {
            background: rgba(15, 23, 42, 0.95) !important;
            border-color: #475569 !important;
            color: #e2e8f0 !important;
        }

        body.dark-mode input::placeholder,
        body.dark-mode textarea::placeholder {
            color: #64748b !important;
        }

        body.dark-mode input:focus,
        body.dark-mode select:focus,
        body.dark-mode textarea:focus {
            border-color: #667eea !important;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.2) !important;
        }

        body.dark-mode .btn-format {
            background: rgba(15, 23, 42, 0.95);
            color: #a5b4fc;
            border-color: #667eea;
        }

        body.dark-mode .btn-format:hover {
            background: rgba(30, 41, 59, 0.95);
        }

        body.dark-mode .info-box {
            background: rgba(102, 126, 234, 0.15);
            border-left-color: #667eea;
            color: #cbd5e1;
        }

        body.dark-mode .image-preview {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.1);
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>✍️ IELTS Writing Builder</h1>
        <p class="subtitle">Create, review, and manage writing tests with AI-powered feedback</p>
    </div>

    <div class="tabs">
        <div class="tab active" onclick="switchTab(1)">📊 Task 1: Report</div>
        <div class="tab" onclick="switchTab(2)">📝 Task 2: Essay</div>
    </div>

    <div id="tab1" class="tab-content active">
        <div class="editor-grid">
            <div>
                <h3>Task Prompt</h3>
                <label>📈 Chart/Image (URL or filename)</label>
                <input type="text" id="t1_img" placeholder="https://example.com/chart.jpg" onchange="previewImage(1)">
                <img id="prev_1" class="image-preview" alt="Chart preview">
                
                <label>�� Instructions</label>
                <div class="format-bar">
                    <button class="btn-format" onclick="insertTag('t1_prompt', '<strong>', '</strong>')">Bold</button>
                    <button class="btn-format" onclick="insertTag('t1_prompt', '<em>', '</em>')">Italic</button>
                </div>
                <textarea id="t1_prompt">The chart below shows consumer spending patterns...

Summarise the information by selecting and reporting the main features, and make comparisons where relevant.</textarea>
                <div class="info-box">💡 Minimum word count: 150 words</div>
            </div>
            <div>
                <h3>Model Answer</h3>
                <label>🎯 Band 9 Sample</label>
                <p class="info-box">Revealed after student submission for comparison.</p>
                <textarea id="t1_model" placeholder="The bar chart illustrates consumer spending across different categories..."></textarea>
            </div>
        </div>
    </div>

    <div id="tab2" class="tab-content">
        <div class="editor-grid">
            <div>
                <h3>Task Prompt</h3>
                <label>📋 Instructions</label>
                <div class="format-bar">
                    <button class="btn-format" onclick="insertTag('t2_prompt', '<strong>', '</strong>')">Bold</button>
                    <button class="btn-format" onclick="insertTag('t2_prompt', '<em>', '</em>')">Italic</button>
                </div>
                <textarea id="t2_prompt">Some people believe that standardized testing is essential for education...

Discuss both views and give your own opinion.</textarea>
                <div class="info-box">💡 Minimum word count: 250 words</div>
            </div>
            <div>
                <h3>Model Answer</h3>
                <label>🎯 Band 9 Sample</label>
                <p class="info-box">Revealed after student submission for comparison.</p>
                <textarea id="t2_model" placeholder="It is argued that standardized testing plays a crucial role in education..."></textarea>
            </div>
        </div>
    </div>

    <div class="action-area">
        <div>
            <label>⏱️ Time Limit (minutes)</label>
            <input type="number" id="timeLimit" value="60" min="1" max="180">
        </div>
        <div>
            <label>📚 Test Title</label>
            <input type="text" id="testTitle" placeholder="Writing Test - Week 1">
        </div>
        <button class="btn-download" onclick="saveTest()">✨ Create & Save Test</button>
    </div>
</div>

<script>
    function switchTab(num) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.getElementById('tab' + num).classList.add('active');
        document.querySelectorAll('.tab')[num - 1].classList.add('active');
    }

    function insertTag(id, openTag, closeTag) {
        const textarea = document.getElementById(id);
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const selected = textarea.value.substring(start, end);
        const before = textarea.value.substring(0, start);
        const after = textarea.value.substring(end);
        textarea.value = before + openTag + selected + closeTag + after;
        textarea.selectionStart = start + openTag.length;
        textarea.selectionEnd = end + openTag.length;
        textarea.focus();
    }

    function previewImage(task) {
        const img = document.getElementById('t' + task + '_img').value;
        const preview = document.getElementById('prev_' + task);
        if (img.startsWith('http') || img.includes('.')) {
            preview.src = img;
            preview.style.display = 'block';
            preview.onerror = function() { this.style.display = 'none'; };
        } else {
            preview.style.display = 'none';
        }
    }

    async function saveTest() {
        const title = document.getElementById('testTitle').value.trim();
        if (!title) { alert('Please enter a test title'); return; }

        const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

        const testData = {
            type: 'writing',
            title: title,
            readingPassage: JSON.stringify({
                timeLimit: parseInt(document.getElementById('timeLimit').value) || 60,
                task1: {
                    prompt: document.getElementById('t1_prompt').value,
                    image: document.getElementById('t1_img').value,
                    modelAnswer: document.getElementById('t1_model').value
                },
                task2: {
                    prompt: document.getElementById('t2_prompt').value,
                    modelAnswer: document.getElementById('t2_model').value
                }
            })
        };

        try {
            const res = await fetch('/create-test-writing', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
                body: JSON.stringify(testData)
            });
            if (res.ok) {
                alert('✨ Test created successfully!');
                window.location.href = '/admin';
            } else {
                alert('Error: ' + await res.text());
            }
        } catch (err) {
            alert('Error creating test: ' + err.message);
        }
    }
</script>

</body>
</html>
