<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reading Test</title>
    <%- include('../partials/design-system') %>
    <style>
        body {
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px;
            transition: all 0.3s ease;
        }
        body.theme-modern { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        body.theme-monochrome { background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%); }
        body.theme-ocean { background: linear-gradient(135deg, #06b6d4 0%, #0369a1 100%); }
        body.theme-forest { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        body.theme-sunset { background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); }
        body.dark-mode { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important; color: var(--text-primary); }
        .container { max-width: 1400px; margin: 0 auto; }
        header {
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            padding: 28px 32px;
            border-radius: var(--radius-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            box-shadow: var(--shadow-lg);
            flex-wrap: wrap;
            gap: 16px;
        }
        header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .timer {
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: white;
            padding: 12px 24px;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 1.1rem;
        }
        .header-controls { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .theme-selector { display: flex; gap: 6px; align-items: center; background: rgba(229, 231, 235, 0.5); padding: 8px; border-radius: var(--radius-md); }
        .theme-circle {
            width: 32px; height: 32px; border: 2px solid transparent;
            border-radius: 8px; cursor: pointer; transition: all 0.3s ease; font-size: 12px;
        }
        .theme-circle:hover { transform: scale(1.1); }
        .theme-circle.active { border-color: var(--text-primary); box-shadow: 0 0 8px rgba(0, 0, 0, 0.2); }
        .theme-modern-btn { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .theme-monochrome-btn { background: linear-gradient(135deg, #6b7280 0%, #1f2937 100%); }
        .theme-ocean-btn { background: linear-gradient(135deg, #06b6d4 0%, #0369a1 100%); }
        .theme-forest-btn { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .theme-sunset-btn { background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); }
        .content { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
        .test-section {
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
        }
        .passage {
            background: var(--gray-50);
            padding: 28px;
            border-radius: var(--radius-md);
            line-height: 1.8;
            margin-bottom: 24px;
            font-size: 1.05rem;
            color: var(--text-secondary);
            max-height: 400px;
            overflow-y: auto;
        }
        .passage::-webkit-scrollbar { width: 6px; }
        .passage::-webkit-scrollbar-track { background: var(--border); border-radius: 3px; }
        .passage::-webkit-scrollbar-thumb { background: var(--primary-400); border-radius: 3px; }
        .questions { display: flex; flex-direction: column; gap: 28px; }
        .question-item {
            padding: 20px;
            background: var(--gray-50);
            border-radius: var(--radius-md);
            border-left: 4px solid var(--primary-400);
        }
        .question-text { font-weight: 700; color: var(--text-primary); margin-bottom: 16px; }
        .options { display: flex; flex-direction: column; gap: 12px; }
        .option {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px; background: white; border: 2px solid var(--border);
            border-radius: var(--radius-md); cursor: pointer; transition: all 0.3s ease;
        }
        .option:hover { border-color: var(--primary-400); background: var(--primary-50); }
        .option input[type="radio"] { cursor: pointer; width: 18px; height: 18px; accent-color: var(--primary-400); }
        footer { display: flex; gap: 16px; justify-content: flex-end; }
        .btn-submit {
            padding: 14px 28px; border: none; border-radius: var(--radius-md);
            font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: all 0.3s ease;
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: white; box-shadow: 0 6px 16px rgba(102, 126, 234, 0.3);
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(102, 126, 234, 0.4); }
        @media (max-width: 1024px) { .content { grid-template-columns: 1fr; } }
        @media (max-width: 768px) {
            header { flex-direction: column; gap: 16px; text-align: center; }
            header h1 { font-size: 1.4rem; }
        }
        body.dark-mode header { background: rgba(30, 41, 59, 0.95) !important; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3) !important; }
        body.dark-mode .test-section { background: rgba(30, 41, 59, 0.95) !important; color: var(--text-primary); }
        body.dark-mode .passage { background: rgba(15, 23, 42, 0.95) !important; color: #cbd5e1 !important; }
        body.dark-mode .question-item { background: rgba(30, 41, 59, 0.95) !important; }
        body.dark-mode .option { background: rgba(15, 23, 42, 0.95) !important; border-color: #475569 !important; }
        body.dark-mode label { color: #cbd5e1 !important; }
    </style>
    <script src="/time-warning.js"></script>
    <script src="/loading-spinner.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>📖 Reading Test</h1>
            <div class="timer">⏱️ Time: 00:00</div>
        </header>
        
        <div class="content">
            <div class="test-section">
                <h2 style="margin-bottom: 20px; color: #1f2937;">📄 Reading Passage</h2>
                <div class="passage">
                    <%= test.passage %>
                </div>
            </div>
            
            <div class="test-section">
                <h2 style="margin-bottom: 24px; color: #1f2937;">❓ Questions</h2>
                <div class="questions">
                    <% if(test.questions && test.questions.length > 0) { %>
                        <% test.questions.forEach((q, index) => { %>
                            <div class="question-item">
                                <div class="question-text"><%= q.text %></div>
                                <div class="options">
                                    <% q.options.forEach(opt => { %>
                                        <label class="option">
                                            <input type="radio" name="answer_<%= index %>" value="<%= opt %>">
                                            <span><%= opt %></span>
                                        </label>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
        
        <footer>
            <button class="btn-submit">Submit Test →</button>
        </footer>
    </div>
    <%- include('../partials/notifications') %>
</body>
</html>
