<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Teacher Dashboard - ExamApp</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background: #f4f7f6; display: flex; min-height: 100vh; }
        .sidebar { width: 250px; background: #2c3e50; color: white; padding: 20px; box-sizing: border-box; }
        .main-content { flex-grow: 1; padding: 40px; box-sizing: border-box; }
        .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 30px; }
        h1 { color: #2c3e50; margin-top: 0; }
        h3 { color: #8e44ad; border-bottom: 2px solid #f4ecf7; padding-bottom: 10px; margin-top: 0; }
        
        /* Buttons */
        .btn { display: inline-block; background: #3498db; color: white; padding: 10px 18px; text-decoration: none; border-radius: 8px; font-weight: bold; border: none; cursor: pointer; transition: 0.2s; }
        .btn:hover { background: #2980b9; transform: translateY(-2px); }
        .btn-green { background: #27ae60; }
        .btn-green:hover { background: #219653; }
        
        /* Forms */
        .form-group { margin-bottom: 15px; display: flex; gap: 10px; align-items: center; }
        select, input[type="text"] { padding: 10px; border-radius: 8px; border: 1px solid #ddd; flex-grow: 1; }
        
        /* Tables */
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th, td { text-align: left; padding: 12px; border-bottom: 1px solid #eee; }
        th { background: #f8f9fa; color: #7f8c8d; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; }

        /* Group Grid */
        .group-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        .group-card { border: 1px solid #e1e4e8; border-radius: 12px; padding: 15px; background: #fdfdfd; }
        .group-name { font-size: 18px; font-weight: bold; color: #2c3e50; margin-bottom: 10px; display: block; }
        .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; background: #eee; margin-left: 5px; }
        
        .logout { color: #e74c3c; text-decoration: none; display: block; margin-top: 20px; font-weight: bold; border-top: 1px solid #34495e; padding-top: 20px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>ExamApp</h2>
        <p>Teacher: <strong><%= teacher.username %></strong></p>
        <a href="/logout" class="logout">🚪 Logout</a>
    </div>

    <div class="main-content">
        <h1>Teacher Management</h1>

        <div class="card">
            <h3>🏫 Create New Group</h3>
            <form action="/teacher/create-group" method="POST" class="form-group">
                <input type="text" name="groupName" placeholder="e.g., IELTS Morning Batch" required>
                <button type="submit" class="btn btn-green">Create Group</button>
            </form>
        </div>

        <div class="card">
            <h3>🔗 Assignment Controls</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                
                <form action="/teacher/assign-to-group" method="POST">
                    <label><strong>Add Student to Group:</strong></label>
                    <div class="form-group" style="margin-top:10px;">
                        <select name="studentId">
                            <% allStudents.forEach(s => { %>
                                <option value="<%= s._id %>"><%= s.username %></option>
                            <% }) %>
                        </select>
                        <select name="groupId">
                            <% groups.forEach(g => { %>
                                <option value="<%= g._id %>"><%= g.name %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn">Add</button>
                    </div>
                </form>

                <form action="/teacher/assign-test-group" method="POST">
                    <label><strong>Assign Test to Group:</strong></label>
                    <div class="form-group" style="margin-top:10px;">
                        <select name="testId">
                            <% tests.forEach(t => { %>
                                <option value="<%= t._id %>"><%= t.title %></option>
                            <% }) %>
                        </select>
                        <select name="groupId">
                            <% groups.forEach(g => { %>
                                <option value="<%= g._id %>"><%= g.name %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn">Assign</button>
                    </div>
                </form>

            </div>
        </div>

        <div class="card">
            <h3>📦 Active Groups</h3>
            <% if (groups.length > 0) { %>
                <div class="group-grid">
                    <% groups.forEach(group => { %>
                        <div class="group-card">
                            <span class="group-name">Group: <%= group.name %></span>
                            <p style="font-size: 13px; color: #7f8c8d;">
                                👥 Students: <%= group.students.length %><br>
                                📝 Tests: <%= group.assignedTests.length %>
                            </p>
                            <hr style="border: 0.5px solid #eee;">
                            <div style="font-size: 12px;">
                                <strong>Assigned Tests:</strong>
                                <ul style="padding-left: 20px;">
                                    <% group.assignedTests.forEach(t => { %>
                                        <li><%= t.title %></li>
                                    <% }) %>
                                </ul>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p>No groups created yet. Create one above!</p>
            <% } %>
        </div>

        <div class="card">
            <h3>👥 All Registered Students</h3>
            <a href="/teacher/add-student" class="btn btn-green">➕ Register New Student</a>
            <table>
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Current Group</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% allStudents.forEach(student => { %>
                        <tr>
                            <td><strong><%= student.username %></strong></td>
                            <td>
                                <% if(student.groupId) { %>
                                    <span class="badge" style="background:#e8daef; color:#8e44ad;"><%= groups.find(g => g._id.toString() == student.groupId.toString())?.name %></span>
                                <% } else { %>
                                    <span class="badge">No Group</span>
                                <% } %>
                            </td>
                            <td><a href="#" style="color: #3498db; font-weight: bold; text-decoration: none;">📊 View Progress</a></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>