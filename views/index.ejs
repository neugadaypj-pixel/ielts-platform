<!DOCTYPE html>
<html>
<head>
    <title>Exam Platform</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding-top: 100px; background: #f4f4f4; }
        .container { background: white; padding: 40px; display: inline-block; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .btn { padding: 15px 30px; margin: 10px; font-size: 18px; cursor: pointer; border: none; border-radius: 6px; transition: 0.3s; }
        .btn-student { background: #007bff; color: white; }
        .btn-teacher { background: #28a745; color: white; }
        .btn:hover { opacity: 0.8; transform: translateY(-2px); }
        a { text-decoration: none; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Welcome to the Test Platform</h1>
        <p>Select your role to continue</p>
        <a href="/login"><button class="btn btn-student">I am a Student</button></a>
        <a href="/login"><button class="btn btn-teacher">I am a Teacher</button></a>
    </div>
</body>
</html>