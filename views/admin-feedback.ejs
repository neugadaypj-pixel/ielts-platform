<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Feedback</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           ADMIN FEEDBACK — feedback list with tabs and resolve forms
           ============================================================ */
        body { padding: var(--space-lg); }
        .admin-feedback-container { max-width: 1200px; margin: 0 auto; }

        .tabs { display: flex; gap: var(--space-sm); margin-bottom: var(--space-lg); }
        .tab {
            padding: var(--space-sm) var(--space-lg);
            border-radius: var(--radius-full);
            font-weight: 800;
            cursor: pointer;
            background: var(--surface-glass);
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 0.9rem;
            font-family: var(--font-sans);
            transition: all var(--transition-fast);
        }
        .tab.active {
            background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
            color: #fff;
            border: none;
        }
        .tab:hover:not(.active) { background: var(--gray-100); }

        .feedback-list { display: grid; gap: var(--space-md); }

        .feedback-card {
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-lg);
            padding: var(--space-lg);
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(255,255,255,0.12);
        }
        .feedback-header { display: flex; justify-content: space-between; align-items: start; margin-bottom: var(--space-md); }
        .feedback-meta { font-size: 0.85rem; color: var(--text-muted); }
        .feedback-content { margin: var(--space-md) 0; line-height: 1.6; color: var(--text-primary); }

        .resolve-form {
            margin-top: var(--space-md);
            padding-top: var(--space-md);
            border-top: 1px solid var(--border);
            display: grid;
            gap: var(--space-sm);
        }

        .admin-note {
            margin-top: var(--space-sm);
            padding: var(--space-sm) var(--space-md);
            background: var(--gray-50);
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            color: var(--text-secondary);
        }
        .admin-reply {
            margin-top: var(--space-sm);
            padding: var(--space-sm) var(--space-md);
            background: var(--primary-50);
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            color: var(--primary-800);
            border-left: 4px solid var(--primary-500);
        }

        body.dark-mode .admin-note { background: var(--gray-800); }
        body.dark-mode .admin-reply { background: rgba(99, 102, 241, 0.1); border-left-color: var(--primary-400); color: var(--primary-200); }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <div class="admin-feedback-container">
        <div class="page-header">
            <div>
                <h1 class="page-title">📬 Student Feedback</h1>
                <p class="page-subtitle">Review and resolve student-reported issues</p>
            </div>
            <a href="/admin" class="btn btn-ghost btn-sm">← Back</a>
        </div>

        <div class="tabs">
            <button class="tab <%= status === 'open' ? 'active' : '' %>" onclick="window.location.href='/admin/feedback?status=open'">Open (<%= feedback.filter(f => f.status === 'open').length %>)</button>
            <button class="tab <%= status === 'resolved' ? 'active' : '' %>" onclick="window.location.href='/admin/feedback?status=resolved'">Resolved</button>
        </div>

        <div class="feedback-list">
            <% if (feedback.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <div class="empty-title">No <%= status %> feedback yet.</div>
                </div>
            <% } else { %>
                <% feedback.forEach(item => { %>
                    <div class="feedback-card">
                        <div class="feedback-header">
                            <div>
                                <strong style="font-size:1.1rem;"><%= item.studentName %></strong>
                                <div class="feedback-meta">
                                    <%= new Date(item.createdAt).toLocaleString() %> •
                                    <span style="text-transform:capitalize;"><%= item.testType %></span>
                                    <% if (item.questionType) { %> • <%= item.questionType %><% } %>
                                </div>
                            </div>
                            <span class="badge <%= item.status === 'open' ? 'badge-error' : 'badge-success' %>"><%= item.status %></span>
                        </div>
                        <div class="feedback-content"><%= item.issueDescription %></div>
                        <% if (item.status === 'open') { %>
                            <div class="resolve-form">
                                <textarea id="notes-<%= item._id %>" class="form-input" placeholder="Add admin notes (optional)..." style="min-height:80px;resize:vertical;"></textarea>
                                <textarea id="reply-<%= item._id %>" class="form-input" placeholder="Message back to <%= item.studentName %> (optional)..." style="min-height:80px;resize:vertical;"></textarea>
                                <div style="display:flex;gap:var(--space-sm);flex-wrap:wrap;">
                                    <button class="btn btn-success btn-sm" onclick="resolve('<%= item._id %>')">Mark as Resolved</button>
                                    <button class="btn btn-primary btn-sm" onclick="sendReply('<%= item._id %>', '<%= item.studentId %>')">Send Reply</button>
                                </div>
                            </div>
                        <% } else { %>
                            <% if (item.adminNotes) { %>
                                <div class="admin-note">
                                    <strong>Admin Notes:</strong> <%= item.adminNotes %>
                                </div>
                            <% } %>
                            <% if (item.adminReply) { %>
                                <div class="admin-reply">
                                    <strong>Reply to Student:</strong> <%= item.adminReply %>
                                </div>
                            <% } %>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <script>
        async function resolve(id) {
            const notes = document.getElementById('notes-' + id).value;
            const reply = document.getElementById('reply-' + id).value;
            const res = await fetch('/admin/feedback/' + id + '/resolve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ adminNotes: notes, adminReply: reply })
            });
            if (res.ok) location.reload();
            else alert('Error resolving feedback');
        }

        async function sendReply(feedbackId, studentId) {
            const reply = document.getElementById('reply-' + feedbackId).value;
            if (!reply.trim()) {
                alert('Please enter a reply message');
                return;
            }
            const res = await fetch('/admin/feedback/' + feedbackId + '/reply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reply, studentId })
            });
            if (res.ok) {
                alert('Reply sent successfully!');
                location.reload();
            } else {
                alert('Error sending reply');
            }
        }
    </script>
    <%- include('partials/notifications') %>
</body>
</html>
