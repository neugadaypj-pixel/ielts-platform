    /* --- RESTORE LOGIC --- */
    window.addEventListener('load', function() {
        const savedTheme = localStorage.getItem('theme_' + SESSION_KEY);
        if (savedTheme === 'dark') {
            document.body.classList.add('dark-mode');
            const tBtn = document.querySelector('.theme-btn');
            if(tBtn) tBtn.innerText = '☀️';
        }

        if(localStorage.getItem(SESSION_KEY + '_name')) document.getElementById('studentName').value = localStorage.getItem(SESSION_KEY + '_name');

        restoreState(); 
        updatePickNStates();
        setTimeout(() => renderSubNav(1), 100); 
        
        // Add Block Flag Buttons dynamically
        document.querySelectorAll('.tf-question, .multi-choice-question, .short-answer-question, .pick-n-question, .matching-group-block, .flow-question-block, .map-question-block').forEach(el => {
            if(el.querySelector('.flag-btn')) return;
            const btn = document.createElement('button');
            btn.className = 'flag-btn'; btn.innerHTML = '⚑'; btn.title = 'Flag for Review';
            btn.onclick = function() { toggleBlockFlag(this); };
            el.appendChild(btn);
        });

        // Add Inline Flags to standard gaps
        document.querySelectorAll('.gap-input').forEach(inp => {
            if(!inp.nextElementSibling || !inp.nextElementSibling.classList.contains('inline-flag')) {
                const flag = document.createElement('span');
                flag.className = 'q-flag inline-flag';
                flag.innerHTML = '⚑';
                flag.title = 'Flag for Review';
                flag.onclick = function() { toggleInlineFlag(this, inp.id.replace('q', '')); };
                inp.parentNode.insertBefore(flag, inp.nextSibling);
            }
        });

        const savedState = localStorage.getItem(AUDIO_KEY);
        if(savedState) {
            try {
                const state = JSON.parse(savedState);
                if(isFullAudio && state.time > 0) {
                    audioPlayer.src = fullAudioData;
                    audioPlayer.currentTime = state.time;
                    document.getElementById('mainStartBtn').innerText = "Resume Test";
                    document.getElementById('mainStartBtn').style.background = "linear-gradient(135deg, #27ae60 0%, #2ecc71 100%)";
                    document.getElementById('welcomeMsg').innerText = "Resume your test";
                } else if (!isFullAudio && state.index !== undefined && state.time > 0) {
                    currentAudioIndex = state.index;
                    if(audioDataList[currentAudioIndex]) {
                        audioPlayer.src = audioDataList[currentAudioIndex];
                        audioPlayer.currentTime = state.time;
                    }
                    document.getElementById('mainStartBtn').innerText = "Resume Test";
                    document.getElementById('mainStartBtn').style.background = "linear-gradient(135deg, #27ae60 0%, #2ecc71 100%)";
                    document.getElementById('welcomeMsg').innerText = "Resume from Part " + (state.index+1);
                }
            } catch(e) {}
        }
    });

    if(audioPlayer) {
        audioPlayer.addEventListener('timeupdate', function() {
            if(!audioPlayer.paused && !audioPlayer.ended) {
                const state = isFullAudio ? { time: audioPlayer.currentTime } : { index: currentAudioIndex, time: audioPlayer.currentTime };
                localStorage.setItem(AUDIO_KEY, JSON.stringify(state));
            }
        });

        audioPlayer.addEventListener('ended', function() {
            if(isFullAudio) {
                finishAudio();
            } else {
                if(currentAudioIndex < audioDataList.length - 1) {
                    currentAudioIndex++;
                    if(audioDataList[currentAudioIndex]) {
                        
                        if (usePause) {
                            // 30 SECOND COUNTDOWN LOGIC
                            let pauseSeconds = 30;
                            document.getElementById('timerDisplay').style.color = "#e67e22";
                            document.getElementById('timerDisplay').innerText = "Next Part in: " + pauseSeconds + "s";
                            
                            let pauseInterval = setInterval(() => {
                                pauseSeconds--;
                                if (pauseSeconds <= 0) {
                                    clearInterval(pauseInterval);
                                    document.getElementById('timerDisplay').style.color = "";
                                    document.getElementById('timerDisplay').innerText = "Playing Part " + (currentAudioIndex+1);
                                    audioPlayer.src = audioDataList[currentAudioIndex];
                                    audioPlayer.play();
                                } else {
                                    document.getElementById('timerDisplay').innerText = "Next Part in: " + pauseSeconds + "s";
                                }
                            }, 1000);
                        } else {
                            // NORMAL PLAYBACK
                            audioPlayer.src = audioDataList[currentAudioIndex];
                            audioPlayer.play();
                        }
                        
                    } else {
                        finishAudio();
                    }
                } else {
                    finishAudio();
                }
            }
        });
    }

    function finishAudio() {
        localStorage.removeItem(AUDIO_KEY);
        startReviewTimer(120); 
    }

    function startTest() {
        document.getElementById('startOverlay').style.display = 'none';
        testStarted = true;
        
        if(!audioPlayer.src) {
            if(isFullAudio && fullAudioData) {
                audioPlayer.src = fullAudioData;
            } else if (!isFullAudio && audioDataList[0]) {
                audioPlayer.src = audioDataList[0];
            } else if (!isFullAudio && audioDataList[currentAudioIndex]) {
                audioPlayer.src = audioDataList[currentAudioIndex];
            }
        }
        
        audioPlayer.play().then(() => {
            document.getElementById('timerDisplay').innerText = isFullAudio ? "Playing Audio" : "Playing Part " + (currentAudioIndex+1);
        }).catch(e => {
            document.getElementById('timerDisplay').innerText = "Click to Play";
        });
    }

    function startReviewTimer(sec) {
        reviewTime = true;
        secondsLeft = sec;
        clearInterval(timerInterval);
        document.getElementById('timerDisplay').style.color = "#e67e22";
        
        timerInterval = setInterval(() => {
            if(secondsLeft <= 0) {
                clearInterval(timerInterval);
                checkAnswers(false, true); 
            } else {
                secondsLeft--;
                let m = Math.floor(secondsLeft/60);
                let s = secondsLeft%60;
                document.getElementById('timerDisplay').innerText = "Review: " + m + ":" + (s<10?'0':'')+s;
            }
        }, 1000);
    }

    /* --- HIGHLIGHT LOGIC (3 COLORS) --- */
    const ctxMenu = document.getElementById('contextMenu');
    const questionsPanel = document.getElementById('questionsPanel');
    let savedRange = null;

    questionsPanel.addEventListener('contextmenu', function(e) {
        e.preventDefault();
        const sel = window.getSelection();
        if (sel.rangeCount > 0 && !sel.isCollapsed) {
            savedRange = sel.getRangeAt(0);
            ctxMenu.style.display = 'block'; 
            ctxMenu.style.left = e.clientX + 'px'; 
            ctxMenu.style.top = e.clientY + 'px';
        }
    });

    document.addEventListener('click', function(e) { 
        if (!ctxMenu.contains(e.target)) ctxMenu.style.display = 'none'; 
    });

    function performHighlight(colorCode) { 
        if (savedRange) { 
            const sel = window.getSelection(); sel.removeAllRanges(); sel.addRange(savedRange);
            document.body.contentEditable = "true";
            document.execCommand("BackColor", false, colorCode); 
            document.body.contentEditable = "false";
            sel.removeAllRanges(); savedRange = null; 
            saveState(); 
        } 
        ctxMenu.style.display = 'none'; 
    }

    function clearHighlight() { 
        if (savedRange) { 
            const sel = window.getSelection(); sel.removeAllRanges(); sel.addRange(savedRange); 
            document.body.contentEditable = "true";
            document.execCommand("BackColor", false, "transparent"); 
            document.body.contentEditable = "false";
            sel.removeAllRanges(); savedRange = null; 
            saveState(); 
        } 
        ctxMenu.style.display = 'none'; 
    }

    /* --- MAP / FLOW LOGIC --- */
    function openMapPicker(zone) {
        if(isSubmitted) return;
        const variants = zone.dataset.variants.split(',');
        let popup = document.getElementById('variantPopup');
        if (!popup) { popup = document.createElement('div'); popup.id = 'variantPopup'; popup.className = 'variant-popup'; document.body.appendChild(popup); }
        popup.innerHTML = '';
        variants.forEach(v => {
            const div = document.createElement('div'); div.className = 'variant-option'; div.innerText = v;
            div.onclick = function() { 
                const qId = zone.dataset.qid;
                zone.innerHTML = `<strong>${qId}</strong> ${v} <input type="hidden" id="q${qId}" value="${v}" autocomplete="off">`;
                zone.dataset.droppedText = v;
                zone.classList.add('filled');
                popup.style.display = ''; 
                popup.classList.remove('active-popup');
                saveState();
            };
            popup.appendChild(div);
        });
        
        // SMART POSITIONING LOGIC
        popup.style.display = '';
        popup.classList.add('active-popup');
        const rect = zone.getBoundingClientRect();
        const popupHeight = popup.offsetHeight;
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;
        const spaceBelow = window.innerHeight - rect.bottom;
        
        if (spaceBelow < popupHeight && rect.top > popupHeight) {
            popup.style.top = (rect.top + scrollTop - popupHeight - 5) + 'px';
        } else {
            popup.style.top = (rect.bottom + scrollTop + 5) + 'px';
        }
        popup.style.left = (rect.left + scrollLeft) + 'px';
    }

    function clearZone(zone) {
        if(isSubmitted) return;
        if(zone.classList.contains('filled')) {
            const qId = zone.dataset.qid;
            zone.innerHTML = `? <input type="hidden" id="q${qId}" value="">`;
            zone.classList.remove('filled');
            delete zone.dataset.droppedText;
            saveState();
        }
    }

    function scrollToQuestion(qNum) {
        let el = document.getElementById('q' + qNum);
        let target = el;
        
        if (!target) {
            target = document.querySelector('[data-q-start="' + qNum + '"]');
        }
        
        if (!target) {
            const cb = document.querySelector('input[data-questions~="' + qNum + '"]');
            if (cb) target = cb.closest('.pick-n-question');
        }

        if (target && target.tagName === 'INPUT' && target.type === 'hidden') {
            const mapZone = target.closest('.map-drop-zone');
            const matchItem = target.closest('.match-item');
            if (mapZone) target = mapZone;
            else if (matchItem) target = matchItem;
        }

        if (target) {
            target.scrollIntoView({behavior: "smooth", block: "center"});
            target.classList.remove('target-glow');
            void target.offsetWidth; 
            target.classList.add('target-glow');
            setTimeout(() => target.classList.remove('target-glow'), 2000);
        }
    }

    /* --- NAV LOGIC --- */
    function renderSubNav(partNum) {
        const container = document.getElementById('subNav');
        container.innerHTML = '';
        
        const qPanel = document.getElementById('panel_q'+partNum);
        const qSet = new Set();
        
        if(!qPanel) return;
        
        qPanel.querySelectorAll('input[id^="q"], select[id^="q"]').forEach(el => qSet.add(el.id.replace('q','')));
        qPanel.querySelectorAll('.map-drop-zone').forEach(el => qSet.add(el.dataset.qid));
        qPanel.querySelectorAll('.multi-checkbox').forEach(el => {
            el.dataset.questions.split(' ').forEach(q => qSet.add(q));
        });
        qPanel.querySelectorAll('[data-q-start]').forEach(el => qSet.add(el.dataset.qStart));
        
        const sortedQs = Array.from(qSet).sort((a,b) => parseInt(a)-parseInt(b));
        
        sortedQs.forEach((q, idx) => {
            const btn = document.createElement('div');
            btn.className = 'nav-circle';
            btn.style.animationDelay = (idx * 0.05) + 's';
            btn.classList.add('nav-enter');
            btn.innerText = q;
            btn.onclick = () => scrollToQuestion(q);
            container.appendChild(btn);
        });
        
        let saved = null;
        try { saved = JSON.parse(localStorage.getItem(SESSION_KEY)); } catch(e){}
        if(saved) updateNavigatorUI(saved);
    }

    function saveState() {
        if(isResetting || !testStarted) return;
        const state = { submitted: isSubmitted, answers: {}, drops: {}, flags: [], htmlContent: {} };
        
        [1,2,3,4].forEach(i => {
             const el = document.getElementById('panel_q'+i);
             if(el) state.htmlContent['p'+i] = el.innerHTML;
        });

        document.querySelectorAll('input:not([type="hidden"]), select').forEach(el => {
            if(el.type === 'radio') { if(el.checked) state.answers[el.name] = el.value; } 
            else if(el.id) { state.answers[el.id] = el.value; }
        });
        
        document.querySelectorAll('.custom-select-wrapper input[type="hidden"]').forEach(el => {
            if(el.value) state.answers[el.id] = el.value;
        });
        
        document.querySelectorAll('.pick-n-question').forEach(group => {
            const startQ = group.dataset.groupStart; const checks = [];
            group.querySelectorAll('input[type="checkbox"]:checked').forEach(cb => checks.push(cb.value));
            if(checks.length > 0) state.answers['multi_'+startQ] = checks;
        });
        
        document.querySelectorAll('.map-drop-zone.filled').forEach(zone => {
            const hidden = zone.querySelector('input[type="hidden"]');
            if(hidden && hidden.value) {
                state.drops[zone.dataset.qid] = { val: hidden.value, text: zone.dataset.droppedText || hidden.value };
            }
        });
        
        document.querySelectorAll('.flagged').forEach(block => {
             block.querySelectorAll('input[id^="q"], select[id^="q"]').forEach(el => {
                 const id = String(el.id).replace('q','');
                 if(id && !state.flags.includes(id)) state.flags.push(id);
             });
             block.querySelectorAll('.map-drop-zone').forEach(el => {
                 const id = String(el.dataset.qid);
                 if(id && !state.flags.includes(id)) state.flags.push(id);
             });
             block.querySelectorAll('input[type="radio"][name^="q"]').forEach(el => {
                 const id = String(el.name).replace('q','');
                 if(id && !state.flags.includes(id)) state.flags.push(id);
             });
             block.querySelectorAll('input[type="checkbox"][data-questions]').forEach(el => {
                 el.dataset.questions.split(' ').forEach(id => {
                     if(id && !state.flags.includes(id)) state.flags.push(String(id));
                 });
             });
             if(block.dataset.qStart && !state.flags.includes(String(block.dataset.qStart))) { 
                 state.flags.push(String(block.dataset.qStart)); 
             }
        });
        
        document.querySelectorAll('.gap-input.flagged-input').forEach(inp => {
             const id = String(inp.id).replace('q', '');
             if(id && !state.flags.includes(id)) state.flags.push(id);
        });
        document.querySelectorAll('.map-drop-zone.flagged-zone').forEach(zone => {
             const id = String(zone.dataset.qid);
             if(id && !state.flags.includes(id)) state.flags.push(id);
        });

        updateNavigatorUI(state);
        localStorage.setItem(SESSION_KEY, JSON.stringify(state));
    }
    
    function updateNavigatorUI(state) {
        document.querySelectorAll('.nav-circle').forEach(btn => {
            const q = btn.innerText;
            let isAnswered = false;
            if(state.answers['q'+q] || state.answers[q]) isAnswered = true;
            if(state.drops[q]) isAnswered = true;
            for(const k in state.answers) {
                if(k.startsWith('multi_')) {
                    if(state.answers[k].length > 0) {
                         const group = document.querySelector(`.pick-n-question[data-group-start="${k.replace('multi_','')}"]`);
                         if(group) {
                             const qs = group.querySelectorAll('input')[0].dataset.questions.split(' ');
                             if(qs.includes(q)) isAnswered = true;
                         }
                    }
                }
            }
            const isFlagged = state.flags.includes(String(q));
            
            btn.classList.remove('answered', 'flagged');
            if(isAnswered) btn.classList.add('answered');
            if(isFlagged) btn.classList.add('flagged');
        });
    }

    function restoreState() {
        let saved = null;
        try { saved = localStorage.getItem(SESSION_KEY); } catch(e){}
        if(!saved) return; 
        try {
            const state = JSON.parse(saved);
            
            if(state.htmlContent) {
                for(const [pid, html] of Object.entries(state.htmlContent)) {
                    const el = document.getElementById(pid.replace('p', 'panel_q'));
                    if(el) el.innerHTML = html;
                }
            }
            if(state.submitted) isSubmitted = true;
            
            for(const [key, val] of Object.entries(state.answers)) {
                if(key.startsWith('multi_')) {
                    const startQ = key.replace('multi_', '');
                    const group = document.querySelector(`.pick-n-question[data-group-start="${startQ}"]`);
                    if(group) {
                        val.forEach(v => {
                            const cb = group.querySelector(`input[value="${v}"]`);
                            if(cb) cb.checked = true;
                        });
                    }
                } else {
                    const radios = document.getElementsByName(key);
                    if(radios.length > 0) {
                        for(let i=0; i<radios.length; i++) { if(radios[i].value === val) radios[i].checked = true; }
                    } else {
                        const el = document.getElementById(key);
                        if(el) {
                            el.value = val;
                            const wrapper = el.closest('.custom-select-wrapper');
                            if (wrapper) {
                                const triggerText = wrapper.querySelector('.sel-text');
                                const trigger = wrapper.querySelector('.custom-select-trigger');
                                if(val) { triggerText.innerText = val; trigger.classList.add('answered'); } 
                                else { triggerText.innerText = 'Select...'; trigger.classList.remove('answered'); }
                            }
                        }
                    }
                }
            }
            
            if(state.drops) {
                for(const [qid, data] of Object.entries(state.drops)) {
                    const zone = document.querySelector(`.map-drop-zone[data-qid="${qid}"]`);
                    if(zone) {
                        zone.innerHTML = `<strong>${qid}</strong> ${data.text} <input type="hidden" id="q${qid}" value="${data.val}" autocomplete="off">`;
                        zone.dataset.droppedText = data.text;
                        zone.classList.add('filled');
                    }
                }
            }
            
             if(state.flags) {
                state.flags.forEach(qid => {
                    const zone = document.querySelector(`.map-drop-zone[data-qid="${qid}"]`);
                    if(zone) { 
                        zone.classList.add('flagged-zone'); 
                        if(zone.nextElementSibling && zone.nextElementSibling.classList.contains('q-flag')) { 
                            zone.nextElementSibling.classList.add('active'); 
                        } 
                    }
                    
                    const gapInp = document.getElementById('q'+qid);
                    if(gapInp && gapInp.classList.contains('gap-input')) {
                        gapInp.classList.add('flagged-input');
                        if(gapInp.nextElementSibling && gapInp.nextElementSibling.classList.contains('inline-flag')) {
                            gapInp.nextElementSibling.classList.add('active');
                        }
                    }

                    let target = document.getElementById('q'+qid) 
                              || document.querySelector(`input[name="q${qid}"]`) 
                              || document.querySelector(`input[data-questions~="${qid}"]`)
                              || document.querySelector(`[data-q-start="${qid}"]`);
                    
                    if(target) {
                        const block = target.closest('.tf-question, .multi-choice-question, .short-answer-question, .pick-n-question, .matching-group-block, .flow-question-block, .map-question-block');
                        if(block && !block.classList.contains('flagged')) { block.classList.add('flagged'); }
                    }
                });
            }
            
            if(isSubmitted) checkAnswers(true); 
        } catch(e) { console.error("Restore failed", e); }
    }

    document.addEventListener('input', saveState);
    document.addEventListener('change', function(e) {
        if(e.target.classList.contains('multi-checkbox')) {
            updatePickNStates();
        }
        saveState();
    });

    function checkAnswers(restoring=false, auto=false, bypassNameCheck=false, userConfirmed=false) {
        try {
            const correctAnswers = JSON.parse(atob(encodedKey));

            let nameInput = document.getElementById('studentName');
            let name = nameInput ? nameInput.value.trim() : "";

            if(!restoring && !bypassNameCheck) {
                if (!name) {
                    if (auto) {
                        document.getElementById('lockdownOverlay').style.display = 'flex';
                        document.getElementById('lockdownName').focus();
                        document.querySelectorAll('input, select, .map-drop-zone, .custom-select-wrapper').forEach(el => { 
                            if(el.id !== 'lockdownName' && el.id !== 'studentName' && el.id !== 'modernModalInput') {
                                if(el.classList.contains('custom-select-wrapper') || el.classList.contains('map-drop-zone')) { el.style.pointerEvents = 'none'; }
                                else { el.disabled = true; }
                            }
                        });
                        return;
                    } else {
                        showCustomAlert("Please enter your name at the top of the page before submitting.");
                        triggerNameWarning();
                        return;
                    }
                }
                
                // --- UNANSWERED QUESTIONS WARNING ---
                if (!auto && !userConfirmed) {
                    let unanswered = [];
                    for (const [qId, correctRaw] of Object.entries(correctAnswers)) {
                        let answered = false;
                        let elById = document.getElementById('q' + qId);
                        
                        if (elById && (elById.type === 'hidden' || elById.type === 'text' || elById.type === 'number' || elById.tagName === 'SELECT')) {
                            if (elById.value && elById.value.trim() !== '') answered = true;
                        } else {
                            const multiBoxes = document.querySelectorAll('input[type="checkbox"][data-questions~="' + qId + '"]');
                            if(multiBoxes.length > 0) {
                                if(Array.from(multiBoxes).some(cb => cb.checked)) answered = true;
                            } else {
                                if(document.querySelector('input[name="q' + qId + '"]:checked')) answered = true;
                            }
                        }
                        if (!answered) unanswered.push(qId);
                    }

                    if (unanswered.length > 0) {
                        let msg = "Wait! You have <b>" + unanswered.length + "</b> unanswered question(s):<br><br>" + 
                                  "<span style='color:#e74c3c; font-weight:bold; font-size:18px;'>Q" + unanswered.slice(0, 5).join(', Q') + (unanswered.length > 5 ? "..." : "") + "</span><br><br>" + 
                                  "Are you sure you want to submit?";
                        showModernModal("Incomplete Test", msg, "confirm", function() {
                            checkAnswers(false, false, true, true);
                        });
                        return;
                    } else {
                        showModernModal("Submit Test", "All questions answered!<br>Ready to check your score?", "confirm", function() {
                            checkAnswers(false, false, true, true);
                        });
                        return;
                    }
                }
            }

            if(!restoring) { isSubmitted = true; saveState(); }
            let score = 0; let total = 0;
            
            document.querySelectorAll('input, select').forEach(el => { 
                if(el.id !== 'lockdownName' && el.id !== 'studentName' && el.id !== 'modernModalInput') el.disabled = true;
            });
            document.querySelectorAll('.map-drop-zone, .custom-select-wrapper').forEach(el => { el.style.pointerEvents = 'none'; });
            document.querySelectorAll('.correct-ans-marker, .correct-ans-markers-list').forEach(el => el.remove());
            
            if(document.getElementById('studentName')) document.getElementById('studentName').readOnly = true;

            for (const [qId, correctRaw] of Object.entries(correctAnswers)) {
                total++;
                let correctVariants = [];
                if (Array.isArray(correctRaw)) {
                    correctVariants = correctRaw.map(c => String(c).trim().toUpperCase());
                } else if (typeof correctRaw === 'string' && correctRaw.includes('|')) {
                    correctVariants = correctRaw.split('|').map(c => c.trim().toUpperCase());
                } else {
                    correctVariants = [String(correctRaw).trim().toUpperCase()];
                }

                let isCorrect = false; 
                let container = null; 
                let elById = document.getElementById('q'+qId);
                let userVal = "";

                if (elById && (elById.type === 'hidden' || elById.type === 'text' || elById.type === 'number' || elById.tagName === 'SELECT')) {
                    userVal = elById.value?.trim().toUpperCase() || ""; 
                    
                    let visualTarget = elById;
                    if (elById.type === 'hidden' && elById.closest('.map-drop-zone')) {
                        visualTarget = elById.closest('.map-drop-zone');
                    } else if (elById.type === 'hidden' && elById.closest('.custom-select-wrapper')) {
                        visualTarget = elById.closest('.custom-select-wrapper').querySelector('.custom-select-trigger');
                    }

                    if (correctVariants.includes(userVal)) { 
                        isCorrect = true; 
                        visualTarget.classList.add('correct'); 
                    } else { 
                        visualTarget.classList.add('incorrect'); 
                    }
                } else {
                    const multiBoxes = document.querySelectorAll(`input[type="checkbox"][data-questions~="${qId}"]`);
                    if(multiBoxes.length > 0) {
                        container = multiBoxes[0].closest('.pick-n-question');
                        const checkedVals = Array.from(multiBoxes).filter(cb => cb.checked).map(cb => cb.value.toUpperCase());
                        userVal = checkedVals.length > 0 ? checkedVals.join(", ") : "";
                        if(checkedVals.some(v => correctVariants.includes(v))) {
                            isCorrect = true;
                            const correctBox = Array.from(multiBoxes).find(cb => correctVariants.includes(cb.value.toUpperCase()));
                            if(correctBox) correctBox.closest('.modern-label').classList.add('correct');
                        }
                    } else {
                        const radios = document.querySelectorAll(`input[name="q${qId}"]`);
                        if (radios.length > 0) {
                            container = radios[0].closest('.tf-question, .multi-choice-question, .match-item'); 
                            const checked = document.querySelector(`input[name="q${qId}"]:checked`);
                            if (checked) {
                                userVal = checked.value.toUpperCase();
                                if (correctVariants.includes(userVal)) { isCorrect = true; checked.closest('.modern-label').classList.add('correct'); }
                                else { checked.closest('.modern-label').classList.add('incorrect'); }
                            }
                        }
                    }
                }

                if (isCorrect) score++;

                if (!isCorrect) {
                    let displayCorrect = '';
                    if (Array.isArray(correctRaw)) displayCorrect = correctRaw.join(' / ');
                    else if (typeof correctRaw === 'string' && correctRaw.includes('|')) displayCorrect = correctRaw.split('|').map(s => s.trim()).join(' / ');
                    else displayCorrect = String(correctRaw);
                    
                    const text = '✓ ' + displayCorrect;

                    if (elById) {
                        let targetNode = elById;
                        if(elById.type === 'hidden' && elById.closest('.map-drop-zone')) {
                            targetNode = elById.closest('.map-drop-zone');
                        } else if(elById.type === 'hidden' && elById.closest('.custom-select-wrapper')) {
                            targetNode = elById.closest('.custom-select-wrapper');
                        }
                        
                        const marker = document.createElement('span'); 
                        marker.className = 'correct-ans-marker';
                        marker.style.color = '#27ae60'; 
                        marker.style.fontWeight = 'bold'; 
                        marker.style.marginLeft = '12px'; 
                        marker.style.display = 'inline-block';
                        marker.innerText = text;
                        if(targetNode.nextSibling) {
                            targetNode.parentNode.insertBefore(marker, targetNode.nextSibling);
                        } else {
                            targetNode.parentNode.appendChild(marker);
                        }
                    } else if (container) {
                        let existing = container.querySelector('.correct-ans-markers-list');
                        if (!existing) {
                            existing = document.createElement('div');
                            existing.className = 'correct-ans-markers-list';
                            existing.style.marginTop = '10px';
                            existing.style.padding = '10px';
                            existing.style.backgroundColor = '#e8f5e9';
                            existing.style.border = '1px solid #c3e6cb';
                            existing.style.borderRadius = '8px';
                            existing.style.color = '#2c3e50'; 
                            existing.style.fontSize = '14px';
                            container.appendChild(existing);
                        }
                        
                        const item = document.createElement('div');
                        item.innerHTML = "<span style='color:#27ae60; font-weight:bold'>✓ " + displayCorrect + "</span>";
                        item.style.marginBottom = '4px';
                        existing.appendChild(item);
                    }
                }
            }
            const band = calculateBand(score);
            if(!restoring) {
                if(document.getElementById('modalTitle').innerText !== "Time's Up!") {
                    if(auto) document.getElementById('modalTitle').innerText = "Time's Up!";
                    else document.getElementById('modalTitle').innerText = "Test Completed";
                }
                document.getElementById('scoreValue').innerText = score + "/" + total;
                document.getElementById('bandValue').innerText = "Band: " + band;
                document.getElementById('resultModal').style.display = 'flex';
                localStorage.removeItem(AUDIO_KEY);
            }
        } catch(err) { showModernModal("Grading Error", err.message, "alert"); }
    }
    
    function calculateBand(score) {
        if (score >= 39) return "9.0"; if (score >= 37) return "8.5"; if (score >= 35) return "8.0";
        if (score >= 32) return "7.5"; if (score >= 30) return "7.0"; if (score >= 26) return "6.5";
        if (score >= 23) return "6.0"; if (score >= 18) return "5.5"; if (score >= 16) return "5.0";
        if (score >= 13) return "4.5"; return "4.0";
    }

    function switchPart(num) {
        currentPart = num;
        [1,2,3,4].forEach(i => { document.getElementById('panel_q'+i).classList.add('hidden'); });
        document.querySelectorAll('.part-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('panel_q'+num).classList.remove('hidden');
        document.querySelectorAll('.part-btn')[num-1].classList.add('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
        renderSubNav(num);
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            const active = document.activeElement;
            if (active && active.tagName === 'INPUT' && active.type !== 'hidden') {
                e.preventDefault();
                
                const visibleInputs = Array.from(document.querySelectorAll('input:not([type="hidden"])')).filter(el => {
                    return el.offsetParent !== null; 
                });
                
                const index = visibleInputs.indexOf(active);
                if (index > -1 && index < visibleInputs.length - 1) {
                    const nextInput = visibleInputs[index + 1];
                    nextInput.focus();
                    nextInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }
        }
    });

    document.addEventListener('click', function(e) {
        const variantPopup = document.getElementById('variantPopup');
        if (variantPopup && e.target.id !== 'variantPopup' && !e.target.classList.contains('map-drop-zone') && !variantPopup.contains(e.target)) {
            variantPopup.style.display = '';
            variantPopup.classList.remove('active-popup');
        }

        if (!e.target.closest('.custom-select-wrapper')) {
            document.querySelectorAll('.custom-select-wrapper').forEach(w => {
                w.classList.remove('open');
                w.style.zIndex = '1';
                const mi = w.closest('.match-item');
                if(mi) mi.style.zIndex = '1';
            });
        }
    });
})();
</script>
</body>
</html>
