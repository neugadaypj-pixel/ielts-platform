<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Performance Analysis</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: "Segoe UI", "Trebuchet MS", sans-serif;
            min-height: 100vh;
            color: #1f2937;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            padding: 24px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        .header {
            padding: 30px;
            border-radius: 24px;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            margin-bottom: 24px;
        }

        .header h1 {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 12px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header p {
            color: #64748b;
            line-height: 1.6;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 18px;
            background: white;
            color: #334155;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            border: 2px solid #e2e8f0;
            margin-bottom: 20px;
            transition: all 0.3s ease;
        }

        .back-btn:hover {
            background: #f8fafc;
            border-color: #667eea;
        }

        .analysis-card {
            padding: 32px;
            border-radius: 24px;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
            margin-bottom: 24px;
        }

        .analysis-content {
            line-height: 1.9;
            color: #475569;
            white-space: pre-wrap;
            font-size: 1rem;
        }

        .test-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .info-box {
            padding: 16px;
            background: #f8fafc;
            border-radius: 12px;
            border-left: 4px solid #667eea;
        }

        .info-box strong {
            display: block;
            font-size: 1.5rem;
            color: #667eea;
            margin-bottom: 4px;
        }

        .info-box span {
            color: #64748b;
            font-size: 0.9rem;
        }

        .no-analysis {
            padding: 40px;
            text-align: center;
            color: #64748b;
            background: #f8fafc;
            border-radius: 16px;
            border: 2px dashed #cbd5e1;
        }

        .no-analysis h2 {
            font-size: 1.5rem;
            margin-bottom: 12px;
            color: #475569;
        }

        /* Dark Mode */
        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: #e2e8f0;
        }

        body.dark-mode .header,
        body.dark-mode .analysis-card {
            background: rgba(30, 41, 59, 0.95);
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.3);
        }

        body.dark-mode .header h1 {
            background: linear-gradient(135deg, #a5f4fc 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        body.dark-mode .header p,
        body.dark-mode .analysis-content {
            color: #cbd5e1;
        }

        body.dark-mode .info-box {
            background: rgba(15, 23, 42, 0.9);
            border-color: #667eea;
        }

        body.dark-mode .info-box strong {
            color: #a5b4fc;
        }

        body.dark-mode .info-box span {
            color: #94a3b8;
        }

        body.dark-mode .back-btn {
            background: rgba(51, 65, 85, 0.9);
            color: #e2e8f0;
            border-color: #475569;
        }

        body.dark-mode .back-btn:hover {
            background: rgba(71, 85, 105, 0.9);
            border-color: #667eea;
        }

        body.dark-mode .no-analysis {
            background: rgba(15, 23, 42, 0.9);
            border-color: #334155;
            color: #94a3b8;
        }

        body.dark-mode .no-analysis h2 {
            color: #cbd5e1;
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <div class="container">
        <a href="/student-dashboard" class="back-btn">← Back to Dashboard</a>

        <div class="header">
            <h1>🤖 AI Performance Analysis</h1>
            <p>Personalized insights powered by Google Gemini Flash 1.5</p>
        </div>

        <% if (submission && submission.details?.aiAnalysis) { %>
            <div class="test-info">
                <div class="info-box">
                    <strong><%= submission.score %>/<%= submission.totalQuestions %></strong>
                    <span>Your Score</span>
                </div>
                <div class="info-box">
                    <strong><%= submission.percentage %>%</strong>
                    <span>Percentage</span>
                </div>
                <% if (submission.band) { %>
                <div class="info-box">
                    <strong>Band <%= submission.band %></strong>
                    <span>IELTS Band</span>
                </div>
                <% } %>
                <div class="info-box">
                    <strong><%= new Date(submission.lastSubmittedAt).toLocaleDateString() %></strong>
                    <span>Submitted</span>
                </div>
            </div>

            <div class="analysis-card">
                <div class="analysis-content"><%= submission.details.aiAnalysis %></div>
            </div>

            <% if (submission.details.aiAnalyzedAt) { %>
                <p style="text-align:center;color:#64748b;font-size:0.9rem;">
                    Analysis generated on <%= new Date(submission.details.aiAnalyzedAt).toLocaleString() %>
                </p>
            <% } %>
        <% } else { %>
            <div class="no-analysis">
                <h2>🔍 No AI Analysis Available</h2>
                <p>AI analysis is only available for Reading and Listening tests after submission.</p>
                <p style="margin-top:12px;">Complete a test to receive personalized feedback!</p>
            </div>
        <% } %>
    </div>
</body>
</html>
