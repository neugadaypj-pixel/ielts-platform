<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #1f2937;
            padding: 20px;
        }
        
        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .container { max-width: 1400px; margin: 0 auto; }
        
        .header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: 24px;
            margin-bottom: 32px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        h1 {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
        }
        
        .header-actions { display: flex; gap: 12px; align-items: center; }
        
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        }
        
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(102, 126, 234, 0.4); }
        
        .btn-success {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
        }
        
        .btn-success:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(16, 185, 129, 0.4); }
        
        .btn-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            padding: 8px 16px;
            font-size: 0.85rem;
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.3);
        }
        
        .btn-danger:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(239, 68, 68, 0.4); }
        
        .logout-link {
            color: #ef4444;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }
        
        .logout-link:hover { transform: translateX(-4px); }
        
        .section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: 24px;
            margin-bottom: 32px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            animation: slideUp 0.6s ease-out;
        }
        
        h2 {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 24px;
            padding-bottom: 12px;
            border-bottom: 3px solid #667eea;
            display: inline-block;
        }
        
        .form-row { display: grid; grid-template-columns: 1fr 1fr auto; gap: 12px; margin-bottom: 16px; }
        
        select, input[type="text"] {
            padding: 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            font-family: inherit;
            background: white;
        }
        
        select:focus, input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        
        th {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.05) 100%);
            padding: 16px;
            text-align: left;
            font-weight: 700;
            color: #374151;
            border-bottom: 2px solid #e5e7eb;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        td {
            padding: 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #6b7280;
        }
        
        tr:hover { background: rgba(102, 126, 234, 0.02); }
        
        .action-cell { display: flex; gap: 8px; }
        
        .empty-state {
            text-align: center;
            padding: 40px;
            color: #9ca3af;
        }
        
        .empty-state svg {
            font-size: 3rem;
            margin-bottom: 16px;
        }
    </style>
    <script>
        function deleteItem(type, id, name) {
            if (!confirm(`Are you sure you want to delete ${type} "${name}"? This cannot be undone.`)) {
                return;
            }
            
            fetch(`/delete-${type}/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ redirect: '/admin' })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    window.location.href = '/admin';
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(err => alert('Error: ' + err.message));
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🛡️ Admin Control Center</h1>
            <div class="header-actions">
                <a href="/create-test" class="btn btn-primary">+ Create Test</a>
                <a href="/admin/add-teacher" class="btn btn-success">+ Add Teacher</a>
                <a href="/logout" class="logout-link">Logout →</a>
            </div>
        </div>

        <div class="section">
            <h2>Assign Tests to Teachers</h2>
            <form action="/admin/assign-test" method="POST">
                <div class="form-row">
                    <select name="testId" required>
                        <option value="">Select a Test</option>
                        <% tests.forEach(test => { %>
                            <option value="<%= test._id %>"><%= test.title %></option>
                        <% }) %>
                    </select>
                    <select name="teacherId" required>
                        <option value="">Select a Teacher</option>
                        <% teachers.forEach(teacher => { %>
                            <option value="<%= teacher._id %>"><%= teacher.username %></option>
                        <% }) %>
                    </select>
                    <button type="submit" class="btn btn-primary">Grant Access</button>
                </div>
            </form>
        </div>

        <div class="section">
            <h2>📝 Existing Tests</h2>
            <% if(tests.length === 0) { %>
                <div class="empty-state">
                    <div style="font-size: 2rem;">📭</div>
                    <p>No tests created yet. <a href="/create-test" style="color: #667eea; font-weight: 700;">Create one now</a></p>
                </div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Type</th>
                            <th>Created By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tests.forEach(test => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= test.title %></td>
                                <td><span style="background: #667eea; color: white; padding: 4px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 700;"><%= test.type %></span></td>
                                <td><%= test.teacherName %></td>
                                <td class="action-cell">
                                    <button class="btn btn-danger" onclick="deleteItem('test', '<%= test._id %>', '<%= test.title %>')">Delete</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>

        <div class="section">
            <h2>👨‍🏫 Teachers</h2>
            <% if(teachers.length === 0) { %>
                <div class="empty-state">
                    <div style="font-size: 2rem;">👤</div>
                    <p>No teachers added yet. <a href="/admin/add-teacher" style="color: #667eea; font-weight: 700;">Add a teacher</a></p>
                </div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Tests Assigned</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% teachers.forEach(teacher => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= teacher.username %></td>
                                <td><span style="background: #10b981; color: white; padding: 4px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 700;"><%= teacher.assignedTests ? teacher.assignedTests.length : 0 %> tests</span></td>
                                <td class="action-cell">
                                    <button class="btn btn-danger" onclick="deleteItem('teacher', '<%= teacher._id %>', '<%= teacher.username %>')">Delete</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</body>
</html>
