<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Performance Analysis</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           AI FEEDBACK — analysis display page
           ============================================================ */
        body { padding: var(--space-lg); }

        .ai-feedback-container { max-width: 900px; margin: 0 auto; }

        .analysis-card {
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-lg);
            padding: var(--space-xl);
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(255,255,255,0.12);
            margin-bottom: var(--space-lg);
        }

        .analysis-content {
            line-height: 1.9;
            color: var(--text-secondary);
            white-space: pre-wrap;
            font-size: 1rem;
        }

        .test-info {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: var(--space-md);
            margin-bottom: var(--space-lg);
        }

        .info-box {
            padding: var(--space-md);
            background: var(--gray-50);
            border-radius: var(--radius-md);
            border-left: 4px solid var(--primary-500);
        }
        .info-box strong {
            display: block;
            font-size: 1.4rem;
            color: var(--primary-600);
            margin-bottom: 4px;
            font-weight: 800;
        }
        .info-box span { color: var(--text-muted); font-size: 0.85rem; }

        .no-analysis {
            padding: var(--space-2xl);
            text-align: center;
            color: var(--text-muted);
            background: var(--surface-glass);
            border-radius: var(--radius-lg);
            border: 2px dashed var(--border);
        }
        .no-analysis h2 { font-size: 1.3rem; margin-bottom: var(--space-sm); color: var(--text-secondary); }

        .analysis-meta {
            text-align: center;
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: var(--space-md);
        }

        body.dark-mode .info-box { background: var(--gray-800); }
        body.dark-mode .info-box strong { color: var(--primary-300); }

        @media (max-width: 600px) {
            .test-info { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <div class="ai-feedback-container">
        <a href="/student-dashboard" class="btn btn-ghost btn-sm" style="margin-bottom:var(--space-lg);">← Back to Dashboard</a>

        <div class="analysis-card">
            <h1 class="page-title" style="background:linear-gradient(135deg, var(--primary-500), var(--primary-600));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">🤖 AI Performance Analysis</h1>
            <p class="page-subtitle">Personalized insights powered by Google Gemini Flash 1.5</p>
        </div>

        <% if (submission && submission.details?.aiAnalysis) { %>
            <div class="test-info">
                <div class="info-box">
                    <strong><%= submission.score %>/<%= submission.totalQuestions %></strong>
                    <span>Your Score</span>
                </div>
                <div class="info-box">
                    <strong><%= submission.percentage %>%</strong>
                    <span>Percentage</span>
                </div>
                <% if (submission.band) { %>
                <div class="info-box">
                    <strong>Band <%= submission.band %></strong>
                    <span>IELTS Band</span>
                </div>
                <% } %>
                <div class="info-box">
                    <strong><%= new Date(submission.lastSubmittedAt).toLocaleDateString() %></strong>
                    <span>Submitted</span>
                </div>
            </div>

            <div class="analysis-card">
                <div class="analysis-content"><%= submission.details.aiAnalysis %></div>
            </div>

            <% if (submission.details.aiAnalyzedAt) { %>
                <p class="analysis-meta">
                    Analysis generated on <%= new Date(submission.details.aiAnalyzedAt).toLocaleString() %>
                </p>
            <% } %>
        <% } else { %>
            <div class="no-analysis">
                <h2>🔍 No AI Analysis Available</h2>
                <p>AI analysis is only available for Reading and Listening tests after submission.</p>
                <p style="margin-top:12px;">Complete a test to receive personalized feedback!</p>
            </div>
        <% } %>
    </div>
    <%- include('partials/notifications') %>
</body>
</html>
