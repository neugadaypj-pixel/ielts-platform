        .check-btn { background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%); color:white; border:1px solid rgba(255,255,255,0.2); padding:12px 30px; border-radius:30px; font-weight:bold; cursor:pointer; transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: 0 8px 20px rgba(39, 174, 96, 0.3); backdrop-filter: blur(5px); }
        .check-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(39, 174, 96, 0.4); }
        .check-btn:active { transform: scale(0.95); }
        
        .admin-btn { background: #e74c3c; color: white; border: none; width: 30px; height: 30px; border-radius: 50%; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: transform 0.2s; }
        .admin-btn:hover { transform: scale(1.1); }

        .hidden { display:none !important; }
        .correct { animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .incorrect { animation: shake 0.4s; }
        
        .modal { display:none; position:fixed; z-index:9999; left:0; top:0; width:100%; height:100%; background-color:rgba(0,0,0,0.4); align-items:center; justify-content:center; backdrop-filter:blur(8px); }
        .modal-content { background-color:rgba(255, 255, 255, 0.95); backdrop-filter: blur(15px); padding:40px; border-radius:25px; width:90%; max-width:500px; text-align:center; box-shadow:0 15px 50px rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.4); animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); transition: background 0.3s, color 0.3s, border-color 0.3s; }
        .score-circle { width:120px; height:120px; border-radius:50%; background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%); color:white; display:flex; align-items:center; justify-content:center; font-size:40px; font-weight:bold; margin:20px auto; box-shadow: 0 10px 25px rgba(44, 62, 80, 0.3); }
        
        /* FLAG STYLES */
        .flag-btn { position: absolute; top: 10px; right: 10px; background: transparent; border: none; font-size: 24px; color: #e0e0e0; cursor: pointer; transition: all 0.2s; z-index: 10; }
        .flag-btn:hover { color: #f39c12; transform: scale(1.1); }
        .flagged .flag-btn { color: #e74c3c; }
        .flagged { border: 1px solid #e74c3c !important; border-left: 6px solid #e74c3c !important; }
        
        .q-flag { cursor: pointer; color: #e0e0e0; font-size: 18px; margin-left: 5px; vertical-align: middle; line-height: 1; user-select: none; transition: transform 0.2s; }
        .q-flag:hover { color: #f39c12; transform: scale(1.2); }
        .q-flag.active { color: #e74c3c; }
        .q-flag.inline-flag { color: #cbd5e1; font-size: 18px; margin-left: 6px; }
        .q-flag.inline-flag:hover { color: #f39c12; }
        .q-flag.inline-flag.active { color: #e74c3c; }
        .gap-input.flagged-input { border-color: #e74c3c !important; box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.15) !important; background-color: #fff9f9 !important; }
        .map-drop-zone.flagged-zone { border-color: #e74c3c; background-color: #fff5f5; }

        /* --- START OVERLAY --- */
        .start-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.85); z-index: 5000; display: flex; flex-direction: column; align-items: center; justify-content: center; backdrop-filter: blur(15px); transition: background 0.3s; }
        .start-btn-big { background: linear-gradient(135deg, #8e44ad 0%, #2c3e50 100%); color: white; border: none; padding: 20px 50px; font-size: 24px; font-weight: bold; border-radius: 50px; cursor: pointer; box-shadow: 0 10px 25px rgba(142, 68, 173, 0.4); transition: all 0.2s; border: 1px solid rgba(255,255,255,0.2); }
        .start-btn-big:hover { transform: translateY(-4px); box-shadow: 0 15px 35px rgba(142, 68, 173, 0.5); }

        /* --- INVISIBLE TABLE STYLES (EXPORTED) --- */
        .invisible-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; border: none !important; background: transparent; }
        .invisible-table td, .invisible-table th { border: none !important; padding: 10px; vertical-align: top; }

        /* --- MODERN TABLE STYLES --- */
        .modern-table-wrapper { width: 100%; overflow-x: auto; margin: 15px 0; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #e1e4e8; background: #fff; }
        .modern-table { width: 100%; border-collapse: collapse; text-align: left; font-size: 15px; }
        .modern-table th, .modern-table td { padding: 12px 15px; border-bottom: 1px solid #e1e4e8; border-right: 1px solid #e1e4e8; vertical-align: top; }
        .modern-table th:last-child, .modern-table td:last-child { border-right: none; }
        .modern-table tr:last-child th, .modern-table tr:last-child td { border-bottom: none; }
        .modern-table thead tr { background-color: #f8f9fa; color: #2c3e50; font-weight: 600; }
        .modern-table tbody tr:nth-child(even) { background-color: #fdfdfd; }
        .modern-table tbody tr:hover { background-color: #f4ecf7; }
        
        /* MODERN FLOW BOX (Pill-shaped ovals, strictly 15px font) */
        .flow-box { padding: 8px 20px; border: 2px solid #e1e4e8; border-radius: 50px; background: #fff; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.02); transition: transform 0.2s, box-shadow 0.2s; min-width: 80px; display: inline-block; vertical-align: middle; margin: 0 auto; line-height: 1.5; font-size: 15px !important; color: #333; }
        .flow-box:hover { border-color: #bdc3c7; box-shadow: 0 6px 15px rgba(0,0,0,0.05); }

        /* --- MODERN CUSTOM MODAL --- */
        .modern-modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); z-index: 20000; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; }
        .modern-modal-overlay.show { display: flex; opacity: 1; }
        .modern-modal-box { background: #fff; border-radius: 20px; padding: 30px; max-width: 400px; width: 90%; text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.2); transform: scale(0.9); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .modern-modal-overlay.show .modern-modal-box { transform: scale(1); }
        .modern-modal-title { font-size: 22px; font-weight: 800; color: #2c3e50; margin-bottom: 15px; }
        .modern-modal-text { font-size: 16px; color: #555; margin-bottom: 25px; line-height: 1.6; }
        .modern-modal-buttons { display: flex; gap: 15px; justify-content: center; }
        .btn-modal { padding: 12px 25px; border-radius: 30px; font-weight: bold; cursor: pointer; border: none; transition: transform 0.2s, box-shadow 0.2s; font-size: 15px; }
        .btn-modal:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(0,0,0,0.1); }
        .btn-modal-cancel { background: #ecf0f1; color: #7f8c8d; }
        .btn-modal-confirm { background: linear-gradient(135deg, #8e44ad 0%, #2c3e50 100%); color: #fff; }
        .modal-input-field { width: 80%; padding: 12px; margin: 0 auto 20px; border: 2px solid #ddd; border-radius: 12px; font-size: 16px; text-align: center; display: none; outline: none; transition: border-color 0.3s; }
        .modal-input-field:focus { border-color: #8e44ad; }
        .dark-mode .modern-modal-box { background: #252525; border: 1px solid #444; }
        .dark-mode .modern-modal-title { color: #fff; }
        .dark-mode .modern-modal-text { color: #ccc; }
        .dark-mode .btn-modal-cancel { background: #333; color: #bbb; }
        .dark-mode .modal-input-field { background: #333; color: #fff; border-color: #555; }

        /* --- DARK MODE STYLES --- */
        body.dark-mode { background: #121212; color: #e0e0e0; }
        .dark-mode .header, .dark-mode .footer { background: rgba(30, 30, 30, 0.95); border-color: #333; color: #e0e0e0; }
        .dark-mode .logo { color: #e0e0e0; }
        .dark-mode .tf-question, .dark-mode .multi-choice-question, .dark-mode .short-answer-question, .dark-mode .gap-fill-text, .dark-mode .pick-n-question, .dark-mode .matching-group-block, .dark-mode .flow-question-block, .dark-mode .map-question-block { background: #252525; border-color: #333; color: #e0e0e0; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
        .dark-mode h2, .dark-mode h3, .dark-mode strong, .dark-mode b, .dark-mode .question-section-header { color: #fff; border-color: #555; }
        .dark-mode .gap-fill-text, .dark-mode .flow-chart-content { color: #d4d4d4; }
        .dark-mode .gap-input, .dark-mode .answer-input { background: #333; color: #fff; border-color: #555; }
        .dark-mode .map-drop-zone { background: #333; border-color: #555; color: #aaa; }
        .dark-mode .map-drop-zone.filled { background: #34495e; color: #fff; border-color: #3498db; }
        .dark-mode .custom-select-trigger { background: #333; color: #fff; border-color: #555; }
        .dark-mode .custom-select-options { background: #2c2c2c; border-color: #444; color: #eee; }
        .dark-mode .custom-option { color: #ccc; }
        .dark-mode .custom-option:hover { background: #444; color: #9b59b6; }
        .dark-mode .custom-cb, .dark-mode .custom-radio { background: #333; border-color: #666; }
        .dark-mode .hidden-cb:checked + .custom-cb, .dark-mode .hidden-cb:checked + .custom-radio { background: #8e44ad; border-color: #8e44ad; }
        .dark-mode .timer { background: #3a1c1c; color: #ff7675; }
        .dark-mode .part-btn { background: #333; color: #aaa; border-color: #555; }
        .dark-mode .part-btn.active { background: linear-gradient(135deg, #8e44ad 0%, #9b59b6 100%); color: #fff; border-color: #9b59b6; }
        .dark-mode .nav-circle { background: #333; color: #aaa; border-color: #555; }
        .dark-mode .nav-circle.answered { background: #8e44ad; color: #fff; border-color: #8e44ad; }
        .dark-mode .modal-content { background-color: rgba(30, 30, 30, 0.95); color: #eee; border-color: #555; }
        .dark-mode .ctx-item:hover { background: #3a3a3a; }
        .dark-mode #contextMenu { background: #252525; border-color: #444; color: #eee; }
        .dark-mode .ctx-header { color: #aaa; }
        .dark-mode .start-overlay { background: rgba(18, 18, 18, 0.95); }
        .dark-mode .start-overlay h1 { color: #e0e0e0 !important; }
        .dark-mode .start-overlay p { color: #aaa !important; }
        .dark-mode .variant-popup { background: rgba(44, 44, 44, 0.95); border-color: #555; color: #eee; }
        .dark-mode .variant-option { color: #eee; }
        .dark-mode .variant-option:hover { background-color: #555; color: #e0b0ff; }
        .dark-mode .match-features-box { background: #333; border-color: #444; }
        .dark-mode .gap-input.flagged-input { background-color: rgba(231, 76, 60, 0.1) !important; }
        .dark-mode .map-drop-zone.flagged-zone { background-color: rgba(231, 76, 60, 0.1); }
        .dark-mode .lockdown-box { background: #252525; border: 1px solid #444; color: #eee; }
        .dark-mode .lockdown-input { background: #333; color: #fff; border-color: #555; }
        .dark-mode .name-input { background: #333; color: #fff; border-color: #555; }
        
        .dark-mode .modern-table-wrapper { background: #252525; border-color: #444; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .dark-mode .modern-table th, .dark-mode .modern-table td { border-color: #444; color: #e0e0e0; }
        .dark-mode .modern-table thead tr { background-color: #2c2c2c; color: #fff; }
        .dark-mode .modern-table tbody tr:nth-child(even) { background-color: #2a2a2a; }
        .dark-mode .modern-table tbody tr:hover { background-color: #333; }
        .dark-mode .flow-box { background: #2a2a2a !important; border-color: #444 !important; color: #e0e0e0 !important; }

        /* --- PASTE FORMATTING FIXES FOR DARK MODE --- */
        .dark-mode .tf-question *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .multi-choice-question *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .short-answer-question *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .gap-fill-text *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .pick-n-question *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .matching-group-block *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .flow-question-block *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .map-question-block *:not(span[style*="background-color"]):not(.correct-ans-marker)[style], 
        .dark-mode .modern-table *:not(span[style*="background-color"]):not(.correct-ans-marker)[style] {
            color: #d4d4d4 !important;
        }
        
        .dark-mode [style*="background-color: white"], .dark-mode [style*="background-color: #fff"], 
        .dark-mode [style*="background-color: #ffffff"], .dark-mode [style*="background-color: rgb(255, 255, 255)"],
        .dark-mode [style*="background: white"], .dark-mode [style*="background: #fff"] {
            background-color: transparent !important;
        }

        /* Enforce dark text on ALL colored highlights so they remain visible */
        body.dark-mode div.main-container span[style*="background-color"] {
            color: #1a1a1a !important;
        }
        
        /* Ensure cleared highlights correctly revert to normal light gray text */
        body.dark-mode div.main-container span[style*="background-color: transparent"],
        body.dark-mode div.main-container span[style*="background-color: rgba(0, 0, 0, 0)"] {
            color: #d4d4d4 !important;
        }

        .dark-mode span[style*="#8e44ad"] { color: #e0b0ff !important; } 
        .dark-mode .correct-ans-marker, .dark-mode .correct-ans-markers-list span { color: #2ecc71 !important; }
    </style>
</head>
<body>
    <div id="customAlert" class="custom-alert"></div>
    <div id="modernModal" class="modern-modal-overlay">
        <div class="modern-modal-box">
            <div id="modernModalTitle" class="modern-modal-title">Attention</div>
            <div id="modernModalText" class="modern-modal-text"></div>
            <input type="password" id="modernModalInput" class="modal-input-field" placeholder="Enter code..." autocomplete="off">
            <div class="modern-modal-buttons">
                <button id="modernModalCancel" class="btn-modal btn-modal-cancel">Cancel</button>
                <button id="modernModalConfirm" class="btn-modal btn-modal-confirm">OK</button>
            </div>
        </div>
    </div>
    <div id="lockdownOverlay" class="lockdown-overlay">
        <div class="lockdown-box">
            <h2 style="color:#e74c3c; margin-top:0;">Time's Up!</h2>
            <p>Please enter your full name to submit your test.</p>
            <input type="text" id="lockdownName" class="lockdown-input" placeholder="Student Name">
            <button class="check-btn" style="width:100%" onclick="submitFromLockdown()">Submit Test & View Results</button>
        </div>
    </div>

    <div id="startOverlay" class="start-overlay">
        <h1 style="color:#2c3e50; margin-bottom: 20px; font-size:3rem;">IELTS Listening Test</h1>
        <p style="color:#7f8c8d; margin-bottom: 40px; font-size: 18px;" id="welcomeMsg">Click below to start the audio and timer.</p>
        <button class="start-btn-big" id="mainStartBtn" onclick="startTest()">Start Test</button>
    </div>

    <div class="header">
        <div class="logo">IELTS Listening Test
            <input type="text" id="studentName" class="name-input" placeholder="Student Name" oninput="saveName(); this.classList.remove('shake-active');">
        </div>
        <div class="header-right" style="display:flex; align-items:center;">
            <button class="theme-btn" data-tooltip="Toggle Dark Mode" onclick="toggleTheme()">🌙</button>
            <button class="help-btn" onclick="showHelp()" title="Help / Instructions">?</button>
            <div class="timer" id="timerDisplay">Wait...</div>
            <a href="https://t.me/SynergyacademyBukhara" target="_blank" class="synergy-logo">
                <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.446 1.394c-.14.18-.357.223-.548.223l.188-2.85 5.18-4.68c.223-.198-.054-.306-.346-.109l-6.4 4.02-2.76-.86c-.6-.188-.612-.6.125-.892l10.782-4.156c.5-.187.943.114.785.832z"/></svg>
                Synergy Academy
            </a>
        </div>
    </div>

    <div style="display:none;">
        <audio id="testAudio" preload="auto" crossOrigin="anonymous"></audio>
    </div>

    <div class="main-container" id="questionsPanel">
        <div id="panel_q1" class="question-set">
            <% if (testData.parts && testData.parts[1]) { %><%- testData.parts[1].finalHtml %><% } else { %><p>No questions mapped for Part 1.</p><% } %>
        </div>
        <div id="panel_q2" class="question-set hidden">
            <% if (testData.parts && testData.parts[2]) { %><%- testData.parts[2].finalHtml %><% } %>
        </div>
        <div id="panel_q3" class="question-set hidden">
            <% if (testData.parts && testData.parts[3]) { %><%- testData.parts[3].finalHtml %><% } %>
        </div>
        <div id="panel_q4" class="question-set hidden">
            <% if (testData.parts && testData.parts[4]) { %><%- testData.parts[4].finalHtml %><% } %>
        </div>
    </div>

    <div id="contextMenu">
        <div class="ctx-header">Highlight</div>
        <div class="color-row">
            <div class="color-btn color-yellow" onclick="performHighlight('#fff176')"></div>
            <div class="color-btn color-green" onclick="performHighlight('#a5d6a7')"></div>
            <div class="color-btn color-pink" onclick="performHighlight('#f48fb1')"></div>
        </div>
        <div class="ctx-item" onclick="clearHighlight()">
            ✕ Clear Highlight
        </div>
