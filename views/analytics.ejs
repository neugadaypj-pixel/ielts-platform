<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           ANALYTICS DASHBOARD — charts + stat cards
           ============================================================ */
        body { padding: var(--space-lg); }

        .analytics-container { max-width: 1400px; margin: 0 auto; }

        .chart-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--space-lg);
        }
        .chart-card {
            padding: var(--space-xl);
            border-radius: var(--radius-lg);
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(255,255,255,0.12);
        }
        .chart-card h2 { font-size: 1.1rem; font-weight: 900; margin-bottom: var(--space-lg); color: var(--text-primary); }
        canvas { max-height: 300px; }

        body.dark-mode .chart-card { background: var(--surface-glass); }

        @media (max-width: 1200px) {
            .chart-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="analytics-container">
        <div class="page-header">
            <div>
                <h1 class="page-title">📊 Analytics Dashboard</h1>
                <p class="page-subtitle">Performance insights and trends across all your students</p>
            </div>
            <a href="/teacher-dashboard" class="btn btn-ghost">← Back</a>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value"><%= submissions.length %></div>
                <div class="stat-label">Total Submissions</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= students.length %></div>
                <div class="stat-label">Active Students</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">
                    <% const scoredSubmissions = submissions.filter(s => Number.isFinite(Number(s.percentage))); %>
                    <% const avgScore = scoredSubmissions.length > 0
                        ? Math.round(scoredSubmissions.reduce((sum, s) => sum + Number(s.percentage), 0) / scoredSubmissions.length)
                        : 0; %>
                    <%= avgScore %>%
                </div>
                <div class="stat-label">Average Score</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= tests.length %></div>
                <div class="stat-label">Tests Created</div>
            </div>
        </div>

        <div class="chart-grid">
            <div class="chart-card">
                <h2>Submissions by Test Type</h2>
                <canvas id="typeChart"></canvas>
            </div>
            <div class="chart-card">
                <h2>Average Scores by Type</h2>
                <canvas id="scoreChart"></canvas>
            </div>
            <div class="chart-card">
                <h2>Submissions Over Time (Last 30 Days)</h2>
                <canvas id="timeChart"></canvas>
            </div>
            <div class="chart-card">
                <h2>Score Distribution</h2>
                <canvas id="distChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        const submissions = <%- JSON.stringify(submissions) %>;

        // Type distribution
        const typeCounts = { reading: 0, listening: 0, writing: 0 };
        submissions.forEach(s => typeCounts[s.type] = (typeCounts[s.type] || 0) + 1);
        new Chart(document.getElementById('typeChart'), {
            type: 'doughnut',
            data: {
                labels: ['Reading', 'Listening', 'Writing'],
                datasets: [{
                    data: [typeCounts.reading, typeCounts.listening, typeCounts.writing],
                    backgroundColor: ['#3b82f6', '#10b981', '#f97316']
                }]
            },
            options: { responsive: true, maintainAspectRatio: true }
        });

        // Average scores by type
        const scoresByType = { reading: [], listening: [], writing: [] };
        submissions.forEach(s => { if (Number.isFinite(Number(s.percentage)) && scoresByType[s.type]) scoresByType[s.type].push(Number(s.percentage)); });
        const avgByType = {
            reading: scoresByType.reading.length ? Math.round(scoresByType.reading.reduce((a,b)=>a+b,0)/scoresByType.reading.length) : 0,
            listening: scoresByType.listening.length ? Math.round(scoresByType.listening.reduce((a,b)=>a+b,0)/scoresByType.listening.length) : 0,
            writing: scoresByType.writing.length ? Math.round(scoresByType.writing.reduce((a,b)=>a+b,0)/scoresByType.writing.length) : 0
        };
        new Chart(document.getElementById('scoreChart'), {
            type: 'bar',
            data: {
                labels: ['Reading', 'Listening', 'Writing'],
                datasets: [{
                    label: 'Average Score (%)',
                    data: [avgByType.reading, avgByType.listening, avgByType.writing],
                    backgroundColor: ['#3b82f6', '#10b981', '#f97316']
                }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true, max: 100 } } }
        });

        // Submissions over time
        const last30Days = Array.from({length: 30}, (_, i) => {
            const d = new Date();
            d.setDate(d.getDate() - (29 - i));
            return d.toISOString().split('T')[0];
        });
        const submissionsByDay = {};
        last30Days.forEach(d => submissionsByDay[d] = 0);
        submissions.forEach(s => {
            const day = new Date(s.createdAt).toISOString().split('T')[0];
            if (submissionsByDay[day] !== undefined) submissionsByDay[day]++;
        });
        new Chart(document.getElementById('timeChart'), {
            type: 'line',
            data: {
                labels: last30Days.map(d => new Date(d).toLocaleDateString('en-US', {month:'short', day:'numeric'})),
                datasets: [{
                    label: 'Submissions',
                    data: last30Days.map(d => submissionsByDay[d]),
                    borderColor: '#667eea',
                    backgroundColor: 'rgba(102,126,234,0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });

        // Score distribution
        const scoreBuckets = { '0-20': 0, '21-40': 0, '41-60': 0, '61-80': 0, '81-100': 0 };
        submissions.forEach(s => {
            const percentage = Number(s.percentage);
            if (!Number.isFinite(percentage)) return;
            if (percentage <= 20) scoreBuckets['0-20']++;
            else if (percentage <= 40) scoreBuckets['21-40']++;
            else if (percentage <= 60) scoreBuckets['41-60']++;
            else if (percentage <= 80) scoreBuckets['61-80']++;
            else scoreBuckets['81-100']++;
        });
        new Chart(document.getElementById('distChart'), {
            type: 'bar',
            data: {
                labels: Object.keys(scoreBuckets),
                datasets: [{
                    label: 'Number of Students',
                    data: Object.values(scoreBuckets),
                    backgroundColor: '#764ba2'
                }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
    <%- include('partials/notifications') %>
</body>
</html>
