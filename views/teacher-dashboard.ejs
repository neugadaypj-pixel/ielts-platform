<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #1f2937;
            min-height: 100vh;
            display: flex;
        }
        
        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
        
        .sidebar {
            width: 280px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 32px 24px;
            box-sizing: border-box;
            box-shadow: 10px 0 40px rgba(0, 0, 0, 0.1);
            animation: slideIn 0.6s ease-out;
        }
        
        .sidebar h2 {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }
        
        .sidebar p {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 32px;
            padding-bottom: 32px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .logout-link {
            color: rgba(255, 255, 255, 0.9);
            text-decoration: none;
            font-weight: 700;
            transition: all 0.3s ease;
            display: inline-block;
        }
        
        .logout-link:hover {
            color: white;
            transform: translateX(-4px);
        }
        
        .main-content {
            flex-grow: 1;
            padding: 40px;
            box-sizing: border-box;
            overflow-y: auto;
        }
        
        h1 {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 32px;
        }
        
        .section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: 24px;
            margin-bottom: 32px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            animation: slideUp 0.6s ease-out;
        }
        
        h2 {
            font-size: 1.4rem;
            font-weight: 800;
            color: #1f2937;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 3px solid #667eea;
            display: inline-block;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 12px;
            align-items: flex-end;
        }
        
        input[type="text"], select {
            padding: 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 0.95rem;
            font-family: inherit;
            background: white;
            transition: all 0.3s ease;
        }
        
        input[type="text"]:focus, select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        }
        
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        }
        
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(102, 126, 234, 0.4); }
        
        .btn-success {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: white;
            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
        }
        
        .btn-success:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(16, 185, 129, 0.4); }
        
        .btn-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            padding: 8px 16px;
            font-size: 0.85rem;
            box-shadow: 0 6px 16px rgba(239, 68, 68, 0.3);
        }
        
        .btn-danger:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(239, 68, 68, 0.4); }
        
        .group-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }
        
        .group-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(102, 126, 234, 0.05) 100%);
            border: 2px solid #e5e7eb;
            border-radius: 16px;
            padding: 24px;
            position: relative;
            transition: all 0.3s ease;
        }
        
        .group-card:hover {
            border-color: #667eea;
            box-shadow: 0 12px 32px rgba(102, 126, 234, 0.15);
            transform: translateY(-4px);
        }
        
        .group-name {
            font-size: 1.2rem;
            font-weight: 800;
            color: #667eea;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .group-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 16px 0;
            padding: 16px 0;
            border-top: 1px solid #e5e7eb;
            border-bottom: 1px solid #e5e7eb;
        }
        
        .stat {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.05) 100%);
            padding: 12px;
            border-radius: 12px;
            text-align: center;
            font-size: 0.9rem;
        }
        
        .stat-value {
            font-weight: 800;
            font-size: 1.4rem;
            color: #667eea;
        }
        
        .stat-label {
            color: #9ca3af;
            font-size: 0.8rem;
            margin-top: 4px;
        }
        
        .group-actions {
            position: absolute;
            top: 16px;
            right: 16px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 24px;
        }
        
        th {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.05) 100%);
            padding: 16px;
            text-align: left;
            font-weight: 700;
            color: #374151;
            border-bottom: 2px solid #e5e7eb;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        td {
            padding: 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #6b7280;
        }
        
        tr:hover { background: rgba(102, 126, 234, 0.02); }
        
        .action-cell { display: flex; gap: 8px; }
        
        .badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 700;
        }
        
        .badge-primary {
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.1) 100%);
            color: #667eea;
        }
        
        .empty-state {
            text-align: center;
            padding: 40px;
            color: #9ca3af;
        }
        
        .empty-state svg {
            font-size: 3rem;
            margin-bottom: 16px;
        }
    </style>
    <script>
        function deleteItem(type, id, name) {
            if (!confirm(`Are you sure you want to delete ${type} "${name}"?`)) return;
            fetch(`/delete-${type}/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ redirect: '/teacher-dashboard' })
            }).then(r => r.json()).then(d => {
                if (d.success) { alert(d.message); location.href = '/teacher-dashboard'; }
                else alert('Error: ' + d.message);
            }).catch(e => alert('Error: ' + e.message));
        }

        function removeStudentFromGroup(groupId, studentId, studentName) {
            if (!confirm(`Remove ${studentName}?`)) return;
            fetch(`/remove-student-from-group/${groupId}/${studentId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ redirect: '/teacher-dashboard' })
            }).then(r => r.json()).then(d => {
                if (d.success) { alert(d.message); location.href = '/teacher-dashboard'; }
                else alert('Error: ' + d.message);
            }).catch(e => alert('Error: ' + e.message));
        }
    </script>
</head>
<body>

    <div class="sidebar">
        <h2>📚 ExamApp</h2>
        <p>Teacher: <strong><%= teacher.username %></strong></p>
        <a href="/logout" class="logout-link">🚪 Logout</a>
    </div>

    <div class="main-content">
        <h1>👨‍🏫 Teacher Management</h1>

        <div class="section">
            <h2>Create New Group</h2>
            <form action="/teacher/create-group" method="POST">
                <div class="form-row">
                    <input type="text" name="groupName" placeholder="e.g., IELTS Morning Batch" required>
                    <button type="submit" class="btn btn-success">+ Create</button>
                </div>
            </form>
        </div>

        <div class="section">
            <h2>Assignment Controls</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
                
                <form action="/teacher/assign-to-group" method="POST">
                    <label style="font-weight: 700; color: #374151; display: block; margin-bottom: 12px;">📌 Add Student to Group</label>
                    <div style="display: grid; gap: 12px;">
                        <select name="studentId" required>
                            <option value="">Select Student</option>
                            <% allStudents.forEach(s => { %>
                                <option value="<%= s._id %>"><%= s.username %></option>
                            <% }) %>
                        </select>
                        <select name="groupId" required>
                            <option value="">Select Group</option>
                            <% groups.forEach(g => { %>
                                <option value="<%= g._id %>"><%= g.name %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-primary">Add Student</button>
                    </div>
                </form>

                <form action="/teacher/assign-test-group" method="POST">
                    <label style="font-weight: 700; color: #374151; display: block; margin-bottom: 12px;">📝 Assign Test to Group</label>
                    <div style="display: grid; gap: 12px;">
                        <select name="testId" required>
                            <option value="">Select Test</option>
                            <% tests.forEach(t => { %>
                                <option value="<%= t._id %>"><%= t.title %></option>
                            <% }) %>
                        </select>
                        <select name="groupId" required>
                            <option value="">Select Group</option>
                            <% groups.forEach(g => { %>
                                <option value="<%= g._id %>"><%= g.name %></option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-primary">Assign Test</button>
                    </div>
                </form>

            </div>
        </div>

        <div class="section">
            <h2>Active Groups</h2>
            <% if (groups.length > 0) { %>
                <div class="group-grid">
                    <% groups.forEach(group => { %>
                        <div class="group-card">
                            <div class="group-actions">
                                <button class="btn btn-danger" onclick="deleteItem('group', '<%= group._id %>', '<%= group.name %>')">Delete</button>
                            </div>
                            <div class="group-name">📌 <%= group.name %></div>
                            <div class="group-stats">
                                <div class="stat">
                                    <div class="stat-value"><%= group.students.length %></div>
                                    <div class="stat-label">Students</div>
                                </div>
                                <div class="stat">
                                    <div class="stat-value"><%= group.assignedTests.length %></div>
                                    <div class="stat-label">Tests</div>
                                </div>
                            </div>
                            <hr style="border: 1px solid #e5e7eb; margin: 16px 0;">
                            <div style="font-size: 0.9rem; margin-bottom: 12px;">
                                <strong style="color: #374151;">Assigned Tests:</strong>
                                <ul style="list-style: none; padding: 8px 0 0 0; margin: 0;">
                                    <% group.assignedTests.forEach(t => { %>
                                        <li style="padding: 4px 0; color: #6b7280;">✓ <%= t.title %></li>
                                    <% }) %>
                                </ul>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div style="font-size: 2rem;">📭</div>
                    <p>No groups yet. Create one above!</p>
                </div>
            <% } %>
        </div>

        <div class="section">
            <h2>All Students</h2>
            <a href="/teacher/add-student" class="btn btn-success">+ Register Student</a>
            <% if (allStudents.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Current Group</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% allStudents.forEach(student => { %>
                            <tr>
                                <td style="font-weight: 600;"><%= student.username %></td>
                                <td>
                                    <% if(student.groupId) { %>
                                        <span class="badge badge-primary"><%= groups.find(g => g._id.toString() == student.groupId.toString())?.name %></span>
                                    <% } else { %>
                                        <span class="badge" style="background: #fee2e2; color: #dc2626;">Unassigned</span>
                                    <% } %>
                                </td>
                                <td class="action-cell">
                                    <button class="btn btn-danger" onclick="deleteItem('student', '<%= student._id %>', '<%= student.username %>')">Delete</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="empty-state" style="margin-top: 20px;">
                    <div style="font-size: 2rem;">👥</div>
                    <p>No students registered. <a href="/teacher/add-student" style="color: #667eea; font-weight: 700;">Register one now</a></p>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>
