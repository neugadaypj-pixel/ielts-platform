<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listening Test</title>
    <%- include('../partials/design-system') %>
    <style>
        body {
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px;
        }
        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
            color: var(--text-primary);
        }
        .container { max-width: 1200px; margin: 0 auto; }
        header {
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            padding: 28px 32px;
            border-radius: var(--radius-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            box-shadow: var(--shadow-lg);
            flex-wrap: wrap;
            gap: 16px;
        }
        header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .timer {
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: white;
            padding: 12px 24px;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 1.1rem;
        }
        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }
        .test-section {
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
        }
        .audio-player {
            background: var(--gray-50);
            padding: 24px;
            border-radius: var(--radius-md);
            margin-bottom: 24px;
        }
        audio { width: 100%; border-radius: 8px; }
        .questions { display: flex; flex-direction: column; gap: 28px; }
        .question-item {
            padding: 20px;
            background: var(--gray-50);
            border-radius: var(--radius-md);
            border-left: 4px solid var(--primary-400);
        }
        .question-text { font-weight: 700; color: var(--text-primary); margin-bottom: 16px; }
        .options { display: flex; flex-direction: column; gap: 12px; }
        .option {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: white;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .option:hover { border-color: var(--primary-400); background: var(--primary-50); }
        .option input[type="radio"] { cursor: pointer; width: 18px; height: 18px; accent-color: var(--primary-400); }
        .notes-section { background: var(--gray-50); padding: 24px; border-radius: var(--radius-md); }
        .notes-section h3 { font-size: 1.1rem; font-weight: 800; margin-bottom: 12px; color: var(--text-primary); }
        .test-textarea {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            font-family: inherit;
            font-size: 0.9rem;
            min-height: 120px;
            resize: vertical;
        }
        .test-textarea:focus { outline: none; border-color: var(--primary-400); box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1); }
        footer { display: flex; gap: 16px; justify-content: flex-end; }
        .btn-submit {
            padding: 14px 28px;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: white;
            box-shadow: 0 6px 16px rgba(102, 126, 234, 0.3);
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(102, 126, 234, 0.4); }
        @media (max-width: 1024px) { .content { grid-template-columns: 1fr; } }
        @media (max-width: 768px) {
            header { flex-direction: column; gap: 16px; text-align: center; }
            header h1 { font-size: 1.4rem; }
        }
        body.dark-mode header { background: rgba(30, 41, 59, 0.95) !important; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3) !important; }
        body.dark-mode .test-section { background: rgba(30, 41, 59, 0.95) !important; color: var(--text-primary); }
        body.dark-mode .question-item { background: rgba(30, 41, 59, 0.95) !important; }
        body.dark-mode .audio-player { background: rgba(15, 23, 42, 0.95) !important; }
        body.dark-mode .option { background: rgba(15, 23, 42, 0.95) !important; border-color: #475569 !important; }
        body.dark-mode .test-textarea { background: rgba(15, 23, 42, 0.95) !important; border-color: #475569 !important; color: #e2e8f0 !important; }
        body.dark-mode label { color: #cbd5e1 !important; }
    </style>
    <script src="/time-warning.js"></script>
    <script src="/loading-spinner.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>🎧 Listening Test</h1>
            <div class="timer">⏱️ Time: 00:00</div>
        </header>
        
        <div class="content">
            <div class="test-section">
                <h2 style="margin-bottom: 24px; color: #1f2937;">Listen to the Audio</h2>
                
                <div class="audio-player">
    <audio id="testAudio" controls preload="auto" crossOrigin="anonymous">
        <source src="<%= test.audioUrl %>" type="audio/mpeg">
        Your browser does not support the audio element.
    </audio>
</div>
                
                <div class="questions">
                    <% if(test.questions && test.questions.length > 0) { %>
                        <% test.questions.forEach((q, index) => { %>
                            <div class="question-item">
                                <div class="question-text"><%= q.text %></div>
                                <div class="options">
                                    <% q.options.forEach(opt => { %>
                                        <label class="option">
                                            <input type="radio" name="answer_<%= index %>" value="<%= opt %>">
                                            <span><%= opt %></span>
                                        </label>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
            
            <div class="test-section">
                <div class="notes-section">
                    <h3>📝 Your Notes</h3>
                    <textarea class="test-textarea" placeholder="Write down any notes while listening..."></textarea>
                </div>
            </div>
        </div>
        
        <footer>
            <button class="btn-submit">Submit Test →</button>
        </footer>
    </div>
    <script>
    function createBlobUrl(url) {
        // Only process if it is explicitly a Base64 data URI
        if (typeof url === 'string' && url.startsWith('data:')) {
            try {
                const parts = url.split(',');
                const mime = parts[0].match(/:(.*?);/)[1];
                const bstr = atob(parts[1]);
                let n = bstr.length;
                const u8arr = new Uint8Array(n);
                while (n--) { u8arr[n] = bstr.charCodeAt(n); }
                return URL.createObjectURL(new Blob([u8arr], { type: mime }));
            } catch (error) {
                console.error("Base64 to Blob conversion failed:", error);
                return null;
            }
        }
        // If it's a standard HTTP link or anything else, return it untouched
        return url; 
    }

    const audioEl = document.getElementById('testAudio');
    if (audioEl) {
        const sourceEl = audioEl.querySelector('source');
        const originalSrc = sourceEl ? sourceEl.getAttribute('src') : audioEl.getAttribute('src');
        
        if (originalSrc && originalSrc.startsWith('data:')) {
            const resolved = createBlobUrl(originalSrc);
            if (resolved) {
                audioEl.src = resolved;
                audioEl.load();
            }
        }
    }
</script>
    <%- include('../partials/notifications') %>
</body>
</html>
