    <script>
        function toggleMeta(id) {
            const el = document.getElementById('meta-' + id);
            el.style.display = el.style.display === 'none' ? 'grid' : 'none';
        }

        function saveMeta(id) {
            const customTitle = document.getElementById('title-' + id).value.trim();
            const folder = document.getElementById('folder-' + id).value.trim();
            fetch('/teacher/update-test-meta/' + id, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ customTitle, folder })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) window.location.reload();
                    else alert('Error: ' + data.message);
                })
                .catch(e => alert('Error: ' + e.message));
        }

        function showToast(msg, type = 'success') {
            const t = document.createElement('div');
            t.style.cssText = `position:fixed;bottom:28px;right:28px;z-index:99999;padding:14px 22px;border-radius:16px;font-weight:800;font-size:0.95rem;color:#fff;box-shadow:0 12px 28px rgba(15,23,42,0.18);transition:opacity 0.4s ease;background:${type === 'error' ? 'linear-gradient(135deg,#ef4444,#dc2626)' : 'linear-gradient(135deg,#10b981,#059669)'}`;
            t.textContent = msg;
            document.body.appendChild(t);
            setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 400); }, 3000);
        }

        function showConfirm(message, onConfirm) {
            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(15,23,42,0.45);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;';
            overlay.innerHTML = `<div style="background:white;border-radius:24px;padding:32px;max-width:400px;width:90%;box-shadow:0 24px 48px rgba(15,23,42,0.18);text-align:center;">
                <div style="font-size:2rem;margin-bottom:12px;">⚠️</div>
                <p style="font-weight:800;font-size:1.05rem;color:#1f2937;margin-bottom:24px;line-height:1.5;">${message}</p>
                <div style="display:flex;gap:12px;justify-content:center;">
                    <button id="cfm-cancel" style="padding:12px 24px;border-radius:999px;border:1px solid #dbe3f1;background:white;font-weight:800;cursor:pointer;">Cancel</button>
                    <button id="cfm-ok" style="padding:12px 24px;border-radius:999px;border:none;background:linear-gradient(135deg,#ef4444,#dc2626);color:white;font-weight:800;cursor:pointer;">Delete</button>
                </div>
            </div>`;
            document.body.appendChild(overlay);
            overlay.querySelector('#cfm-cancel').onclick = () => overlay.remove();
            overlay.querySelector('#cfm-ok').onclick = () => { overlay.remove(); onConfirm(); };
        }

        function deleteItem(type, id, name) {
            showConfirm(`Delete ${type} "${name}"? This cannot be undone.`, () => {
                fetch(`/delete-${type}/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ redirect: '/teacher-dashboard' })
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.success) {
                            showToast(data.message);
                            setTimeout(() => { window.location.href = data.redirect || '/teacher-dashboard'; }, 800);
                        } else {
                            showToast('Error: ' + data.message, 'error');
                        }
                    })
                    .catch((error) => showToast('Error: ' + error.message, 'error'));
            });
        }

        function removeStudentFromGroup(groupId, studentId, studentName) {
            showConfirm(`Remove ${studentName} from this group?`, () => {
                fetch(`/remove-student-from-group/${groupId}/${studentId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ redirect: '/teacher-dashboard' })
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.success) {
                            showToast(data.message);
                            setTimeout(() => { window.location.href = data.redirect || '/teacher-dashboard'; }, 800);
                        } else {
                            showToast('Error: ' + data.message, 'error');
                        }
                    })
                    .catch((error) => showToast('Error: ' + error.message, 'error'));
            });
        }

        function removeTestFromGroup(groupId, testId, testTitle) {
            showConfirm(`Remove test "${testTitle}" from this group?`, () => {
                fetch(`/teacher/remove-test-from-group/${groupId}/${testId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ redirect: '/teacher-dashboard' })
                })
                    .then((response) => response.json())
                    .then((data) => {
                        if (data.success) {
                            showToast(data.message);
                            setTimeout(() => { window.location.href = data.redirect || '/teacher-dashboard'; }, 800);
                        } else {
                            showToast('Error: ' + data.message, 'error');
                        }
                    })
                    .catch((error) => showToast('Error: ' + error.message, 'error'));
            });
        }

        function initModernSelect(selectEl) {
            if (!selectEl || selectEl.dataset.msReady === 'true') return;
            selectEl.dataset.msReady = 'true';

            const wrap = document.createElement('div');
            wrap.className = 'ms-select-wrap';

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'ms-button';

            const panel = document.createElement('div');
            panel.className = 'ms-panel';

            const search = document.createElement('input');
            search.type = 'text';
            search.className = 'ms-search';
            search.placeholder = 'Search...';

            const options = document.createElement('div');
            options.className = 'ms-options';

            function getOptionLabel(opt) {
                return (opt && opt.textContent ? opt.textContent : '').trim();
            }

            function syncButtonLabel() {
                const selected = selectEl.options[selectEl.selectedIndex];
                const label = selected && selected.value ? getOptionLabel(selected) : (selectEl.options[0] ? getOptionLabel(selectEl.options[0]) : 'Select');
                button.textContent = label;
            }

            function rebuildOptions(filterText) {
                const needle = String(filterText || '').toLowerCase();
                options.innerHTML = '';

                Array.from(selectEl.options).forEach((opt, idx) => {
                    const label = getOptionLabel(opt);
                    if (needle && !label.toLowerCase().includes(needle)) return;
                    const div = document.createElement('div');
                    div.className = 'ms-option' + (opt.selected ? ' selected' : '');
                    div.textContent = label;
                    div.addEventListener('click', () => {
                        selectEl.value = opt.value;
                        selectEl.dispatchEvent(new Event('change', { bubbles: true }));
                        panel.classList.remove('open');
                    });
                    options.appendChild(div);
                });

                if (!options.childElementCount) {
                    const empty = document.createElement('div');
                    empty.className = 'ms-option';
                    empty.style.cursor = 'default';
                    empty.style.opacity = '0.7';
                    empty.textContent = 'No matches';
                    options.appendChild(empty);
                }
            }

            button.addEventListener('click', () => {
                const isOpen = panel.classList.toggle('open');
                if (isOpen) {
                    search.value = '';
                    rebuildOptions('');
                    setTimeout(() => search.focus(), 0);
                }
            });

            selectEl.addEventListener('change', () => {
                syncButtonLabel();
                rebuildOptions(search.value);
            });

            search.addEventListener('input', () => rebuildOptions(search.value));

            document.addEventListener('click', (event) => {
                if (!wrap.contains(event.target)) {
                    panel.classList.remove('open');
                }
            });

            panel.appendChild(search);
            panel.appendChild(options);

            selectEl.parentNode.insertBefore(wrap, selectEl);
            wrap.appendChild(button);
            wrap.appendChild(panel);
            wrap.appendChild(selectEl);
            selectEl.style.display = 'none';

            syncButtonLabel();
            rebuildOptions('');
        }

        window.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('select').forEach((el) => {
                initModernSelect(el);
            });
        });

        function filterTests() {
            const query = document.getElementById('searchTests').value.toLowerCase();
            const type = document.getElementById('filterType').value;
            document.querySelectorAll('.test-card').forEach(card => {
                const title = card.querySelector('h4').textContent.toLowerCase();
                const cardType = card.closest('.library-column').classList.contains('type-reading') ? 'reading' :
                    card.closest('.library-column').classList.contains('type-listening') ? 'listening' : 'writing';
                const matchQuery = !query || title.includes(query);
                const matchType = !type || cardType === type;
                card.style.display = matchQuery && matchType ? 'block' : 'none';
            });
        }

        async function viewPassword(studentId, studentName) {
            try {
                const res = await fetch(`/teacher/view-password/${studentId}`);
                const data = await res.json();

                if (data.hasPassword && data.password) {
                    const overlay = document.createElement('div');
                    overlay.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(15,23,42,0.45);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;';
                    overlay.innerHTML = `<div style="background:white;border-radius:24px;padding:32px;max-width:400px;width:90%;box-shadow:0 24px 48px rgba(15,23,42,0.18);text-align:center;">
                        <div style="font-size:2rem;margin-bottom:12px;">🔑</div>
                        <p style="font-weight:800;font-size:1.05rem;margin-bottom:12px;">Password for ${studentName}</p>
                        <p style="font-size:1.5rem;font-weight:900;color:#667eea;margin-bottom:24px;font-family:monospace;">${data.password}</p>
                        <button onclick="this.closest('div').parentElement.remove()" style="padding:12px 24px;border-radius:999px;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-weight:800;cursor:pointer;">Close</button>
                    </div>`;
                    document.body.appendChild(overlay);
                } else {
                    const overlay = document.createElement('div');
                    overlay.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(15,23,42,0.45);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;';
                    overlay.innerHTML = `<div style="background:white;border-radius:24px;padding:32px;max-width:400px;width:90%;box-shadow:0 24px 48px rgba(15,23,42,0.18);text-align:center;">
                        <div style="font-size:2rem;margin-bottom:12px;">⚠️</div>
                        <p style="font-weight:800;font-size:1.05rem;margin-bottom:12px;">Password Not Available</p>
                        <p style="margin-bottom:24px;line-height:1.5;">This student was created before password storage was enabled. Reset their password to set a new one.</p>
                        <div style="display:flex;gap:12px;justify-content:center;">
                            <button onclick="this.closest('div').parentElement.remove()" style="padding:12px 24px;border-radius:999px;border:1px solid #dbe3f1;background:white;font-weight:800;cursor:pointer;">Cancel</button>
                            <button onclick="resetPassword('${studentId}', '${studentName}')" style="padding:12px 24px;border-radius:999px;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-weight:800;cursor:pointer;">Reset Password</button>
                        </div>
                    </div>`;
                    document.body.appendChild(overlay);
                }
            } catch (err) {
                showToast('Error fetching password', 'error');
            }
        }

        async function resetPassword(studentId, studentName) {
            document.querySelectorAll('body > div[style*="position:fixed"]').forEach(el => el.remove());

            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(15,23,42,0.45);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;';
            overlay.innerHTML = `<div style="background:white;border-radius:24px;padding:32px;max-width:400px;width:90%;box-shadow:0 24px 48px rgba(15,23,42,0.18);">
                <h3 style="font-size:1.2rem;font-weight:900;margin-bottom:12px;">Reset Password for ${studentName}</h3>
                <input type="text" id="newPasswordInput" placeholder="Enter new password (min 6 chars)" style="width:100%;padding:12px;border-radius:12px;border:2px solid #e2e8f0;font-size:1rem;margin-bottom:16px;">
                <div style="display:flex;gap:12px;">
                    <button onclick="this.closest('div').parentElement.remove()" style="flex:1;padding:12px;border-radius:999px;border:1px solid #dbe3f1;background:white;font-weight:800;cursor:pointer;">Cancel</button>
                    <button onclick="confirmReset('${studentId}', '${studentName}')" style="flex:1;padding:12px;border-radius:999px;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:white;font-weight:800;cursor:pointer;">Reset</button>
                </div>
            </div>`;
            document.body.appendChild(overlay);
        }

        async function confirmReset(studentId, studentName) {
            const newPassword = document.getElementById('newPasswordInput').value;

            if (!newPassword || newPassword.length < 6) {
                showToast('Password must be at least 6 characters', 'error');
                return;
            }

            try {
                const res = await fetch(`/teacher/reset-password/${studentId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newPassword })
                });

                const data = await res.json();

                if (data.success) {
                    document.querySelectorAll('body > div[style*="position:fixed"]').forEach(el => el.remove());

                    const overlay = document.createElement('div');
                    overlay.style.cssText = 'position:fixed;inset:0;z-index:10000;background:rgba(15,23,42,0.45);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;';
                    overlay.innerHTML = `<div style="background:white;border-radius:24px;padding:32px;max-width:400px;width:90%;box-shadow:0 24px 48px rgba(15,23,42,0.18);text-align:center;">
                        <div style="font-size:2rem;margin-bottom:12px;">✅</div>
                        <p style="font-weight:800;font-size:1.05rem;margin-bottom:12px;">Password Reset Successfully</p>
                        <p style="margin-bottom:12px;">New password for ${studentName}:</p>
                        <p style="font-size:1.5rem;font-weight:900;color:#667eea;margin-bottom:24px;font-family:monospace;">${data.password}</p>
                        <button onclick="this.closest('div').parentElement.remove()" style="padding:12px 24px;border-radius:999px;border:none;background:linear-gradient(135deg,#10b981,#059669);color:white;font-weight:800;cursor:pointer;">Done</button>
                    </div>`;
                    document.body.appendChild(overlay);
                } else {
                    showToast(data.message, 'error');
                }
            } catch (err) {
                showToast('Error resetting password', 'error');
            }
        }

        function toggleDarkMode() {
            window.toggleDarkMode();
        }
    </script>
    <!-- CSRF Token and Global Fetch Interceptor -->
    <meta name="csrf-token" content="<%= csrfToken %>">
    <script>
        (function () {
            const originalFetch = window.fetch;
            window.fetch = async function (...args) {
                let [resource, config] = args;
                if (config && config.method && ['POST', 'PUT', 'DELETE', 'PATCH'].includes(config.method.toUpperCase())) {
                    const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
                    config.headers = {
                        ...config.headers,
                        'CSRF-Token': token
                    };
                }
                return originalFetch(resource, config);
            };
        })();
    </script>
