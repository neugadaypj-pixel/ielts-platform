<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Study Coach</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           AI CHAT — full-height chat layout with sidebar
           ============================================================ */
        body {
            height: 100vh;
            overflow: hidden;
            background: linear-gradient(135deg, var(--gray-50) 0%, var(--gray-200) 100%);
        }

        .chat-app {
            display: flex;
            flex-direction: column;
            height: 100vh;
            max-width: 1400px;
            margin: 0 auto;
            padding: var(--space-md);
            gap: var(--space-md);
        }

        .chat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: var(--space-lg) var(--space-xl);
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-card);
            flex-shrink: 0;
        }
        .chat-header h1 { font-size: 1.5rem; font-weight: 900; color: var(--text-primary); }

        .main-content {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: var(--space-md);
            flex: 1;
            overflow: hidden;
        }

        .sidebar {
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-lg);
            padding: var(--space-lg);
            box-shadow: var(--shadow-card);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
        }
        .sidebar h3 { font-size: 1rem; font-weight: 900; color: var(--text-primary); }

        .quick-prompts { display: flex; flex-direction: column; gap: var(--space-sm); }

        .prompt-btn {
            padding: var(--space-sm) var(--space-md);
            background: var(--primary-50);
            border: 2px solid var(--primary-200);
            border-radius: var(--radius-md);
            color: var(--primary-800);
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all var(--transition-fast);
            text-align: left;
            font-family: var(--font-sans);
        }
        .prompt-btn:hover {
            background: linear-gradient(135deg, var(--primary-500), var(--primary-600));
            color: #fff;
            border-color: var(--primary-500);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(99, 102, 241, 0.3);
        }

        .stats-box {
            padding: var(--space-md);
            background: var(--gray-50);
            border-radius: var(--radius-md);
            border-left: 4px solid var(--primary-500);
        }
        .stats-box h4 { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: var(--space-sm); }
        .stats-box .stat { display: flex; justify-content: space-between; margin: 6px 0; font-size: 0.82rem; }
        .stats-box .stat strong { color: var(--primary-600); }

        .chat-container {
            display: flex;
            flex-direction: column;
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-card);
            overflow: hidden;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: var(--space-lg);
            display: flex;
            flex-direction: column;
            gap: var(--space-md);
        }

        .message { display: flex; gap: var(--space-sm); animation: slideIn 0.3s ease; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .message.user { flex-direction: row-reverse; }

        .message-avatar {
            width: 40px; height: 40px;
            border-radius: var(--radius-full);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; flex-shrink: 0;
        }
        .message.ai .message-avatar { background: linear-gradient(135deg, var(--primary-500), var(--primary-600)); }
        .message.user .message-avatar { background: linear-gradient(135deg, var(--success), #059669); }

        .message-content {
            max-width: 70%;
            padding: var(--space-md) var(--space-lg);
            border-radius: var(--radius-md);
            line-height: 1.6;
            white-space: pre-wrap;
            font-size: 0.9rem;
        }
        .message.ai .message-content { background: var(--gray-50); color: var(--text-primary); border: 1px solid var(--border); }
        .message.user .message-content { background: linear-gradient(135deg, var(--primary-500), var(--primary-600)); color: #fff; }

        .typing-indicator {
            display: none;
            padding: var(--space-md) var(--space-lg);
            background: var(--gray-50);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            max-width: 100px;
        }
        .typing-indicator.active { display: block; }
        .typing-indicator span {
            display: inline-block; width: 8px; height: 8px; border-radius: var(--radius-full);
            background: var(--primary-400); margin: 0 2px; animation: typing 1.4s infinite;
        }
        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typing { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-10px); } }

        .chat-input-container {
            padding: var(--space-md) var(--space-lg);
            border-top: 2px solid var(--border);
            background: var(--surface);
        }
        .chat-input-wrapper { display: flex; gap: var(--space-sm); align-items: flex-end; }

        #chatInput {
            flex: 1;
            padding: 14px 18px;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            font-family: var(--font-sans);
            font-size: 0.95rem;
            resize: none;
            max-height: 120px;
            transition: all var(--transition-fast);
            outline: none;
            color: var(--text-primary);
            background: var(--surface);
        }
        #chatInput:focus { border-color: var(--primary-400); box-shadow: var(--shadow-glow); }
        #chatInput::placeholder { color: var(--text-muted); }

        .welcome-message { text-align: center; padding: var(--space-xl) var(--space-lg); color: var(--text-secondary); }
        .welcome-message h2 { font-size: 1.3rem; font-weight: 900; color: var(--text-primary); margin-bottom: var(--space-sm); }

        body.dark-mode { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
        body.dark-mode .stats-box { background: var(--gray-800); }
        body.dark-mode .message.ai .message-content,
        body.dark-mode .typing-indicator { background: var(--gray-800); border-color: var(--border); }
        body.dark-mode #chatInput { background: var(--gray-800); }

        @media (max-width: 1024px) {
            .main-content { grid-template-columns: 1fr; }
            .sidebar { display: none; }
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <div class="chat-app">
        <div class="chat-header">
            <h1>🤖 AI Study Coach</h1>
            <a href="/student-dashboard" class="btn btn-ghost btn-sm">← Back to Dashboard</a>
        </div>

        <div class="main-content">
            <div class="sidebar">
                <h3>💡 Quick Prompts</h3>
                <div class="quick-prompts">
                    <button class="prompt-btn" onclick="sendQuickPrompt('What are my question type weaknesses?')">
                        📊 My Question Type Weaknesses
                    </button>
                    <button class="prompt-btn" onclick="sendQuickPrompt('How can I improve my reading score?')">
                        📈 How to Improve Reading
                    </button>
                    <button class="prompt-btn" onclick="sendQuickPrompt('What are my listening weaknesses?')">
                        🎧 My Listening Weaknesses
                    </button>
                    <button class="prompt-btn" onclick="sendQuickPrompt('Give me a personalized study plan')">
                        📅 Create Study Plan
                    </button>
                    <button class="prompt-btn" onclick="sendQuickPrompt('Analyze my progress over time')">
                        📉 Progress Analysis
                    </button>
                    <button class="prompt-btn" onclick="sendQuickPrompt('What should I focus on next?')">
                        🎯 What to Focus On
                    </button>
                    <button class="prompt-btn" onclick="sendQuickPrompt('Compare my reading vs listening performance')">
                        ⚖️ Compare Skills
                    </button>
                </div>

                <div class="stats-box">
                    <h4>📊 Your Stats</h4>
                    <div class="stat">
                        <span>Total Tests:</span>
                        <strong><%= stats.totalTests %></strong>
                    </div>
                    <div class="stat">
                        <span>Reading Tests:</span>
                        <strong><%= stats.readingTests %></strong>
                    </div>
                    <div class="stat">
                        <span>Listening Tests:</span>
                        <strong><%= stats.listeningTests %></strong>
                    </div>
                    <div class="stat">
                        <span>Writing Tests:</span>
                        <strong><%= stats.writingTests %></strong>
                    </div>
                    <% if (stats.avgScore !== null) { %>
                    <div class="stat">
                        <span>Avg Score:</span>
                        <strong><%= stats.avgScore %>%</strong>
                    </div>
                    <% } %>
                </div>
            </div>

            <div class="chat-container">
                <div class="chat-messages" id="chatMessages">
                    <div class="welcome-message">
                        <h2>👋 Hi <%= studentName %>!</h2>
                        <p>I'm your AI Study Coach powered by DeepSeek V4 Pro.</p>
                        <p>I have access to your last <strong>10 Reading</strong>, <strong>10 Listening</strong>, and <strong>10 Writing</strong> tests and can help you improve!</p>
                        <p style="margin-top: 16px; font-weight: 700; color: var(--primary-500);">
                            Try the quick prompts on the left or ask me anything! 💬
                        </p>
                    </div>
                </div>

                <div class="chat-input-container">
                    <div class="chat-input-wrapper">
                        <textarea
                            id="chatInput"
                            placeholder="Ask me anything about your test performance..."
                            rows="1"
                            onkeydown="handleKeyPress(event)"
                        ></textarea>
                        <button id="sendBtn" class="btn btn-primary" onclick="sendMessage()">Send 🚀</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendBtn');

        // Auto-resize textarea
        chatInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });

        function handleKeyPress(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                sendMessage();
            }
        }

        function sendQuickPrompt(prompt) {
            chatInput.value = prompt;
            sendMessage();
        }

        async function sendMessage() {
            const message = chatInput.value.trim();
            if (!message) return;

            // Disable input
            chatInput.disabled = true;
            sendBtn.disabled = true;

            // Add user message
            addMessage(message, 'user');
            chatInput.value = '';
            chatInput.style.height = 'auto';

            // Show typing indicator
            const typingIndicator = document.createElement('div');
            typingIndicator.className = 'message ai';
            typingIndicator.innerHTML = `
                <div class="message-avatar">🤖</div>
                <div class="typing-indicator active">
                    <span></span><span></span><span></span>
                </div>
            `;
            chatMessages.appendChild(typingIndicator);
            scrollToBottom();

            try {
                const response = await fetch('/api/ai-chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message })
                });

                const data = await response.json();

                // Remove typing indicator
                typingIndicator.remove();

                if (data.success) {
                    addMessage(data.reply, 'ai');
                } else {
                    addMessage('Sorry, I encountered an error. Please try again.', 'ai');
                }
            } catch (error) {
                typingIndicator.remove();
                addMessage('Sorry, I could not connect to the AI. Please try again.', 'ai');
            }

            // Re-enable input
            chatInput.disabled = false;
            sendBtn.disabled = false;
            chatInput.focus();
        }

        function addMessage(text, type) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'message ' + type;

            const avatar = type === 'ai' ? '🤖' : '👤';

            messageDiv.innerHTML = `
                <div class="message-avatar">${avatar}</div>
                <div class="message-content">${escapeHtml(text)}</div>
            `;

            chatMessages.appendChild(messageDiv);
            scrollToBottom();
        }

        function scrollToBottom() {
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Focus input on load
        window.addEventListener('load', () => {
            chatInput.focus();
        });
    </script>
    <%- include('partials/notifications') %>
</body>
</html>
