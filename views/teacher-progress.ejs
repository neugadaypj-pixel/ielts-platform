<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test Progress</title>
    <%- include('../partials/design-system') %>
    <style>
        /* ============================================================
           TEACHER PROGRESS — student submission table + stats
           ============================================================ */
        body { padding: var(--space-lg); }

        .progress-container { max-width: 1280px; margin: 0 auto; }

        .actions { display: flex; flex-wrap: wrap; gap: var(--space-sm); }

        .pill {
            display: inline-flex;
            align-items: center;
            padding: 6px 14px;
            border-radius: var(--radius-full);
            background: var(--primary-100);
            color: var(--primary-800);
            font-size: 0.82rem;
            font-weight: 800;
        }
        body.dark-mode .pill { background: rgba(99, 102, 241, 0.15); color: var(--primary-200); }

        .snippet {
            max-width: 340px;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* AI Modal */
        #aiModal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(4px);
            z-index: 9999;
            overflow: auto;
            animation: fadeIn 0.2s ease-out;
        }
        #aiModal.open { display: block; }
        .ai-modal-content {
            max-width: 900px;
            margin: 50px auto;
            background: var(--surface);
            border-radius: var(--radius-xl);
            padding: var(--space-2xl);
            position: relative;
            box-shadow: var(--shadow-xl);
        }
        .ai-modal-content h2 { font-size: 1.5rem; font-weight: 900; margin-bottom: var(--space-lg); color: var(--text-primary); }
        #aiContent { line-height: 1.8; color: var(--text-secondary); white-space: pre-wrap; font-size: 0.95rem; }

        .group-row { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-bottom: var(--space-md); }

        @media (max-width: 1100px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 760px) {
            body { padding: var(--space-md); }
            .page-header { flex-direction: column; }
        }
    </style>
</head>
<body>
    <div class="progress-container">
        <div class="page-header">
            <div>
                <h1 class="page-title"><%= test.title %></h1>
                <p class="page-subtitle"><strong><%= test.type %></strong> progress for <%= currentUser %>. Preview and download stay tied to the same student-facing renderer.</p>
            </div>
            <div class="actions">
                <a href="/teacher-dashboard" class="btn btn-ghost btn-sm">Back To Dashboard</a>
                <a href="/view-test/<%= test._id %>" target="_blank" class="btn btn-ghost btn-sm">Preview Test</a>
                <a href="/download-test/<%= test._id %>" class="btn btn-primary btn-sm">Download HTML</a>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value"><%= summary.assignedStudents %></div>
                <div class="stat-label">Assigned students across the linked groups</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= summary.completedStudents %></div>
                <div class="stat-label">Students with a saved submission</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= summary.pendingStudents %></div>
                <div class="stat-label">Assigned students who have not submitted yet</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">
                    <% if (summary.averageScore !== null) { %>
                        <%= summary.averageScore.toFixed(1) %>
                    <% } else { %>
                        --
                    <% } %>
                </div>
                <div class="stat-label">
                    <% if (summary.averagePercentage !== null) { %>
                        Average score, <%= summary.averagePercentage %>% overall
                    <% } else { %>
                        Score average is only shown for graded reading/listening attempts
                    <% } %>
                </div>
            </div>
        </div>

        <div class="card">
            <h2 style="font-size:1.3rem;font-weight:900;margin-bottom:var(--space-sm);">Assigned Groups</h2>
            <p style="color:var(--text-muted);margin-bottom:var(--space-md);">The rows below include currently assigned students plus any saved submissions already linked to this test.</p>

            <div class="group-row">
                <% if (groups.length > 0) { %>
                    <% groups.forEach(group => { %>
                        <div class="pill"><%= group.name %> • <%= group.students.length %> students</div>
                    <% }) %>
                <% } else { %>
                    <div class="pill">No active groups currently linked</div>
                <% } %>
            </div>

            <% if (rows.length > 0) { %>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Group</th>
                                <th>Status</th>
                                <th>Result</th>
                                <th>Details</th>
                                <th>Last Saved</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% rows.forEach(row => { const submission = row.submission; %>
                                <tr>
                                    <td>
                                        <div style="font-weight:900;color:var(--text-primary);"><%= row.studentName %></div>
                                        <% if (submission) { %>
                                            <div style="margin-top:4px;color:var(--text-muted);font-size:0.82rem;">Attempts saved: <%= submission.attemptCount %></div>
                                            <a href="/teacher/student-patterns/<%= row.studentId %>" class="btn btn-sm" style="margin-top:6px;background:var(--success);color:#fff;">🔍 View Patterns</a>
                                        <% } %>
                                    </td>
                                    <td><span class="badge"><%= row.groupName || 'Ungrouped' %></span></td>
                                    <td>
                                        <% if (submission) { %>
                                            <span class="badge badge-success">Completed</span>
                                        <% } else { %>
                                            <span class="badge badge-error">Pending</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (submission) { %>
                                            <% if (test.type === 'writing') { %>
                                                Task 1: <strong><%= submission.wordCount1 || 0 %></strong> words<br>
                                                Task 2: <strong><%= submission.wordCount2 || 0 %></strong> words
                                            <% } else { %>
                                                <strong><%= submission.score %>/<%= submission.totalQuestions %></strong>
                                                <% if (submission.band) { %>
                                                    <br>Band <%= submission.band %>
                                                <% } %>
                                                <% if (submission.percentage !== null) { %>
                                                    <br><%= submission.percentage %>%
                                                <% } %>
                                            <% } %>
                                        <% } else { %>
                                            --
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (submission) { %>
                                            <% if (test.type === 'writing') { %>
                                                <div class="snippet">
                                                    T1: <%= (submission.details?.task1Preview || submission.details?.task1 || '').slice(0, 140) || 'No response stored.' %>
                                                </div>
                                                <div class="snippet" style="margin-top:8px;">
                                                    T2: <%= (submission.details?.task2Preview || submission.details?.task2 || '').slice(0, 140) || 'No response stored.' %>
                                                </div>
                                            <% } else { %>
                                                <div class="snippet"><%= submission.details?.summaryText || 'Auto-graded result saved.' %></div>
                                                <% if (submission.details?.aiAnalysis) { %>
                                                    <button onclick="showAIAnalysis('<%= submission._id %>')" class="btn btn-primary btn-sm" style="margin-top:8px;">🤖 View AI Analysis</button>
                                                <% } %>
                                            <% } %>
                                        <% } else { %>
                                            <div class="snippet">No submission has been recorded yet.</div>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (submission) { %>
                                            <%= new Date(submission.lastSubmittedAt).toLocaleString() %>
                                        <% } else { %>
                                            --
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <div class="empty-title">No Submissions Yet</div>
                    <div class="empty-text">No student submissions have been recorded for this test yet.</div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- AI Analysis Modal -->
    <div id="aiModal">
        <div class="ai-modal-content">
            <button onclick="closeAIModal()" class="btn btn-danger" style="position:absolute;top:var(--space-lg);right:var(--space-lg);width:36px;height:36px;border-radius:var(--radius-full);padding:0;font-size:1.3rem;line-height:1;">×</button>
            <h2>🤖 AI Performance Analysis</h2>
            <div id="aiContent"></div>
        </div>
    </div>

    <script>
        const aiAnalysisData = {};
        <% rows.forEach(row => { if (row.submission && row.submission.details?.aiAnalysis) { %>
            aiAnalysisData['<%= row.submission._id %>'] = `<%= row.submission.details.aiAnalysis.replace(/`/g, '\\`').replace(/\n/g, '\\n').replace(/\r/g, '') %>`;
        <% } }) %>

        function showAIAnalysis(submissionId) {
            const analysis = aiAnalysisData[submissionId];
            if (analysis) {
                document.getElementById('aiContent').textContent = analysis;
                document.getElementById('aiModal').classList.add('open');
                document.body.style.overflow = 'hidden';
            }
        }

        function closeAIModal() {
            document.getElementById('aiModal').classList.remove('open');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        document.getElementById('aiModal')?.addEventListener('click', function(e) {
            if (e.target === this) closeAIModal();
        });
    </script>
    <%- include('../partials/notifications') %>
</body>
</html>
