<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reading Test</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        :root {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --text-color: #1f2937;
            --bg-light: #f9fafb;
            --border-color: #e5e7eb;
            --accent-color: #fbbf24;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            color: var(--text-color);
            min-height: 100vh;
            padding: 20px;
            transition: all 0.3s ease;
        }
        
        /* THEME 1: Modern Purple (Default) */
        body.theme-modern {
            --primary-color: #667eea;
            --secondary-color: #764ba2;
            --bg-light: #f9fafb;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        
        /* THEME 2: Minimal Monochrome */
        body.theme-monochrome {
            --primary-color: #1f2937;
            --secondary-color: #111827;
            --bg-light: #f3f4f6;
            background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
        }
        
        /* THEME 3: Ocean Blue */
        body.theme-ocean {
            --primary-color: #0369a1;
            --secondary-color: #0c4a6e;
            --bg-light: #f0f9ff;
            background: linear-gradient(135deg, #06b6d4 0%, #0369a1 100%);
        }
        
        /* THEME 4: Forest Green */
        body.theme-forest {
            --primary-color: #059669;
            --secondary-color: #047857;
            --bg-light: #ecfdf5;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        }
        
        /* THEME 5: Warm Sunset */
        body.theme-sunset {
            --primary-color: #ea580c;
            --secondary-color: #c2410c;
            --bg-light: #fef3c7;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        }
        
        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .container { max-width: 1400px; margin: 0 auto; }
        
        header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 28px 32px;
            border-radius: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            animation: slideUp 0.6s ease-out;
        }
        
        header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .header-controls {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        
        .timer {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            color: white;
            padding: 12px 24px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.1rem;
        }
        
        .theme-selector {
            display: flex;
            gap: 6px;
            align-items: center;
            background: rgba(229, 231, 235, 0.5);
            padding: 8px;
            border-radius: 12px;
        }
        
        .theme-btn {
            width: 32px;
            height: 32px;
            border: 2px solid transparent;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 12px;
        }
        
        .theme-btn:hover {
            transform: scale(1.1);
        }
        
        .theme-btn.active {
            border-color: var(--text-color);
            box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
        }
        
        .theme-modern-btn { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .theme-monochrome-btn { background: linear-gradient(135deg, #6b7280 0%, #1f2937 100%); }
        .theme-ocean-btn { background: linear-gradient(135deg, #06b6d4 0%, #0369a1 100%); }
        .theme-forest-btn { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .theme-sunset-btn { background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); }
        
        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }
        
        .test-section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            animation: slideUp 0.6s ease-out;
        }
        
        .passage {
            background: #f9fafb;
            padding: 28px;
            border-radius: 16px;
            line-height: 1.8;
            margin-bottom: 24px;
            font-size: 1.05rem;
            color: #374151;
            max-height: 400px;
            overflow-y: auto;
        }
        
        .passage::-webkit-scrollbar {
            width: 6px;
        }
        
        .passage::-webkit-scrollbar-track {
            background: #e5e7eb;
            border-radius: 3px;
        }
        
        .passage::-webkit-scrollbar-thumb {
            background: #667eea;
            border-radius: 3px;
        }
        
        .questions {
            display: flex;
            flex-direction: column;
            gap: 28px;
        }
        
        .question-item {
            padding: 20px;
            background: #f9fafb;
            border-radius: 16px;
            border-left: 4px solid #667eea;
        }
        
        .question-text {
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 16px;
        }
        
        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .option {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: white;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .option:hover {
            border-color: #667eea;
            background: #f0f4ff;
        }
        
        .option input[type="radio"] {
            cursor: pointer;
            width: 18px;
            height: 18px;
            accent-color: #667eea;
        }
        
        footer {
            display: flex;
            gap: 16px;
            justify-content: flex-end;
        }
        
        button {
            padding: 14px 28px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-submit {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 6px 16px rgba(102, 126, 234, 0.3);
        }
        
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(102, 126, 234, 0.4);
        }
        
        @media (max-width: 1024px) {
            .content { grid-template-columns: 1fr; }
        }
        
        @media (max-width: 768px) {
            header { flex-direction: column; gap: 16px; text-align: center; }
            header h1 { font-size: 1.4rem; }
        }

        /* Dark Mode Styles */
        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%) !important;
            color: #e2e8f0 !important;
        }

        body.dark-mode header {
            background: rgba(30, 41, 59, 0.95) !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3) !important;
        }

        body.dark-mode header h1 {
            background: linear-gradient(135deg, #a5f4fc 0%, #a5b4fc 100%) !important;
            -webkit-background-clip: text !important;
            -webkit-text-fill-color: transparent !important;
        }

        body.dark-mode .timer {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        }

        body.dark-mode .question-card,
        body.dark-mode .passage-panel {
            background: rgba(30, 41, 59, 0.95) !important;
            border-color: #334155 !important;
            color: #e2e8f0 !important;
        }

        body.dark-mode .question-text,
        body.dark-mode .passage-text {
            color: #cbd5e1 !important;
        }

        body.dark-mode input[type="text"],
        body.dark-mode input[type="radio"],
        body.dark-mode input[type="checkbox"],
        body.dark-mode textarea,
        body.dark-mode select {
            background: rgba(15, 23, 42, 0.95) !important;
            border-color: #475569 !important;
            color: #e2e8f0 !important;
        }

        body.dark-mode input::placeholder,
        body.dark-mode textarea::placeholder {
            color: #64748b !important;
        }

        body.dark-mode label {
            color: #cbd5e1 !important;
        }

        body.dark-mode .btn,
        body.dark-mode button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
            color: white !important;
        }
    </style>
    <script src="/time-warning.js"></script>
    <script src="/loading-spinner.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>📖 Reading Test</h1>
            <div class="timer">⏱️ Time: 00:00</div>
        </header>
        
        <div class="content">
            <div class="test-section">
                <h2 style="margin-bottom: 20px; color: #1f2937;">📄 Reading Passage</h2>
                <div class="passage">
                    <%= test.passage %>
                </div>
            </div>
            
            <div class="test-section">
                <h2 style="margin-bottom: 24px; color: #1f2937;">❓ Questions</h2>
                <div class="questions">
                    <% if(test.questions && test.questions.length > 0) { %>
                        <% test.questions.forEach((q, index) => { %>
                            <div class="question-item">
                                <div class="question-text"><%= q.text %></div>
                                <div class="options">
                                    <% q.options.forEach(opt => { %>
                                        <label class="option">
                                            <input type="radio" name="answer_<%= index %>" value="<%= opt %>">
                                            <span><%= opt %></span>
                                        </label>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
        
        <footer>
            <button class="btn-submit">Submit Test →</button>
        </footer>
    </div>
</body>
</html>
