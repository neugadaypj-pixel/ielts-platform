                                                                    <button class="btn-icon"
                                                                        onclick="toggleMeta('<%= test._id %>')"
                                                                        title="Rename / Move">✏️</button>
                                                                </div>

                                                                <div id="meta-<%= test._id %>" class="meta-edit"
                                                                    style="display:none;">
                                                                    <input type="text" class="meta-input"
                                                                        id="title-<%= test._id %>"
                                                                        value="<%= displayTitle %>"
                                                                        placeholder="Custom name...">
                                                                    <input type="text" class="meta-input"
                                                                        id="folder-<%= test._id %>"
                                                                        value="<%= test.folder || '' %>"
                                                                        placeholder="Folder name...">
                                                                    <button class="btn btn-success"
                                                                        style="padding:8px 14px; font-size:0.85rem;"
                                                                        onclick="saveMeta('<%= test._id %>')">Save</button>
                                                                </div>

                                                                <div class="test-metrics">
                                                                    <div class="metric"><strong>
                                                                            <%= test.assignedGroupCount %>
                                                                        </strong><span>Groups</span></div>
                                                                    <div class="metric"><strong>
                                                                            <%= test.assignedStudentCount %>
                                                                        </strong><span>Students</span></div>
                                                                    <div class="metric"><strong>
                                                                            <%= test.completedStudentCount %>
                                                                        </strong><span>Completed</span></div>
                                                                </div>
                                                                <div class="progress-track">
                                                                    <div class="progress-fill"
                                                                        style="width: <%= completionRate %>%"></div>
                                                                </div>

                                                                <div class="test-actions">
                                                                    <% const canEdit=test.createdBy &&
                                                                        String(test.createdBy)===String(teacher._id); %>
                                                                        <% if (canEdit) { %>
                                                                            <a href="/edit-test/<%= test._id %>"
                                                                                class="btn btn-success">Edit</a>
                                                                            <% } %>
                                                                                <a href="/view-test/<%= test._id %>"
                                                                                    target="_blank"
                                                                                    class="btn btn-secondary">Preview</a>
                                                                                <a href="/download-test/<%= test._id %>"
                                                                                    class="btn btn-secondary">Download</a>
                                                                                <a href="/teacher/progress/<%= test._id %>"
                                                                                    class="btn btn-primary">Progress</a>
                                                                                <a href="/teacher/live/<%= test._id %>"
                                                                                    target="_blank" class="btn"
                                                                                    style="background:linear-gradient(135deg,#ef4444,#dc2626);color:white;box-shadow:0 10px 20px rgba(239,68,68,0.24);">📡
                                                                                    Live</a>
                                                                </div>
                                                            </article>
                                                            <% }) %>
                                                    </div>
                                                </div>
                                                <% }) %>
                                    </div>
                                </div>
                                <% }) %>

                                    <% if (pagination.totalPages> 1) { %>
                                        <div
                                            style="display:flex;align-items:center;justify-content:center;gap:10px;margin-top:24px;flex-wrap:wrap;">
                                            <% if (pagination.page> 1) { %>
                                                <a href="?page=<%= pagination.page - 1 %>" class="btn btn-secondary"
                                                    style="padding:10px 18px;">← Prev</a>
                                                <% } %>
                                                    <span style="font-weight:800;color:#64748b;font-size:0.9rem;">Page
                                                        <%= pagination.page %> of <%= pagination.totalPages %> (<%=
                                                                    pagination.totalTests %> tests)
                                                    </span>
                                                    <% if (pagination.page < pagination.totalPages) { %>
                                                        <a href="?page=<%= pagination.page + 1 %>"
                                                            class="btn btn-secondary" style="padding:10px 18px;">Next
                                                            →</a>
                                                        <% } %>
                                        </div>
                                        <% } %>
                                            <% } %>
            </section>

            <section class="section">
                <div class="section-header">
                    <div>
                        <h2>Group Setup</h2>
                        <p>Create groups, place students, and assign the right tests without leaving the dashboard.</p>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="panel-card">
                        <h3>Create New Group</h3>
                        <form action="/teacher/create-group" method="POST" class="field-stack">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="text" name="groupName" placeholder="e.g. IELTS Evening Group" required>
                            <button type="submit" class="btn btn-success">Create Group</button>
                        </form>
                    </div>

                    <div class="panel-card">
                        <h3>Add Student To Group</h3>
                        <form action="/teacher/assign-to-group" method="POST" class="field-stack">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <select name="studentId" required>
                                <option value="">Select Student</option>
                                <% allStudents.forEach(student=> { %>
                                    <option value="<%= student._id %>">
                                        <%= student.username %>
                                    </option>
                                    <% }) %>
                            </select>
                            <select name="groupId" required>
                                <option value="">Select Group</option>
                                <% groups.forEach(group=> { %>
                                    <option value="<%= group._id %>">
                                        <%= group.name %>
                                    </option>
                                    <% }) %>
                            </select>
                            <button type="submit" class="btn btn-primary">Assign Student</button>
                        </form>
                    </div>

                    <div class="panel-card">
                        <h3>Assign Test To Group</h3>
                        <form action="/teacher/assign-test-group" method="POST" class="field-stack">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <select name="testId" required>
                                <option value="">Select Test</option>
                                <% tests.forEach(test=> { %>
                                    <option value="<%= test._id %>">
                                        <%= test.title %> (<%= test.type %>)
                                    </option>
                                    <% }) %>
                            </select>
                            <select name="groupId" required>
                                <option value="">Select Group</option>
                                <% groups.forEach(group=> { %>
                                    <option value="<%= group._id %>">
                                        <%= group.name %>
                                    </option>
                                    <% }) %>
                            </select>

                            <!-- Modern Schedule Type Selector -->
                            <div style="margin-top: 16px;">
                                <label
                                    style="font-weight: 700; margin-bottom: 12px; display: block; color: #475569;">Access
                                    Type</label>
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                                    <label
                                        style="margin: 0; cursor: pointer; padding: 16px; border-radius: 14px; text-align: center; font-weight: 700; transition: all 0.3s ease; background: white; border: 2px solid #e2e8f0; display: flex; flex-direction: column; align-items: center; gap: 8px;"
                                        id="now-label">
                                        <input type="radio" name="scheduleType" value="now" id="scheduleType" checked
                                            style="display: none;">
                                        <span style="font-size: 1.5rem;">📅</span>
                                        <span style="font-size: 0.9rem;">Available Now</span>
                                    </label>
                                    <label
                                        style="margin: 0; cursor: pointer; padding: 16px; border-radius: 14px; text-align: center; font-weight: 700; transition: all 0.3s ease; background: white; border: 2px solid #e2e8f0; display: flex; flex-direction: column; align-items: center; gap: 8px;"
                                        id="scheduled-label">
                                        <input type="radio" name="scheduleType" value="scheduled"
                                            style="display: none;">
                                        <span style="font-size: 1.5rem;">⏰</span>
                                        <span style="font-size: 0.9rem;">Schedule for Later</span>
                                    </label>
                                </div>
                            </div>

                            <input type="datetime-local" name="availableFrom" id="availableFrom"
                                style="display:none; margin-top: 12px; width: 100%; padding: 14px 16px; border-radius: 14px; border: 2px solid #e2e8f0; background: white; font-size: 0.95rem; font-family: inherit; transition: all 0.2s ease;">
                            <button type="submit" class="btn btn-primary" style="margin-top: 16px;">Assign Test</button>
                        </form>
                    </div>
                    <script>
                        function toggleSchedule() {
                            const radios = document.querySelectorAll('input[name="scheduleType"]');
                            const availableFromInput = document.getElementById('availableFrom');
                            const selectedRadio = document.querySelector('input[name="scheduleType"]:checked');

                            if (!selectedRadio) return;

                            const type = selectedRadio.value;
                            availableFromInput.style.display = type === 'scheduled' ? 'block' : 'none';
                            availableFromInput.required = type === 'scheduled';

                            const nowLabel = document.getElementById('now-label');
                            const scheduledLabel = document.getElementById('scheduled-label');

                            if (type === 'now') {
                                nowLabel.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
                                nowLabel.style.borderColor = '#667eea';
                                nowLabel.style.color = 'white';
                                nowLabel.style.transform = 'scale(1.02)';
                                nowLabel.style.boxShadow = '0 8px 20px rgba(102, 126, 234, 0.3)';
                                scheduledLabel.style.background = 'white';
                                scheduledLabel.style.borderColor = '#e2e8f0';
                                scheduledLabel.style.color = '#64748b';
                                scheduledLabel.style.transform = 'scale(1)';
                                scheduledLabel.style.boxShadow = 'none';
                            } else {
                                scheduledLabel.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
                                scheduledLabel.style.borderColor = '#667eea';
                                scheduledLabel.style.color = 'white';
                                scheduledLabel.style.transform = 'scale(1.02)';
                                scheduledLabel.style.boxShadow = '0 8px 20px rgba(102, 126, 234, 0.3)';
                                nowLabel.style.background = 'white';
                                nowLabel.style.borderColor = '#e2e8f0';
                                nowLabel.style.color = '#64748b';
                                nowLabel.style.transform = 'scale(1)';
                                nowLabel.style.boxShadow = 'none';
                            }
                        }

                        document.querySelectorAll('input[name="scheduleType"]').forEach(radio => {
                            radio.addEventListener('change', toggleSchedule);
                        });

                        document.getElementById('now-label').addEventListener('click', function () {
                            document.querySelector('input[name="scheduleType"][value="now"]').checked = true;
                            toggleSchedule();
                        });

                        document.getElementById('scheduled-label').addEventListener('click', function () {
                            document.querySelector('input[name="scheduleType"][value="scheduled"]').checked = true;
                            toggleSchedule();
                        });

                        window.addEventListener('DOMContentLoaded', toggleSchedule);
                    </script>

                    <div class="panel-card">
                        <h3>Quick Notes</h3>
                        <div class="field-stack">
                            <div class="ghost-note">Preview uses the exact student renderer, so anything you verify
                                there will match the student version.</div>
                            <div class="ghost-note">Downloaded HTML keeps the same layout, theme options, and
                                interaction logic as the platform view.</div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="section">
                <div class="section-header">
                    <div>
                        <h2>Active Groups</h2>
                        <p>See each group’s roster and currently assigned tests.</p>
                    </div>
                </div>

                <% if (groups.length> 0) { %>
                    <div class="group-grid">
                        <% groups.forEach(group=> { %>
                            <article class="group-card">
                                <div class="group-title-row">
                                    <div class="group-title">
                                        <%= group.name %>
                                    </div>
                                    <button class="btn btn-danger"
                                        onclick="deleteItem('group', '<%= group._id %>', '<%= group.name %>')">Delete</button>
                                </div>

                                <div class="pill-row" style="margin-bottom: 14px;">
                                    <div class="pill neutral">
                                        <%= group.students.length %> students
                                    </div>
                                    <div class="pill neutral">
                                        <%= group.assignedTests.length %> tests
                                    </div>
                                </div>

                                <p style="font-weight: 800; color: #334155; margin-bottom: 8px;">Assigned Tests</p>
                                <div class="pill-row" style="margin-bottom: 16px;">
                                    <% if (group.assignedTests.length> 0) { %>
                                        <% group.assignedTests.forEach(test=> { %>
                                            <div class="pill" style="display:flex;align-items:center;gap:6px;">
                                                <%= test.title %>
                                                    <button type="button"
                                                        onclick="removeTestFromGroup('<%= group._id %>', '<%= test._id %>', '<%= test.title %>')"
                                                        style="border:none; background:none; color:#b91c1c; font-weight:900; cursor:pointer; font-size:1.1rem; line-height:1;">×</button>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="ghost-note" style="width: 100%;">No tests assigned yet.
                                                    </div>
                                                    <% } %>
                                </div>

                                <p style="font-weight: 800; color: #334155; margin-bottom: 8px;">Students</p>
                                <div class="pill-row">
                                    <% if (group.students.length> 0) { %>
                                        <% group.students.forEach(student=> { %>
                                            <div class="pill neutral">
                                                <%= student.username %>
                                                    <button type="button"
                                                        onclick="removeStudentFromGroup('<%= group._id %>', '<%= student._id %>', '<%= student.username %>')"
                                                        style="margin-left:8px; border:none; background:none; color:#b91c1c; font-weight:900; cursor:pointer;">×</button>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="ghost-note" style="width: 100%;">No students in this
                                                        group yet.</div>
                                                    <% } %>
                                </div>
                            </article>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div class="ghost-note">No groups yet. Create one above to start assigning students and tests.
                        </div>
                        <% } %>
            </section>

            <section class="section">
                <div class="section-header">
                    <div>
                        <h2>All Students</h2>
                        <p>Keep track of current group placement and remove student accounts when needed.</p>
                    </div>
                    <a href="/teacher/add-student" class="btn btn-success">+ Register Student</a>
                </div>

                <% if (allStudents.length> 0) { %>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Current Group</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% allStudents.forEach(student=> { %>
                                    <% const activeGroup=groups.find(group=> String(group._id) ===
                                        String(student.groupId)); %>
                                        <tr>
                                            <td style="font-weight: 800;">
                                                <%= student.username %>
                                            </td>
                                            <td>
                                                <% if (activeGroup) { %>
                                                    <span class="tag">
                                                        <%= activeGroup.name %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="tag muted">Unassigned</span>
                                                        <% } %>
                                            </td>
                                            <td>
                                                <div class="action-row">
                                                    <button class="btn btn-secondary"
                                                        onclick="viewPassword('<%= student._id %>', '<%= student.username %>')"
                                                        style="padding:8px 14px;font-size:0.85rem;">🔑 View
                                                        Password</button>
                                                    <button class="btn btn-danger"
                                                        onclick="deleteItem('student', '<%= student._id %>', '<%= student.username %>')">Delete</button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="ghost-note">No students registered yet. Use the register button to create the first
                            student account.</div>
                        <% } %>
            </section>
        </main>


       
</body>

</html>