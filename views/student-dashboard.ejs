<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           PAGE-SPECIFIC STYLES — Student Dashboard
           ============================================================ */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: var(--space-md);
        }

        .hero {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: center;
        }

        .group-pill {
            display: inline-flex;
            align-items: center;
            padding: 9px 14px;
            border-radius: var(--radius-full);
            background: linear-gradient(135deg, var(--primary-500), var(--primary-700));
            color: #fff;
            font-weight: 800;
            margin-top: 12px;
        }

        .type-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: var(--space-md);
        }

        .type-column {
            padding: var(--space-md);
            border-radius: var(--radius-xl);
            border: 1px solid var(--border);
            background: linear-gradient(180deg, var(--surface-glass) 0%, var(--gray-100) 100%);
        }
        .type-column.reading { border-top: 6px solid var(--info); }
        .type-column.listening { border-top: 6px solid var(--success); }
        .type-column.writing { border-top: 6px solid #f97316; }

        .type-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }
        .type-header h3 {
            font-size: 1.12rem;
            font-weight: 900;
            color: var(--text-primary);
        }

        .test-list {
            display: grid;
            gap: 14px;
        }

        .test-card {
            padding: var(--space-md);
            border-radius: var(--radius-lg);
            background: var(--surface);
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
        }
        .test-card h4 {
            font-size: 1.06rem;
            font-weight: 900;
            color: var(--text-primary);
            margin-bottom: 8px;
        }
        .test-card p {
            color: var(--text-secondary);
            line-height: 1.55;
            font-size: 0.92rem;
        }

        .meta-row {
            display: flex;
            flex-wrap: wrap;
            gap: var(--space-sm);
            margin: 14px 0;
        }

        .meta-pill {
            padding: 7px 11px;
            border-radius: var(--radius-full);
            font-size: 0.82rem;
            font-weight: 800;
            background: var(--primary-100);
            color: var(--primary-800);
        }
        .meta-pill.success {
            background: var(--success-bg);
            color: #065f46;
        }
        .meta-pill.warning {
            background: var(--error-bg);
            color: #991b1b;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .st-empty {
            padding: var(--space-md);
            border-radius: var(--radius-md);
            background: var(--surface-glass);
            border: 1px dashed var(--border);
            color: var(--text-muted);
            text-align: center;
        }

        .ai-analysis-callout {
            padding: 12px;
            background: var(--primary-100);
            border-radius: var(--radius-md);
            margin-bottom: 14px;
            border-left: 4px solid var(--primary-500);
        }
        .ai-analysis-callout p {
            color: var(--primary-800);
            font-weight: 700;
            font-size: 0.9rem;
            margin: 0;
        }

        /* ============================================================
           FLOATING AI CHAT BUTTON
           ============================================================ */
        .ai-chat-fab {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--primary-500), var(--primary-700));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4);
            cursor: pointer;
            z-index: 9999;
            transition: all var(--transition-base);
            text-decoration: none;
            border: 3px solid rgba(255, 255, 255, 0.3);
            animation: pulse-fab 2s infinite;
            overflow: hidden;
        }
        .ai-chat-fab::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3) 0%, transparent 60%);
            animation: shimmer-fab 3s infinite;
        }
        .ai-chat-fab:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 40px rgba(99, 102, 241, 0.5);
        }
        .ai-chat-fab:active {
            transform: translateY(-2px) scale(1);
        }
        .ai-chat-fab .icon { position: relative; z-index: 1; }

        .ai-icon {
            width: 40px;
            height: 40px;
            position: relative;
            animation: float-fab 3s ease-in-out infinite;
        }

        .spiral-circle {
            position: absolute;
            border: 2px solid white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: spiral-rotate 4s linear infinite;
        }
        .circle-1 { width: 32px; height: 32px; border-top-color: transparent; border-right-color: transparent; }
        .circle-2 { width: 24px; height: 24px; border-bottom-color: transparent; border-left-color: transparent; animation-duration: 3s; animation-direction: reverse; }
        .circle-3 { width: 16px; height: 16px; border-top-color: transparent; border-right-color: transparent; animation-duration: 2.5s; }

        .center-dot {
            position: absolute;
            width: 6px;
            height: 6px;
            background: white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        .orbit-particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: white;
            border-radius: 50%;
            animation: orbit-around 3s linear infinite;
        }
        .particle-1 { animation-delay: 0s; }
        .particle-2 { animation-delay: 1s; }
        .particle-3 { animation-delay: 2s; }

        @keyframes pulse-fab {
            0%, 100% { box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4); }
            50% { box-shadow: 0 10px 40px rgba(99, 102, 241, 0.6), 0 0 0 10px rgba(99, 102, 241, 0.1); }
        }
        @keyframes shimmer-fab {
            0%, 100% { transform: rotate(0deg) scale(1); opacity: 0.3; }
            50% { transform: rotate(180deg) scale(1.2); opacity: 0.6; }
        }
        @keyframes float-fab {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-4px); }
        }
        @keyframes spiral-rotate {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }
        @keyframes pulse-dot {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
            50% { transform: translate(-50%, -50%) scale(1.5); opacity: 0.6; }
        }
        @keyframes orbit-around {
            0% { transform: translate(-50%, -50%) rotate(0deg) translateX(18px) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translate(-50%, -50%) rotate(360deg) translateX(18px) rotate(-360deg); opacity: 0; }
        }

        @media (max-width: 1180px) {
            .type-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 760px) {
            .hero { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <%- include('partials/notifications') %>
    <div class="container">
        <header class="hero card">
            <div>
                <h1 class="page-title" style="margin-bottom:8px;">Welcome, <%= student.username %></h1>
                <p class="page-subtitle">Your assigned tests are grouped below by skill area so it's easy to jump into the right exam format.</p>
                <% if (groupName && groupName !== 'No Group Assigned') { %>
                    <div class="group-pill"><%= groupName %></div>
                <% } %>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
                <a href="/settings" class="btn btn-ghost btn-sm">⚙️ Settings</a>
                <a href="/student/feedback" class="btn btn-success">🐛 Report Issue</a>
                <a href="/logout" class="btn btn-ghost btn-sm">Logout</a>
            </div>
        </header>

        <section class="card" style="margin-top:var(--space-lg);">
            <div class="page-header" style="margin-bottom:var(--space-md);">
                <div>
                    <h2 class="page-title" style="font-size:1.45rem;">Your Tests</h2>
                    <p class="page-subtitle">Each test opens in the same student view your teacher previewed and can resume from saved progress.</p>
                </div>
                <div style="display:flex;gap:10px;align-items:center;">
                    <input type="text" id="searchTests" class="form-input" style="width:auto;" placeholder="Search tests..." value="<%= pagination.search || '' %>" oninput="searchTests()">
                </div>
            </div>

            <% const typeConfig = [
                { key: 'reading', label: 'Reading', className: 'reading' },
                { key: 'listening', label: 'Listening', className: 'listening' },
                { key: 'writing', label: 'Writing', className: 'writing' }
            ]; %>

            <% if (tests.length > 0) { %>
                <div class="type-grid">
                    <% typeConfig.forEach(type => { const typeTests = testsByType[type.key] || []; %>
                        <div class="type-column <%= type.className %>">
                            <div class="type-header">
                                <h3><%= type.label %></h3>
                                <span class="badge"><%= typeTests.length %> tests</span>
                            </div>

                            <% if (typeTests.length > 0) { %>
                                <div class="test-list">
                                    <% typeTests.forEach(test => { %>
                                        <article class="test-card">
                                            <% if (test.isLocked) { %>
                                                <h4>🔒 Scheduled Test</h4>
                                                <p>This test will be available soon.</p>
                                                <div class="meta-row">
                                                    <span class="meta-pill warning">Locked</span>
                                                    <span class="meta-pill">Available: <%= new Date(test.availableFrom).toLocaleString() %></span>
                                                </div>
                                                <div id="countdown-<%= test._id %>" style="margin-top:12px;font-weight:700;color:var(--primary-500);"></div>
                                                <script>
                                                (function() {
                                                    const target = new Date('<%= test.availableFrom %>').getTime();
                                                    const el = document.getElementById('countdown-<%= test._id %>');
                                                    function update() {
                                                        const now = Date.now();
                                                        const diff = target - now;
                                                        if (diff <= 0) {
                                                            el.textContent = 'Available now! Refresh the page.';
                                                            return;
                                                        }
                                                        const days = Math.floor(diff / 86400000);
                                                        const hours = Math.floor((diff % 86400000) / 3600000);
                                                        const minutes = Math.floor((diff % 3600000) / 60000);
                                                        const seconds = Math.floor((diff % 60000) / 1000);
                                                        el.textContent = `Unlocks in: ${days}d ${hours}h ${minutes}m ${seconds}s`;
                                                        setTimeout(update, 1000);
                                                    }
                                                    update();
                                                })();
                                                </script>
                                            <% } else { %>
                                            <h4><%= test.title %></h4>
                                            <p>Open the live student view and continue from where you left off.</p>

                                            <div class="meta-row">
                                                <% if (test.submission) { %>
                                                    <span class="meta-pill success">Completed</span>
                                                    <% if (test.type === 'writing') { %>
                                                        <span class="meta-pill">Writing saved</span>
                                                    <% } else { %>
                                                        <span class="meta-pill"><%= test.submission.score %>/<%= test.submission.totalQuestions %></span>
                                                    <% } %>
                                                <% } else { %>
                                                    <span class="meta-pill warning">Not submitted yet</span>
                                                <% } %>
                                                <span class="meta-pill">ID <%= test._id.toString().slice(-6) %></span>
                                            </div>

                                            <% if (test.submission && test.submission.lastSubmittedAt) { %>
                                                <p style="margin-bottom: 14px;">Last saved result: <strong><%= new Date(test.submission.lastSubmittedAt).toLocaleString() %></strong></p>
                                                <% if (test.submission.details?.aiAnalysis && (test.type === 'reading' || test.type === 'listening')) { %>
                                                    <div class="ai-analysis-callout">
                                                        <p>🤖 AI Analysis Available</p>
                                                    </div>
                                                <% } %>
                                            <% } %>

                                            <div class="actions">
                                                <a href="/view-test/<%= test._id %>" class="btn btn-primary btn-sm">Open Test</a>
                                                <% if (test.submission && test.submission.details?.aiAnalysis && (test.type === 'reading' || test.type === 'listening')) { %>
                                                    <a href="/student/ai-feedback/<%= test.submission._id %>" class="btn btn-success btn-sm">🤖 View AI Feedback</a>
                                                <% } %>
                                            </div>
                                            <% } %>
                                        </article>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="st-empty">No <%= type.label.toLowerCase() %> tests assigned right now.</div>
                            <% } %>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="st-empty">No tests have been assigned to you yet. Your teacher will place them here when they are ready.</div>
            <% } %>

            <% if (pagination.totalPages > 1) { %>
                <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-top:var(--space-lg);flex-wrap:wrap;">
                    <% if (pagination.page > 1) { %>
                        <a href="?page=<%= pagination.page - 1 %><%= pagination.search ? '&search=' + pagination.search : '' %>" class="btn btn-ghost btn-sm">← Prev</a>
                    <% } %>
                    <span style="font-weight:800;color:var(--text-secondary);font-size:0.9rem;">Page <%= pagination.page %> of <%= pagination.totalPages %> (<%= pagination.total %> tests)</span>
                    <% if (pagination.page < pagination.totalPages) { %>
                        <a href="?page=<%= pagination.page + 1 %><%= pagination.search ? '&search=' + pagination.search : '' %>" class="btn btn-ghost btn-sm">Next →</a>
                    <% } %>
                </div>
            <% } %>
        </section>
    </div>

    <!-- Floating AI Chat Button -->
    <a href="/student/ai-chat" class="ai-chat-fab" title="AI Study Coach">
        <div class="icon">
            <div class="ai-icon">
                <div class="spiral-circle circle-1"></div>
                <div class="spiral-circle circle-2"></div>
                <div class="spiral-circle circle-3"></div>
                <div class="center-dot"></div>
                <div class="orbit-particle particle-1" style="top: 50%; left: 50%;"></div>
                <div class="orbit-particle particle-2" style="top: 50%; left: 50%;"></div>
                <div class="orbit-particle particle-3" style="top: 50%; left: 50%;"></div>
            </div>
        </div>
    </a>

    <script>
        function searchTests() {
            const query = document.getElementById('searchTests').value;
            window.location.href = `/student-dashboard?search=${encodeURIComponent(query)}`;
        }
    </script>
</body>
</html>
