<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Reading Test</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           PAGE-SPECIFIC STYLES — Create Reading Test
           ============================================================ */
        .container { max-width: 1000px; margin: 0 auto; padding: var(--space-md); }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: var(--space-sm);
            color: var(--primary-500);
            text-decoration: none;
            font-weight: 600;
            margin-bottom: var(--space-xl);
            transition: transform var(--transition-base);
        }
        .back-btn:hover { transform: translateX(-4px); color: var(--primary-400); }

        .create-form-section {
            margin-bottom: var(--space-lg);
            animation: slideUp 0.6s ease-out;
        }
        .create-form-section h2 {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: var(--space-lg);
            display: flex;
            align-items: center;
            gap: var(--space-sm);
        }

        .hint {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 6px;
        }

        .button-group {
            display: flex;
            gap: var(--space-md);
            justify-content: flex-end;
            margin-top: var(--space-xl);
            padding-top: var(--space-lg);
            border-top: 1px solid var(--border);
        }

        textarea {
            resize: vertical;
            min-height: 150px;
        }

        @media (max-width: 768px) {
            .button-group { flex-direction: column; }
            .button-group .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>
    <script src="/dark-mode.js"></script>
    <div class="container">
        <a href="/create-test" class="back-btn">← Choose Test Type</a>

        <div class="card create-form-section">
            <h1 style="font-size:2.2rem;font-weight:900;color:var(--text-primary);margin-bottom:8px;display:flex;align-items:center;gap:12px;">📖 Create Reading Test</h1>
            <p style="color:var(--text-secondary);font-size:1.05rem;">Set up your reading comprehension assessment</p>
        </div>

        <form method="POST" action="/create-test-reading">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="card create-form-section">
                <h2>📋 Test Information</h2>

                <div class="form-group">
                    <label for="title">Test Title *</label>
                    <input type="text" id="title" name="title" class="form-input" required placeholder="e.g., Reading Comprehension Module">
                    <div class="hint">Give your test a clear, descriptive name</div>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" class="form-input" placeholder="Describe what students will read and analyze..."></textarea>
                </div>

                <div class="form-group">
                    <label for="duration">Duration (minutes) *</label>
                    <input type="number" id="duration" name="duration" class="form-input" required min="1" placeholder="e.g., 45" value="45">
                </div>
            </div>

            <div class="card create-form-section">
                <h2>📄 Reading Passage</h2>

                <div class="form-group">
                    <label for="passage">Reading Passage *</label>
                    <textarea id="passage" name="passage" class="form-input" required placeholder="Enter the passage that students will read..."></textarea>
                    <div class="hint">Paste the text students will read and analyze</div>
                </div>

                <div class="form-group">
                    <label for="difficulty">Difficulty Level</label>
                    <select id="difficulty" name="difficulty" class="form-select">
                        <option>Beginner</option>
                        <option>Intermediate</option>
                        <option>Advanced</option>
                        <option>Expert</option>
                    </select>
                </div>
            </div>

            <div class="card create-form-section">
                <div class="button-group">
                    <a href="/create-test" class="btn btn-ghost" onclick="return confirm('Are you sure? Progress will be lost.');">Cancel</a>
                    <button type="submit" class="btn btn-primary">Create Reading Test →</button>
                </div>
            </div>
        </form>
    </div>
    <%- include('partials/notifications') %>
</body>
</html>
