<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Teacher</title>
    <%- include('../partials/design-system') %>
    <style>
        /* ============================================================
           ADD TEACHER PAGE — centered form layout
           ============================================================ */
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: var(--space-lg);
            background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-700) 100%);
        }

        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .add-teacher-container {
            max-width: 600px;
            width: 100%;
            animation: slideUp 0.6s ease-out;
        }

        .add-teacher-card {
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: var(--space-2xl);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-xl);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        .add-teacher-header {
            text-align: center;
            margin-bottom: var(--space-xl);
        }
        .add-teacher-header .header-icon { font-size: 3rem; margin-bottom: var(--space-md); }
        .add-teacher-header h1 { font-size: 2rem; font-weight: 900; color: var(--text-primary); margin-bottom: var(--space-sm); }
        .add-teacher-header p { color: var(--text-muted); font-size: 0.95rem; }

        .form-group { margin-bottom: var(--space-lg); }
        .form-group:last-of-type { margin-bottom: var(--space-xl); }

        .button-group { display: flex; gap: var(--space-md); }

        .btn-cancel {
            flex: 1;
            padding: 16px;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            background: var(--gray-100);
            color: var(--text-secondary);
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all var(--transition-base);
            font-family: var(--font-sans);
        }
        .btn-cancel:hover { background: var(--gray-200); }

        .back-link {
            text-align: center;
            margin-top: var(--space-lg);
        }
        .back-link a {
            color: rgba(255, 255, 255, 0.85);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all var(--transition-fast);
        }
        .back-link a:hover { color: #fff; }

        body.dark-mode { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
        body.dark-mode .btn-cancel { background: var(--gray-800); color: var(--text-secondary); }
        body.dark-mode .btn-cancel:hover { background: var(--gray-700); }
        body.dark-mode .back-link a { color: var(--text-muted); }
        body.dark-mode .back-link a:hover { color: var(--primary-300); }

        @media (max-width: 600px) {
            .add-teacher-card { padding: var(--space-xl) var(--space-lg); }
            .add-teacher-header h1 { font-size: 1.5rem; }
            .button-group { flex-direction: column; }
        }
    </style>
</head>
<body>
    <div class="add-teacher-container">
        <div class="add-teacher-card">
            <div class="add-teacher-header">
                <div class="header-icon">👨‍🏫</div>
                <h1>Add New Teacher</h1>
                <p>Register a teacher to your platform</p>
            </div>

            <form method="POST" action="/admin/add-teacher">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="form-group">
                    <label for="username">Username *</label>
                    <input type="text" id="username" name="username" class="form-input" required placeholder="e.g. teacher_john" autocomplete="username">
                </div>

                <div class="form-group">
                    <label for="password">Password *</label>
                    <input type="password" id="password" name="password" class="form-input" required placeholder="••••••••" autocomplete="new-password">
                </div>

                <div class="button-group">
                    <a href="/admin" class="btn-cancel">Cancel</a>
                    <button type="submit" class="btn btn-primary" style="flex:1;padding:16px;font-size:0.95rem;">Add Teacher →</button>
                </div>
            </form>
        </div>

        <div class="back-link">
            <a href="/admin">← Back to Admin</a>
        </div>
    </div>
    <%- include('../partials/notifications') %>
</body>
</html>
