    function initMagicPaste() {
        document.querySelectorAll('.magic-paste').forEach(el => {
            el.addEventListener('paste', function(e) {
                const items = (e.clipboardData || e.originalEvent.clipboardData).items;
                let hasImage = false;
                for (let index in items) {
                    const item = items[index];
                    if (item.kind === 'file' && item.type.includes('image/')) {
                        hasImage = true;
                        e.preventDefault(); 
                        const blob = item.getAsFile();
                        const reader = new FileReader();
                        reader.onload = function(event) {
                            const base64 = event.target.result;
                            const htmlTag = `<img src="${base64}" style="max-width:100%; display:block; margin:10px auto; border:1px solid #ddd; border-radius:8px;">`;
                            insertAtCursor(el, htmlTag);
                        };
                        reader.readAsDataURL(blob);
                    }
                }
                if(hasImage) {
                    const tip = el.closest('.tab-content').querySelector('.paste-tip');
                    if(tip) { tip.style.display = 'block'; setTimeout(() => tip.style.display = 'none', 3000); }
                }
            });
        });
    }

    function handleImagePaste(e, el) {
        const items = (e.clipboardData || e.originalEvent.clipboardData).items;
        for (let index in items) {
            const item = items[index];
            if (item.kind === 'file' && item.type.includes('image/')) {
                e.preventDefault();
                const blob = item.getAsFile();
                const reader = new FileReader();
                reader.onload = function(event) {
                    const base64 = event.target.result;
                    const htmlTag = `<img src="${base64}" style="max-width:100%; display:block; margin:10px auto; border:1px solid #ddd; border-radius:8px;">`;
                    document.execCommand('insertHTML', false, htmlTag);
                };
                reader.readAsDataURL(blob);
                return;
            }
        }
    }

    function insertAtCursor(field, text) {
        if (typeof field === 'string') field = document.getElementById(field);
        if (!field) return;

        if (field.tagName === 'TEXTAREA' || field.tagName === 'INPUT') {
            if (document.selection) { field.focus(); let sel = document.selection.createRange(); sel.text = text; }
            else if (field.selectionStart || field.selectionStart === 0) { let startPos = field.selectionStart; let endPos = field.selectionEnd; field.value = field.value.substring(0, startPos) + text + field.value.substring(endPos, field.value.length); field.selectionStart = startPos + text.length; field.selectionEnd = startPos + text.length; }
            else { field.value += text; }
        } else {
            if (lastSavedRange) {
                const sel = window.getSelection();
                sel.removeAllRanges();
                sel.addRange(lastSavedRange);
            } else { field.focus(); }
            document.execCommand('insertHTML', false, text);
        }
    }

