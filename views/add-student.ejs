<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           ADD STUDENT PAGE — centered form layout
           ============================================================ */
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: var(--space-lg);
            background: linear-gradient(135deg, var(--primary-500) 0%, var(--primary-700) 100%);
        }

        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .add-student-container {
            max-width: 500px;
            width: 100%;
            animation: slideUp 0.6s ease-out;
        }

        .add-student-card {
            background: var(--surface-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            padding: var(--space-2xl);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-xl);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        .add-student-header {
            text-align: center;
            margin-bottom: var(--space-xl);
        }

        .add-student-header .header-icon { font-size: 3rem; margin-bottom: var(--space-md); }

        .add-student-header h1 {
            font-size: 2rem;
            font-weight: 900;
            color: var(--text-primary);
            margin-bottom: var(--space-sm);
        }

        .add-student-header p { color: var(--text-muted); font-size: 0.95rem; }

        .form-group { margin-bottom: var(--space-lg); }
        .form-group:last-of-type { margin-bottom: var(--space-xl); }

        .hint {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 6px;
        }

        .password-row { display: flex; align-items: center; gap: 10px; }
        .password-row .form-input { flex: 1; }

        .toggle-password {
            padding: 12px 14px;
            border-radius: var(--radius-md);
            border: 2px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all var(--transition-fast);
            flex: 0 0 auto;
            font-family: var(--font-sans);
        }
        .toggle-password:hover {
            border-color: var(--primary-400);
            box-shadow: var(--shadow-glow);
        }

        .button-group { display: flex; gap: var(--space-md); }

        .btn-cancel {
            flex: 1;
            padding: 16px;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            background: var(--gray-100);
            color: var(--text-secondary);
            transition: all var(--transition-base);
            font-family: var(--font-sans);
            text-align: center;
        }
        .btn-cancel:hover { background: var(--gray-200); }

        .back-link {
            text-align: center;
            margin-top: var(--space-lg);
        }
        .back-link a {
            color: rgba(255, 255, 255, 0.85);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all var(--transition-fast);
        }
        .back-link a:hover { color: #fff; }

        .alert {
            padding: 16px 18px;
            border-radius: var(--radius-md);
            margin-bottom: var(--space-lg);
            display: none;
            animation: slideUp 0.3s ease-out;
            font-weight: 600;
            font-size: 0.9rem;
        }
        .alert.show { display: block; }
        .alert.success { background: var(--success-bg); color: #065f46; border: 1px solid var(--success); }
        .alert.error { background: var(--error-bg); color: #991b1b; border: 1px solid var(--error); }

        body.dark-mode { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
        body.dark-mode .btn-cancel { background: var(--gray-800); color: var(--text-secondary); }
        body.dark-mode .btn-cancel:hover { background: var(--gray-700); }
        body.dark-mode .back-link a { color: var(--text-muted); }
        body.dark-mode .back-link a:hover { color: var(--primary-300); }

        @media (max-width: 600px) {
            .add-student-card { padding: var(--space-xl) var(--space-lg); }
            .add-student-header h1 { font-size: 1.5rem; }
            .button-group { flex-direction: column; }
        }
    </style>
    <script>
        async function handleSubmit(e) {
            e.preventDefault();

            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value;
            const submitBtn = e.target.querySelector('.btn-submit');
            const alertDiv = document.getElementById('alert');

            // Clear previous alert
            alertDiv.textContent = '';
            alertDiv.className = 'alert';

            // Validation
            if (!username) {
                showAlert('Please enter a username', 'error');
                return;
            }

            if (username.length < 3) {
                showAlert('Username must be at least 3 characters', 'error');
                return;
            }

            if (!password) {
                showAlert('Please enter a password', 'error');
                return;
            }

            if (password.length < 6) {
                showAlert('Password must be at least 6 characters', 'error');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Creating...';

            try {
                const csrfToken = '<%= csrfToken %>';
                const response = await fetch('/teacher/add-student', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-csrf-token': csrfToken
                    },
                    body: JSON.stringify({ username, password })
                });

                const data = await response.json();

                if (data.success) {
                    showAlert(data.message, 'success');
                    setTimeout(() => {
                        window.location.href = data.redirect || '/teacher-dashboard';
                    }, 1500);
                } else {
                    showAlert(data.message || 'Error creating student', 'error');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Create Student →';
                }
            } catch (error) {
                showAlert('Network error: ' + error.message, 'error');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Create Student →';
            }
        }

        function showAlert(message, type) {
            const alertDiv = document.getElementById('alert');
            alertDiv.textContent = message;
            alertDiv.className = 'alert ' + type + ' show';
        }

        function togglePasswordVisibility() {
            const input = document.getElementById('password');
            const btn = document.getElementById('togglePasswordBtn');
            if (!input || !btn) return;
            const nextType = input.type === 'password' ? 'text' : 'password';
            input.type = nextType;
            btn.textContent = nextType === 'text' ? 'Hide' : 'Show';
        }
    </script>
</head>
<body>
    <div class="add-student-container">
        <div class="add-student-card">
            <div class="add-student-header">
                <div class="header-icon">👤</div>
                <h1>Add New Student</h1>
                <p>Register a student to your platform</p>
            </div>

            <div id="alert" class="alert"></div>

            <form onsubmit="handleSubmit(event)">
                <div class="form-group">
                    <label for="username">Student Username *</label>
                    <input type="text" id="username" name="username" class="form-input" required placeholder="john_doe" autocomplete="off">
                    <div class="hint">Unique username for the student (minimum 3 characters)</div>
                </div>

                <div class="form-group">
                    <label for="password">Password *</label>
                    <div class="password-row">
                        <input type="password" id="password" name="password" class="form-input" required placeholder="••••••••" autocomplete="new-password">
                        <button type="button" id="togglePasswordBtn" class="toggle-password" onclick="togglePasswordVisibility()">Show</button>
                    </div>
                    <div class="hint">Minimum 6 characters</div>
                </div>

                <div class="button-group">
                    <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-submit" style="flex:1;padding:16px;font-size:0.95rem;">Create Student →</button>
                </div>
            </form>
        </div>

        <div class="back-link">
            <a href="/teacher-dashboard">← Back to Dashboard</a>
        </div>
    </div>
    <%- include('partials/notifications') %>
</body>
</html>
