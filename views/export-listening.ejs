    /* --- NOTION-STYLE DROPDOWN LOGIC --- */
    function toggleCustomSelect(trigger) {
        if(isSubmitted) return;
        const wrapper = trigger.closest('.custom-select-wrapper');
        const matchItem = trigger.closest('.match-item');
        const wasOpen = wrapper.classList.contains('open');
        
        document.querySelectorAll('.custom-select-wrapper').forEach(w => {
            w.classList.remove('open');
            w.style.zIndex = '1';
            const mi = w.closest('.match-item');
            if(mi) mi.style.zIndex = '1';
        });

        if (!wasOpen) {
            wrapper.classList.add('open');
            wrapper.style.zIndex = '1000';
            if(matchItem) { 
                matchItem.style.position = 'relative'; 
                matchItem.style.zIndex = '1000'; 
            }
        }
    }

    function selectCustomOption(optEl, qId, val) {
        if(isSubmitted) return;
        const wrapper = optEl.closest('.custom-select-wrapper');
        const triggerText = wrapper.querySelector('.sel-text');
        const trigger = wrapper.querySelector('.custom-select-trigger');
        const input = document.getElementById('q' + qId);
        
        input.value = val;
        if (val === '') {
            triggerText.innerText = 'Select...';
            trigger.classList.remove('answered');
        } else {
            triggerText.innerHTML = `<span class="anim-answer">${val}</span>`;
            trigger.classList.add('answered');
        }
        
        wrapper.classList.remove('open');
        wrapper.style.zIndex = '1';
        const matchItem = wrapper.closest('.match-item');
        if(matchItem) matchItem.style.zIndex = '1';
        
        saveState();
    }

    /* --- CHECKBOX LIMIT LOGIC --- */
    function updatePickNStates() {
        if(isSubmitted) return;
        document.querySelectorAll('.pick-n-question').forEach(group => {
            const limit = parseInt(group.dataset.limit);
            const boxes = group.querySelectorAll('input[type="checkbox"]');
            const checkedCount = group.querySelectorAll('input[type="checkbox"]:checked').length;
            
            boxes.forEach(box => {
                if (!box.checked) {
                    box.disabled = (checkedCount >= limit);
                }
            });
        });
    }

