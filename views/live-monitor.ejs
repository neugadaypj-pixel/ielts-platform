<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Monitor — <%= test.title %></title>
    <%- include('../partials/design-system') %>
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            padding: 24px;
            color: var(--text-primary);
        }
        .monitor-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 24px 28px;
            border-radius: var(--radius-xl);
            background: var(--surface-glass);
            box-shadow: var(--shadow-xl);
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 16px;
        }
        .monitor-header h1 { font-size: 1.6rem; font-weight: 900; }
        .monitor-header p { color: var(--text-muted); margin-top: 4px; }
        .live-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 999px;
            background: #fee2e2;
            color: #dc2626;
            font-weight: 800;
            font-size: 0.9rem;
        }
        .live-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
            background: #dc2626;
            animation: pulse 1.2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.8); }
        }
        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }
        .stat-card {
            padding: 20px 24px;
            border-radius: var(--radius-lg);
            background: var(--surface-glass);
            box-shadow: var(--shadow-md);
            text-align: center;
        }
        .stat-value { font-size: 2rem; font-weight: 900; color: var(--text-primary); }
        .stat-label { color: var(--text-muted); font-size: 0.88rem; margin-top: 4px; }
        .table-card {
            padding: 24px;
            border-radius: var(--radius-xl);
            background: var(--surface-glass);
            box-shadow: var(--shadow-xl);
        }
        .table-card h2 { font-size: 1.2rem; font-weight: 900; margin-bottom: 16px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 14px 12px; border-bottom: 1px solid var(--border); }
        th { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); }
        td { color: var(--text-secondary); }
        .progress-bar {
            height: 8px;
            border-radius: 999px;
            background: var(--gray-200);
            overflow: hidden;
            min-width: 80px;
        }
        .progress-fill {
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            transition: width 0.5s ease;
        }
        .empty { color: var(--text-muted); text-align: center; padding: 40px; }
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            padding: 10px 18px;
            border-radius: 999px;
            background: white;
            border: 1px solid var(--border);
            color: var(--text-secondary);
            font-weight: 700;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .back-btn:hover { background: var(--gray-50); }
        .refresh-note { color: var(--text-muted); font-size: 0.85rem; margin-top: 8px; }
        .warning-badge {
            display: inline-block;
            margin-top: 6px;
            padding: 3px 8px;
            background: #fca5a5;
            color: #7f1d1d;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 700;
        }
        .writing-preview {
            padding: 8px;
            background: var(--gray-50);
            border-radius: 8px;
            font-size: 0.85rem;
            color: var(--text-secondary);
            max-height: 60px;
            overflow: hidden;
            margin-top: 4px;
        }
        @media (max-width: 768px) {
            .stats-row { grid-template-columns: 1fr; }
            .monitor-header { flex-direction: column; text-align: center; }
        }
    </style>
</head>
<body>
    <div class="monitor-header">
        <div>
            <h1>📡 Live Monitor</h1>
            <p><strong><%= test.title %></strong> &mdash; <%= test.type %> test</p>
            <p class="refresh-note">Updates instantly as students answer questions. Students appear within 5 seconds of opening the test.</p>
        </div>
        <div style="display:flex; gap:12px; align-items:center;">
            <div class="live-badge"><div class="live-dot"></div> LIVE</div>
            <a href="/teacher-dashboard" class="back-btn">← Dashboard</a>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-value" id="statActive">0</div>
            <div class="stat-label">Active Students</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="statAvg">—</div>
            <div class="stat-label">Avg. Progress</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="statPart">—</div>
            <div class="stat-label">Most Common Part</div>
        </div>
    </div>

    <div class="table-card">
        <h2>Student Activity</h2>
        <table>
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Progress</th>
                    <th>Answered</th>
                    <th>Current Part</th>
                    <th>Time Remaining</th>
                </tr>
            </thead>
            <tbody id="studentTable"></tbody>
        </table>
    </div>

    <script>
        const TEST_ID = '<%= testId %>';

        function updateStats(students) {
            document.getElementById('statActive').textContent = students.length;
            if (students.length === 0) {
                document.getElementById('statAvg').textContent = '—';
                document.getElementById('statPart').textContent = '—';
                return;
            }
            const avg = Math.round(students.reduce((sum, s) => sum + getProgressPercent(s), 0) / students.length);
            document.getElementById('statAvg').textContent = avg + '%';
            const partCounts = {};
            students.forEach(s => { if (s.currentPart) partCounts[s.currentPart] = (partCounts[s.currentPart] || 0) + 1; });
            const topPart = Object.entries(partCounts).sort((a, b) => b[1] - a[1])[0];
            document.getElementById('statPart').textContent = topPart ? topPart[0] : '—';
        }

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, function(ch) {
                return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[ch];
            });
        }

        function getProgressPercent(student) {
            const total = Number(student.totalCount) || 0;
            const answered = Number(student.answeredCount) || 0;
            if (total <= 0) return 0;
            return Math.max(0, Math.min(100, Math.round((answered / total) * 100)));
        }

        function renderTable(students) {
            const tbody = document.getElementById('studentTable');
            if (students.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="empty">No active students yet. They will appear here once they open the test.</td></tr>';
                return;
            }
            tbody.innerHTML = students.map(s => {
                const isWriting = s.type === 'writing';
                const violations = s.examGuardViolations || 0;
                const lastReason = s.examGuardLastReason || '';
                const safeStudentName = escapeHtml(s.studentName || 'Student');
                const safeCurrentPart = escapeHtml(s.currentPart || '—');
                const safeTimeRemaining = escapeHtml(s.timeRemaining || '—');
                const safeTask1Preview = escapeHtml(s.task1Preview || '');
                const safeTask2Preview = escapeHtml(s.task2Preview || '');
                const warningBadge = violations > 0
                    ? `<span style="display:inline-block;margin-top:6px;padding:3px 8px;background:#fca5a5;color:#7f1d1d;border-radius:999px;font-size:0.75rem;font-weight:700;">${violations} violation${violations > 1 ? 's' : ''}${lastReason ? ': ' + escapeHtml(lastReason) : ''}</span>`
                    : '';
                if (isWriting) {
                    return `<tr>
                        <td><strong>${safeStudentName}</strong>${warningBadge ? `<br>${warningBadge}` : ''}</td>
                        <td colspan="2">
                            <div style="margin-bottom:6px;">
                                <span style="font-size:0.8rem;font-weight:700;color:#667eea;">Task 1</span>
                                <span style="font-size:0.8rem;color:#64748b;margin-left:6px;">${s.wordCount1 ? escapeHtml(s.wordCount1) + ' words' : ''}</span>
                                <div style="margin-top:4px;padding:8px;background:#f8fafc;border-radius:8px;font-size:0.85rem;color:#334155;max-height:60px;overflow:hidden;">${safeTask1Preview || '<em style="color:#94a3b8">Not started</em>'}</div>
                            </div>
                            <div>
                                <span style="font-size:0.8rem;font-weight:700;color:#f97316;">Task 2</span>
                                <span style="font-size:0.8rem;color:#64748b;margin-left:6px;">${s.wordCount2 ? escapeHtml(s.wordCount2) + ' words' : ''}</span>
                                <div style="margin-top:4px;padding:8px;background:#f8fafc;border-radius:8px;font-size:0.85rem;color:#334155;max-height:60px;overflow:hidden;">${safeTask2Preview || '<em style="color:#94a3b8">Not started</em>'}</div>
                            </div>
                        </td>
                        <td>${safeCurrentPart}</td>
                        <td>${safeTimeRemaining}</td>
                    </tr>`;
                }
                const pct = getProgressPercent(s);
                return `<tr>
                    <td><strong>${safeStudentName}</strong>${warningBadge ? `<br>${warningBadge}` : ''}</td>
                    <td>
                        <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
                        <span style="font-size:0.8rem;color:#64748b">${pct}%</span>
                    </td>
                    <td>${Math.max(0, Number(s.answeredCount) || 0)} / ${Math.max(0, Number(s.totalCount) || 0)}</td>
                    <td>${safeCurrentPart}</td>
                    <td>${safeTimeRemaining}</td>
                </tr>`;
            }).join('');
        }

        const evtSource = new EventSource('/api/live-stream/' + TEST_ID);
        evtSource.onmessage = function(e) {
            const data = JSON.parse(e.data);
            updateStats(data.students);
            renderTable(data.students);
        };
        evtSource.onerror = function() {
            // Fallback to polling if SSE fails
            setTimeout(() => {
                fetch('/api/live-data/' + TEST_ID, { credentials: 'same-origin' })
                    .then(r => r.json())
                    .then(data => { updateStats(data.students); renderTable(data.students); })
                    .catch(() => {});
            }, 3500);
        };
    </script>
    <%- include('../partials/notifications') %>
</body>
</html>
