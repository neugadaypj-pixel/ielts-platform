{
  "name": "test-platform",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "build": "bash render-build.sh",
    "start": "node server-oracle.js",
    "start:mongo": "node server.js",
    "dev": "nodemon server-oracle.js",
    "dev:mongo": "nodemon server.js",
    "migrate": "node migrate-to-oracle.js",
    "clear-oracle": "node clear-oracle.js",
    "check-oracle": "node check-oracle-data.js",
    "clear-sessions": "node clear-sessions.js",
    "predeploy": "node clear-sessions.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.51.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "mime-types": "^2.1.35",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "oracledb": "^6.10.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server.js",
      "models/**/*.js",
      "utils/**/*.js",
      "middleware/**/*.js"
    ]
  }
