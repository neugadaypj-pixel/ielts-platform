        inputNode.readOnly = true;
        inputNode.value = '[Q' + finalQ + ']';

        if (savedRange) {
            savedRange.deleteContents();
            savedRange.insertNode(inputNode);
            const spaceNode = document.createTextNode('\u00A0');
            inputNode.parentNode.insertBefore(spaceNode, inputNode.nextSibling);

            const newSel = window.getSelection();
            newSel.removeAllRanges();
            savedRange.setStartAfter(spaceNode);
            savedRange.collapse(true);
            newSel.addRange(savedRange);
        } else {
            editor.appendChild(inputNode);
        }

        saveSelection();

        updateAnswerKey(finalQ, ans);
        qNumInput.value = parseInt(finalQ) + 1;
