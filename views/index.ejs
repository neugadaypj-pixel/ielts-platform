<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test Platform</title>
    <%- include('partials/design-system') %>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
            background: linear-gradient(135deg, var(--primary-400) 0%, var(--primary-600) 100%);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        body.dark-mode {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
        .home-container {
            max-width: 1200px;
            width: 100%;
            padding: 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }
        .home-content {
            color: white;
        }
        .logo-icon {
            font-size: 5rem;
            margin-bottom: 20px;
            animation: float 3s ease-in-out infinite;
        }
        @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }
        .home-content h1 {
            font-size: 3.5rem;
            font-weight: 900;
            margin-bottom: 20px;
            line-height: 1.1;
            letter-spacing: -0.02em;
        }
        .home-content p {
            font-size: 1.1rem;
            opacity: 0.95;
            margin-bottom: 32px;
            line-height: 1.8;
        }
        .cta-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }
        .btn-home {
            padding: 16px 32px;
            border-radius: var(--radius-md);
            font-weight: 700;
            font-size: 1rem;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-home-primary {
            background: white;
            color: var(--primary-400);
            box-shadow: var(--shadow-lg);
        }
        .btn-home-primary:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-xl);
        }
        .btn-home-secondary {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            color: white;
            border: 2px solid white;
        }
        .btn-home-secondary:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
        }
        .features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-top: 40px;
        }
        .feature-item {
            display: flex;
            gap: 12px;
            align-items: center;
            opacity: 0.9;
            font-size: 0.95rem;
        }
        .feature-icon { font-size: 1.5rem; }
        .illustration-box {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: var(--radius-xl);
            padding: 60px 40px;
            text-align: center;
        }
        .illustration-icon {
            font-size: 8rem;
            margin-bottom: 20px;
            animation: float 4s ease-in-out infinite;
        }
        .illustration-text {
            color: white;
            font-size: 1.3rem;
            font-weight: 700;
            opacity: 0.95;
        }
        @media (max-width: 1024px) {
            .home-container { grid-template-columns: 1fr; gap: 40px; }
            .home-content h1 { font-size: 2.5rem; }
        }
        @media (max-width: 768px) {
            .home-content h1 { font-size: 2rem; }
            .cta-buttons { flex-direction: column; }
            .btn-home { justify-content: center; }
            .features { grid-template-columns: 1fr; }
            .illustration-box { padding: 40px 20px; }
            .illustration-icon { font-size: 5rem; }
        }
        body.dark-mode .home-content { color: #e2e8f0; }
        body.dark-mode .illustration-box { background: rgba(30, 41, 59, 0.2); border-color: rgba(102, 126, 234, 0.3); }
        body.dark-mode .illustration-text { color: #cbd5e1; }
        body.dark-mode .feature-item { color: #cbd5e1; }
        body.dark-mode .btn-home-secondary { background: rgba(255, 255, 255, 0.1); border-color: rgba(255, 255, 255, 0.3); color: #e2e8f0; }
    </style>
</head>
<body>
    <div class="home-container">
        <div class="home-content">
            <div class="logo-icon">📚</div>
            <h1>Assessment Excellence Platform</h1>
            <p>Create, assign, and evaluate tests with ease. Empower teachers and students with a modern, intuitive testing platform.</p>
            
            <div class="cta-buttons">
                <a href="/login" class="btn-home btn-home-primary">🔐 Get Started</a>
            </div>
            
            <div class="features">
                <div class="feature-item">
                    <span class="feature-icon">✅</span>
                    <span>Multiple Test Types</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">📊</span>
                    <span>Detailed Analytics</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">👥</span>
                    <span>Group Management</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">📱</span>
                    <span>Fully Responsive</span>
                </div>
            </div>
        </div>
        
        <div class="illustration-box">
            <div class="illustration-icon">🎯</div>
            <div class="illustration-text">Ready to Test?</div>
        </div>
    </div>
    <%- include('partials/notifications') %>
</body>
</html>
