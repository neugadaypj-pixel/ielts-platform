<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings</title>
    <%- include('partials/design-system') %>
    <style>
        /* ============================================================
           SETTINGS PAGE — setting rows + password form + export
           ============================================================ */
        body { padding: var(--space-lg); }
        .settings-container { max-width: 800px; margin: 0 auto; }

        .settings-section {
            background: var(--surface-glass);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-radius: var(--radius-lg);
            padding: var(--space-xl);
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(255,255,255,0.12);
            margin-bottom: var(--space-lg);
        }
        .settings-section h2 { font-size: 1.2rem; font-weight: 900; margin-bottom: var(--space-md); color: var(--text-primary); }

        .setting-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: var(--space-md) 0;
            border-bottom: 1px solid var(--border);
        }
        .setting-row:last-child { border-bottom: none; }
        .setting-label { font-weight: 700; color: var(--text-primary); }
        .setting-desc { color: var(--text-muted); font-size: 0.85rem; margin-top: 2px; }

        .toggle {
            position: relative;
            width: 56px;
            height: 28px;
            background: var(--gray-300);
            border-radius: var(--radius-full);
            cursor: pointer;
            transition: background var(--transition-fast);
            flex-shrink: 0;
        }
        .toggle.active { background: linear-gradient(135deg, var(--primary-500), var(--primary-600)); }
        .toggle-knob {
            position: absolute;
            top: 3px;
            left: 3px;
            width: 22px;
            height: 22px;
            background: #fff;
            border-radius: var(--radius-full);
            transition: transform var(--transition-fast);
        }
        .toggle.active .toggle-knob { transform: translateX(28px); }

        #passwordMessage { display: none; padding: var(--space-sm) var(--space-md); border-radius: var(--radius-sm); font-weight: 700; font-size: 0.9rem; }

        @media (max-width: 480px) {
            .setting-row { flex-direction: column; align-items: flex-start; gap: var(--space-sm); }
        }
    </style>
</head>
<body>
    <div class="settings-container">
        <div class="page-header">
            <div>
                <h1 class="page-title">⚙️ Settings</h1>
                <p class="page-subtitle">Customize your platform experience</p>
            </div>
            <a href="/<%= user.role === 'admin' ? 'admin' : user.role === 'teacher' ? 'teacher-dashboard' : 'student-dashboard' %>" class="btn btn-ghost btn-sm">← Back</a>
        </div>

        <div class="settings-section">
            <h2>Appearance</h2>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Dark Mode</div>
                    <div class="setting-desc">Switch to a darker color scheme for reduced eye strain</div>
                </div>
                <div class="toggle" id="darkModeToggle" onclick="toggleDarkMode()">
                    <div class="toggle-knob"></div>
                </div>
            </div>
        </div>

        <div class="settings-section">
            <h2>Account Information</h2>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Username</div>
                    <div class="setting-desc"><%= user.username %></div>
                </div>
            </div>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Role</div>
                    <div class="setting-desc" style="text-transform:capitalize;"><%= user.role %></div>
                </div>
            </div>
            <% if (user.createdAt) { %>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Member Since</div>
                    <div class="setting-desc"><%= new Date(user.createdAt).toLocaleDateString() %></div>
                </div>
            </div>
            <% } %>
            <% if (user.role === 'student' && stats) { %>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Total Tests Taken</div>
                    <div class="setting-desc"><%= stats.totalTests %></div>
                </div>
            </div>
            <% } %>
        </div>

        <% if (user.role === 'student') { %>
        <div class="settings-section">
            <h2>Change Password</h2>
            <form id="passwordForm" style="display:grid;gap:var(--space-md);">
                <div class="form-group">
                    <label for="currentPassword">Current Password</label>
                    <input type="password" id="currentPassword" name="currentPassword" class="form-input" required>
                </div>
                <div class="form-group">
                    <label for="newPassword">New Password</label>
                    <input type="password" id="newPassword" name="newPassword" class="form-input" required minlength="6">
                </div>
                <div class="form-group">
                    <label for="confirmPassword">Confirm New Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" required minlength="6">
                </div>
                <button type="submit" class="btn btn-primary" style="justify-content:center;">Change Password</button>
                <div id="passwordMessage"></div>
            </form>
        </div>

        <div class="settings-section">
            <h2>Export Data</h2>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Progress Report</div>
                    <div class="setting-desc">Download a comprehensive HTML report of your test performance</div>
                </div>
                <a href="/settings/export-report" class="btn btn-success btn-sm">Download Report</a>
            </div>
            <div class="setting-row">
                <div>
                    <div class="setting-label">Test History</div>
                    <div class="setting-desc">Export all your test submissions as CSV file</div>
                </div>
                <a href="/settings/export-history" class="btn btn-sm" style="background:linear-gradient(135deg,#3b82f6,#2563eb);color:#fff;">Download CSV</a>
            </div>
        </div>
        <% } %>
    </div>

    <script src="/dark-mode.js"></script>
    <script>
        // Initialize toggle state
        if (isDarkMode()) {
            document.getElementById('darkModeToggle').classList.add('active');
        }

        // Password change form
        const passwordForm = document.getElementById('passwordForm');
        if (passwordForm) {
            passwordForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const currentPassword = document.getElementById('currentPassword').value;
                const newPassword = document.getElementById('newPassword').value;
                const confirmPassword = document.getElementById('confirmPassword').value;
                const messageDiv = document.getElementById('passwordMessage');

                if (newPassword !== confirmPassword) {
                    messageDiv.textContent = 'New passwords do not match';
                    messageDiv.style.display = 'block';
                    messageDiv.style.background = 'var(--error-bg)';
                    messageDiv.style.color = '#991b1b';
                    return;
                }

                try {
                    const response = await fetch('/settings/change-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ currentPassword, newPassword })
                    });

                    const data = await response.json();

                    if (data.success) {
                        messageDiv.textContent = data.message;
                        messageDiv.style.display = 'block';
                        messageDiv.style.background = 'var(--success-bg)';
                        messageDiv.style.color = '#065f46';
                        passwordForm.reset();
                    } else {
                        messageDiv.textContent = data.message;
                        messageDiv.style.display = 'block';
                        messageDiv.style.background = 'var(--error-bg)';
                        messageDiv.style.color = '#991b1b';
                    }
                } catch (err) {
                    messageDiv.textContent = 'Error changing password';
                    messageDiv.style.display = 'block';
                    messageDiv.style.background = 'var(--error-bg)';
                    messageDiv.style.color = '#991b1b';
                }
            });
        }
    </script>
    <%- include('partials/notifications') %>
</body>
</html>
